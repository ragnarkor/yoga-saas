page {
  background-color: #f6f7f5;

  /* === Yoga Wellness Design System - Sage Green + Warm Terracotta === */
  --projectColor: #5b8a72;
  --projectColorLight: #e3efe8;
  --projectCompareColor: #d4956b;
  --projectColorDark: #4a7160;
  --projectAccent: #c8895a;
  --projectBgSoft: #fafbf9;

  /*#### 父组件日历颜色定义*/
  /* 整体颜色 */
  --calendarPageColor: #fff;
  /* 加重颜色*/
  --calendarMainColor: #5b8a72 !important;
  /* 加重的亮颜色 用于选中日期的数据小圆点 */
  --calendarLightColor: #8bb3a0;
}

.text-project {
  color: var(--projectColor) !important;
}

.bg-project {
  background-color: var(--projectColor) !important;
}

.bg-project.light {
  color: var(--projectColor) !important;
  background-color: var(--projectColorLight) !important;
}

.border-project {
  border-color: var(--projectColor) !important;
}

.tabs .cur {
  color: var(--projectColor) !important;
}

.tabs .tab-menu.cur:after {
  background-color: var(--projectColor) !important;
}

.load-project {
  color: #8799a3 !important;
}

.padding-project {
  padding-left: 20rpx !important;
  padding-right: 20rpx !important;
}

.btn-project {
  line-height: 88rpx;
  height: 88rpx;
  color: #fff;
  background-color: var(--projectColor);
  border-radius: 44rpx;
  width: 98%;
  box-shadow: 0 8rpx 24rpx rgba(91, 138, 114, 0.25);
  font-weight: 500;
  letter-spacing: 2rpx;
  transition: all 0.25s ease;
}

.btn-project:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(91, 138, 114, 0.2);
}

.shadow-project {
  box-shadow: 0 4rpx 20rpx rgba(91, 138, 114, 0.08);
}

.card-project,
.main .list .item.card-project,
.down .comm-list.menu.card-project,
.article-box .article.card-project,
.text-pic-list-box .item.card-project,
.info-list-box .item.card-project,
.main-content .content.card-project,
.meet-list-box .item.card-project,
.form-box.card-project,
.bar .search-form {
  border-radius: 20rpx !important;
}

.up-project {
  width: 100%;
  min-height: 200rpx;
  background-color: unset;
  padding: 0;
  margin: 0;
}

.up-project image {
  padding: 0;
  width: 100%;
  margin: 0;
}

.main .comm-list .item.arrow::before,
.my-icon-project {
  color: var(--projectColor) !important;
}

.meet-list-box {
  padding: 20rpx 30rpx 30rpx 30rpx;
}
