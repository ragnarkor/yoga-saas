<!-- A00 定制首页 - 健心瑜伽馆高端定制版（与 default 标准模板完全区分） -->
<view class="a00-home">

	<!-- Hero 品牌区 -->
	<view class="a00-hero">
		<view class="a00-hero-bg"></view>
		<view class="a00-hero-inner">
			<view class="a00-hero-tag">✦ PREMIUM YOGA ✦</view>
			<view class="a00-hero-brand">健心瑜伽馆</view>
			<view class="a00-hero-slogan">高端定制瑜伽体验中心</view>
			<view class="a00-hero-btn" bindtap="url" data-url="../../../../pages/default/calendar/index/calendar_index">
				<text>立即约课</text>
				<text class="a00-hero-arrow">→</text>
			</view>
		</view>
	</view>

	<!-- 功能入口卡片 -->
	<view class="a00-features">
		<view class="a00-feat-card" bindtap="url" data-url="../../../../pages/default/calendar/index/calendar_index">
			<view class="a00-feat-icon a00-icon-1">🧘</view>
			<view class="a00-feat-name">课程预约</view>
		</view>
		<view class="a00-feat-card" bindtap="url" data-url="../../../../pages/default/news/index/news_index?id=1">
			<view class="a00-feat-icon a00-icon-2">📋</view>
			<view class="a00-feat-name">馆内动态</view>
		</view>
		<view class="a00-feat-card" bindtap="url" data-url="../../../../pages/default/news/index/news_index?id=2">
			<view class="a00-feat-icon a00-icon-3">💡</view>
			<view class="a00-feat-name">瑜伽常识</view>
		</view>
		<view class="a00-feat-card" bindtap="url" data-url="../../../../pages/default/about/index/about_index">
			<view class="a00-feat-icon a00-icon-4">🏠</view>
			<view class="a00-feat-name">关于我们</view>
		</view>
	</view>

	<!-- 动态资讯区 -->
	<view class="a00-section">
		<view class="a00-sec-header">
			<view class="a00-sec-line"></view>
			<view class="a00-sec-title">馆内动态</view>
			<view class="a00-sec-line"></view>
		</view>

		<view wx:if="{{!dataList}}" class="a00-loading">
			<van-loading size="36rpx" color="#C9A96E" type="spinner" />
		</view>

		<block wx:for="{{dataList}}" wx:key="key">
			<view class="a00-news-card" bindtap="url" data-url="../../../../pages/default/news/detail/news_detail?id={{item._id}}">
				<view class="a00-news-body">
					<view class="a00-news-cate">{{item.NEWS_CATE_NAME}}</view>
					<view class="a00-news-title">{{item.NEWS_TITLE}}</view>
					<view class="a00-news-desc">{{item.NEWS_DESC}}</view>
				</view>
				<view class="a00-news-pic" wx:if="{{item.NEWS_PIC[0]}}">
					<image mode="aspectFill" src="{{item.NEWS_PIC[0]}}" />
				</view>
			</view>
		</block>
	</view>

	<!-- 底部品牌 -->
	<view class="a00-footer">
		<view class="a00-footer-line"></view>
		<view class="a00-footer-text">健心瑜伽馆 · 尊享定制</view>
		<view class="a00-footer-line"></view>
	</view>

</view>
<!-- [AI_END LINES=58 TIMESTAMP=2025-01-26 11:00:00] -->
