<!-- A00 定制首页 - 健心瑜伽馆（深色 + 金色主题） -->
<cmpt-tenant-switch title="首页" navBg="#1a1a2e" />

<view class="a00-home">
	<!-- 顶部横幅 / 品牌 Hero -->
	<view class="a00-hero">
		<block wx:if="{{banners.length > 0}}">
			<swiper class="a00-banner-swiper" indicator-dots indicator-color="rgba(255,255,255,0.35)" indicator-active-color="#c9a96e" autoplay circular interval="4500" duration="500">
				<swiper-item wx:for="{{banners}}" wx:key="_id">
					<view class="a00-banner-item" bindtap="bindBannerTap" data-url="{{item.linkUrl}}">
						<image class="a00-banner-img" mode="aspectFill" src="{{item.pic || skin.IMG_DEFAULT_INDEX_BG}}" />
						<view class="a00-banner-mask" wx:if="{{item.title}}">
							<text class="a00-banner-title">{{item.title}}</text>
						</view>
					</view>
				</swiper-item>
			</swiper>
		</block>
		<block wx:else>
			<view class="a00-hero-bg"></view>
			<view class="a00-hero-inner">
				<view class="a00-hero-tag">✦ PREMIUM YOGA ✦</view>
				<view class="a00-hero-brand">{{tenantName}}</view>
				<view class="a00-hero-slogan">{{tenantDesc || '高端定制瑜伽体验中心'}}</view>
				<view class="a00-hero-btn" bindtap="url" data-type="switch" data-url="/pages/default/calendar/index/calendar_index">
					<text>立即约课</text>
					<text class="a00-hero-arrow">→</text>
				</view>
			</view>
		</block>
	</view>

	<!-- 搜索 + 电话 -->
	<view class="a00-toolbar">
		<view class="a00-search" bindtap="bindSearchTap">
			<van-icon name="search" size="30rpx" color="#c9a96e" />
			<text class="a00-search-text">搜索课程、老师、活动</text>
		</view>
		<view class="a00-phone" bindtap="bindPhoneTap">
			<van-icon name="phone-o" size="36rpx" color="#1a1a2e" />
		</view>
	</view>

	<!-- 功能入口 -->
	<view class="a00-features">
		<view class="a00-feat-card" bindtap="url" data-type="switch" data-url="/pages/default/calendar/index/calendar_index">
			<view class="a00-feat-icon a00-icon-1"><van-icon name="calendar-o" size="44rpx" color="#c9a96e" /></view>
			<view class="a00-feat-name">课程预约</view>
		</view>
		<view class="a00-feat-card" bindtap="url" data-url="/pages/default/news/index/news_index?id=1">
			<view class="a00-feat-icon a00-icon-2"><van-icon name="notes-o" size="44rpx" color="#5b8a72" /></view>
			<view class="a00-feat-name">馆内动态</view>
		</view>
		<view class="a00-feat-card" bindtap="url" data-url="/pages/default/news/index/news_index?id=2">
			<view class="a00-feat-icon a00-icon-3"><van-icon name="bulb-o" size="44rpx" color="#e89b6c" /></view>
			<view class="a00-feat-name">瑜伽常识</view>
		</view>
		<view class="a00-feat-card" bindtap="url" data-url="/pages/default/about/index/about_index">
			<view class="a00-feat-icon a00-icon-4"><van-icon name="home-o" size="44rpx" color="#1a1a2e" /></view>
			<view class="a00-feat-name">门店介绍</view>
		</view>
	</view>

	<!-- 金牌老师 -->
	<view class="a00-section" wx:if="{{teachers.length > 0}}">
		<view class="a00-sec-header">
			<view class="a00-sec-line"></view>
			<view class="a00-sec-title">金牌老师</view>
			<view class="a00-sec-line"></view>
		</view>
		<scroll-view class="a00-teacher-scroll" scroll-x enhanced show-scrollbar="{{false}}">
			<view class="a00-teacher-list">
				<view class="a00-teacher-card" wx:for="{{teachers}}" wx:key="_id" bindtap="bindTeacherTap" data-id="{{item._id}}">
					<image class="a00-teacher-cover" mode="aspectFill" src="{{item.cover || item.avatar}}" />
					<view class="a00-teacher-name text-cut">{{item.name}}</view>
					<view class="a00-teacher-spec text-cut">{{item.specialty}}</view>
				</view>
			</view>
		</scroll-view>
	</view>

	<!-- 照片墙：多相册左右滑动 -->
	<view class="a00-section a00-section--compact" wx:if="{{photoAlbums && photoAlbums.length > 0}}">
		<view class="a00-sec-header">
			<view class="a00-sec-line"></view>
			<view class="a00-sec-title">照片墙</view>
			<view class="a00-sec-line"></view>
		</view>
		<swiper class="a00-album-swiper" indicator-dots indicator-color="rgba(255,255,255,0.35)" indicator-active-color="#c9a96e" circular duration="400">
			<swiper-item wx:for="{{photoAlbums}}" wx:for-index="albumIdx" wx:key="albumIdx">
				<view class="a00-album-panel">
					<view class="a00-album-title">{{item.title}}</view>
					<scroll-view class="a00-album-scroll" scroll-x show-scrollbar="{{false}}">
						<view class="a00-album-photos">
							<view
								class="a00-album-photo"
								wx:for="{{item.photos}}"
								wx:for-item="photo"
								wx:for-index="photoIdx"
								wx:key="_id"
								bindtap="bindPhotoTap"
								data-album-index="{{albumIdx}}"
								data-photo-index="{{photoIdx}}"
							>
								<image mode="aspectFill" src="{{photo.pic}}" />
								<view class="a00-album-cap text-cut" wx:if="{{photo.title}}">{{photo.title}}</view>
							</view>
						</view>
					</scroll-view>
				</view>
			</swiper-item>
		</swiper>
	</view>

	<!-- 公告（底部） -->
	<view class="a00-section" wx:if="{{announcements.length > 0}}">
		<view class="a00-sec-header">
			<view class="a00-sec-line"></view>
			<view class="a00-sec-title">公告</view>
			<view class="a00-sec-line"></view>
		</view>
		<view class="a00-news-card" wx:for="{{announcements}}" wx:key="_id" bindtap="bindAnnounceTap" data-id="{{item._id}}">
			<view class="a00-news-body">
				<view class="a00-news-cate">NOTICE</view>
				<view class="a00-news-title text-cut">{{item.title}}</view>
				<view class="a00-news-desc text-cut" wx:if="{{item.desc}}">{{item.desc}}</view>
			</view>
			<van-icon name="arrow" size="24rpx" color="rgba(201,169,110,0.6)" />
		</view>
	</view>

	<view class="a00-footer">
		<view class="a00-footer-line"></view>
		<view class="a00-footer-text">{{tenantName}} · 尊享定制</view>
		<view class="a00-footer-line"></view>
	</view>
</view>
