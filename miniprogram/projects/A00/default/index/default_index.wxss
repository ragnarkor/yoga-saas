/* A00 定制首页 - 深色高级感主题（金色 + 深蓝黑） */
@import "../../skin/skin.wxss";

page {
  background: #0f0f1a !important;
}

.a00-home {
  min-height: 100vh;
  background: #0f0f1a;
}

/* === Hero 品牌区 === */
.a00-hero {
  position: relative;
  width: 100%;
  height: 540rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

.a00-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(
    ellipse at top right,
    rgba(201, 169, 110, 0.15),
    transparent 60%
  );
}

.a00-hero-inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 80rpx 60rpx 0;
}

.a00-hero-tag {
  font-size: 22rpx;
  color: #c9a96e;
  letter-spacing: 6rpx;
  margin-bottom: 24rpx;
  font-weight: 300;
}

.a00-hero-brand {
  font-size: 58rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 20rpx rgba(201, 169, 110, 0.3);
}

.a00-hero-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
  margin-bottom: 48rpx;
}

.a00-hero-btn {
  display: flex;
  align-items: center;
  padding: 20rpx 64rpx;
  background: linear-gradient(135deg, #c9a96e, #b8975a);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 110, 0.35);
}

.a00-hero-arrow {
  font-size: 32rpx;
  margin-left: 12rpx;
}

/* === 功能入口卡片 === */
.a00-features {
  display: flex;
  justify-content: space-around;
  padding: 48rpx 20rpx 32rpx;
  margin: -60rpx 24rpx 0;
  background: rgba(26, 26, 46, 0.85);
  border-radius: 24rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.15);
  position: relative;
  z-index: 3;
}

.a00-feat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.a00-feat-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.a00-icon-1 {
  background: rgba(201, 169, 110, 0.15);
}

.a00-icon-2 {
  background: rgba(91, 138, 114, 0.2);
}

.a00-icon-3 {
  background: rgba(212, 149, 107, 0.15);
}

.a00-icon-4 {
  background: rgba(150, 130, 180, 0.15);
}

.a00-feat-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 1rpx;
}

/* === 资讯区域 === */
.a00-section {
  padding: 48rpx 32rpx 0;
}

.a00-sec-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}

.a00-sec-line {
  width: 60rpx;
  height: 1rpx;
  background: rgba(201, 169, 110, 0.3);
}

.a00-sec-title {
  font-size: 32rpx;
  color: #c9a96e;
  margin: 0 24rpx;
  letter-spacing: 6rpx;
  font-weight: 500;
}

/* === 资讯卡片 === */
.a00-news-card {
  display: flex;
  align-items: center;
  background: rgba(26, 26, 46, 0.6);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.08);
}

.a00-news-body {
  flex: 1;
  padding-right: 24rpx;
  overflow: hidden;
}

.a00-news-cate {
  display: inline-block;
  font-size: 20rpx;
  color: #c9a96e;
  padding: 4rpx 16rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.3);
  border-radius: 6rpx;
  margin-bottom: 16rpx;
}

.a00-news-title {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 500;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.a00-news-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.a00-news-pic {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.a00-news-pic image {
  width: 100%;
  height: 100%;
}

/* === 加载 === */
.a00-loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

/* === 底部品牌 === */
.a00-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx 80rpx;
}

.a00-footer-line {
  width: 80rpx;
  height: 1rpx;
  background: rgba(201, 169, 110, 0.2);
}

.a00-footer-text {
  font-size: 22rpx;
  color: rgba(201, 169, 110, 0.5);
  margin: 0 20rpx;
  letter-spacing: 4rpx;
}
/* [AI_END LINES=172 TIMESTAMP=2025-01-26 11:00:00] */
