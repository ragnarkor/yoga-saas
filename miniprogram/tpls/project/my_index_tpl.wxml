<!-- [AI_START TIMESTAMP=2025-01-25 14:50:00] -->
<template name="myIndexTpl">
	<view class="main">

		<!--top area begin-->
		<view class="upside upside-shadow">
			<image mode="aspectFill" lazy-load class="upImg loading" src="{{skin.IMG_UPIMG}}" />
			<view class="user-bar" bindtap="bindProfileTap">
				<view class="avatar-wrap">
					<image wx:if="{{showAvatarImg}}" class="avatar-img" mode="aspectFill" src="{{avatarSrc}}" />
					<view wx:else class="avatar-placeholder">
						<van-icon name="user-o" size="68rpx" color="{{themeColor}}" />
					</view>
				</view>
				<view class="detail">
					<!-- [AI_START TIMESTAMP=2025-01-25 12:30:00] -->
					<view class="name-text">
						<text>{{userNameInput || '点击完善资料'}}</text>
						<text class="name-edit-hint">编辑</text>
					</view>
					<!-- [AI_END LINES=3 TIMESTAMP=2025-01-25 12:30:00] -->
				</view>
				<van-icon name="arrow" size="28rpx" color="rgba(255,255,255,0.7)" custom-class="profile-arrow" />
			</view>
		</view>
		<!--top area end-->

		<!--down area begin-->
		<view class="down padding-project">
			<!-- 今日约课 -->
			<view class="today-card card-project shadow-project">
				<view class="today-head">
					<view class="today-head-main">
						<text class="today-title">今日{{skin.MEET_NAME}}</text>
						<text wx:if="{{!myTodayLoading && myTodayList.length}}" class="today-badge">{{myTodayList.length}}</text>
					</view>
					<view class="today-link" bindtap="url" data-type="switch" data-url="/pages/default/news/cate1/news_cate1">
						<text>全部记录</text>
						<van-icon name="arrow" size="24rpx" color="#969799" />
					</view>
				</view>

				<view wx:if="{{myTodayLoading}}" class="today-state">
					<van-loading size="32rpx" color="{{themeColor}}" custom-class="today-loading" />
					<text class="today-state-text">加载中...</text>
				</view>

				<view wx:elif="{{!myTodayList || myTodayList.length==0}}" class="today-state">
					<van-icon name="calendar-o" size="56rpx" color="#dcdee0" />
					<text class="today-state-text">今天没有{{skin.MEET_NAME}}安排</text>
					<text class="today-state-sub">去约课页看看近期课程吧</text>
				</view>

				<view wx:else class="today-list">
					<view
						class="today-item"
						bindtap="url"
						data-url="../join_detail/my_join_detail?id={{item._id}}"
						wx:for="{{myTodayList}}"
						wx:key="_id"
					>
						<view class="today-time-col">
							<text class="today-time-start">{{item.JOIN_MEET_TIME_START}}</text>
							<text class="today-time-end">{{item.JOIN_MEET_TIME_END}}</text>
						</view>
						<view class="today-info">
							<text class="today-course-name">{{item.JOIN_MEET_TITLE}}</text>
							<view class="today-tags">
								<text wx:if="{{item.JOIN_STATUS==1}}" class="today-tag today-tag--book">预约成功</text>
								<text wx:if="{{item.JOIN_STATUS==1 && item.JOIN_IS_CHECKIN==1}}" class="today-tag today-tag--checkin">已签到</text>
								<text wx:elif="{{item.JOIN_STATUS==1}}" class="today-tag today-tag--wait">待签到</text>
								<text wx:elif="{{item.JOIN_STATUS==10}}" class="today-tag today-tag--cancel">已取消</text>
								<text wx:elif="{{item.JOIN_STATUS==99}}" class="today-tag today-tag--system">系统取消</text>
								<text wx:elif="{{item.JOIN_STATUS==0}}" class="today-tag today-tag--pending">待确认</text>
							</view>
							<text wx:if="{{item.JOIN_STATUS==1 && item.JOIN_IS_CHECKIN!=1}}" class="today-hint">请准时到场，向工作人员出示预约码签到</text>
						</view>
						<van-icon name="arrow" size="28rpx" color="#c8c9cc" custom-class="today-arrow" />
					</view>
				</view>
			</view>

			<!-- VANT 菜单列表 -->
			<van-cell-group inset custom-class="menu-group">
				<van-cell custom-class="mi-cell mi-card" title="我的卡包" is-link link-type="navigateTo" url="../card_pack/my_card_pack" icon="credit-pay" label="查看会员卡余额与到期" />
				<van-cell custom-class="mi-cell mi-coach" title="切换到教练版" is-link bindtap="bindSwitchCoachTap" icon="manager-o" label="馆主/教练工作台" />
			</van-cell-group>

			<van-cell-group inset custom-class="menu-group">
				<van-cell wx:if="{{!skin.IS_SUB}}" custom-class="mi-cell mi-contact" title="联系我们" is-link link-type="navigateTo" url="../../about/contact/about_contact" icon="phone-o" />
				<van-cell wx:else custom-class="mi-cell mi-contact" title="联系作者了解更多详情" is-link link-type="navigateTo" url="../../../../pages/home/service/home_service" icon="phone-o" />
				<van-cell custom-class="mi-cell mi-setting" title="{{skin.IS_SUB?'系统后台管理（可试用）':'设置'}}" is-link bindtap="bindSetTap" icon="setting-o" />
			</van-cell-group>

		</view>
		<!--down area end-->

	</view>
</template>
<!-- [AI_END LINES=70 TIMESTAMP=2025-01-25 14:50:00] -->
