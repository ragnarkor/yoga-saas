<!-- [AI_START TIMESTAMP=2025-01-24 12:20:00] -->
<template name="calendarIndexTpl">
	<van-empty wx:if="{{isLoad===null}}" description="暂无课程数据" />
	<view wx:if="{{isLoad===false}}" class="loading-wrap">
		<van-loading size="48rpx" color="{{themeColor}}" type="spinner" />
	</view>

	<view class="booking-main" wx:if="{{isLoad}}">

		<!-- 动态页面标题 -->
		<view class="page-header">
			<view class="page-header-bg"></view>
			<view class="page-header-content">
				<view class="page-title">{{pageTitle}}</view>
				<view class="page-subtitle">{{pageSubtitle}}</view>
				<view
					wx:if="{{showPrivateEntry}}"
					class="page-header-private"
					hover-class="page-header-private--active"
					bindtap="bindPrivateBookTap"
				>
					<text>私教预约</text>
					<van-icon name="arrow" size="22rpx" color="rgba(255,255,255,0.85)" />
				</view>
			</view>
		</view>

		<!-- 课程分类（自定义 Tab，避免 template 内 van-tabs 异步不刷新） -->
		<scroll-view
			wx:if="{{tabs.length}}"
			class="category-tabs"
			scroll-x
			enhanced
			show-scrollbar="{{false}}"
		>
			<view class="category-tabs-inner">
				<view
					class="category-tab {{activeTab === index ? 'active' : ''}}"
					wx:for="{{tabs}}"
					wx:key="id"
					data-index="{{index}}"
					bindtap="bindCategoryTap"
				>
					<text class="category-tab-text">{{item.name}}</text>
					<view class="category-tab-line" wx:if="{{activeTab === index}}"></view>
				</view>
			</view>
		</scroll-view>

		<!-- 日期选择条 -->
		<view class="date-selector">
			<scroll-view class="date-scroll" scroll-x scroll-with-animation enhanced show-scrollbar="{{false}}">
				<view class="date-list">
					<view class="date-item {{dateItem.day === selectedDate ? 'active' : ''}}"
						wx:for="{{dateList}}" wx:key="day" wx:for-item="dateItem"
						bindtap="bindDateSelect" data-day="{{dateItem.day}}">
						<view class="date-weekday">{{dateItem.weekday}}</view>
						<view class="date-day">{{dateItem.dateDay}}</view>
						<view class="date-month">{{dateItem.dateMonth}}</view>
						<view class="date-indicator" wx:if="{{dateItem.hasCourse}}"></view>
					</view>
				</view>
			</scroll-view>
		</view>

		<!-- 课程列表 -->
		<view class="course-list" wx:if="{{courseList && courseList.length > 0}}">
			<view class="course-card" wx:for="{{courseList}}" wx:key="cardKey"
				bindtap="url" data-url="/pages/default/meet/detail/meet_detail?id={{item._id}}&day={{selectedDate}}&timeMark={{item.timeMark}}">

				<view class="card-time-section">
					<view class="time-primary">{{item.timeStart}}</view>
					<view class="time-secondary">{{item.timeEnd}}</view>
					<view class="time-duration">{{item.duration}}</view>
				</view>

				<view class="card-info-section">
					<view class="course-name text-cut">{{item.title}}</view>
					<view class="course-tags">
						<view class="course-stars" wx:if="{{item.levelNum > 0}}">
							<text
								wx:for="{{item.levelStars}}"
								wx:for-item="star"
								wx:key="index"
								class="course-star {{star ? 'on' : ''}}"
							>★</text>
						</view>
						<van-tag plain type="warning" size="medium" custom-class="course-tag" wx:if="{{item.typeName}}">{{item.typeName}}</van-tag>
					</view>
					<view class="course-coach">
					<view class="coach-avatar-wrap">
						<image wx:if="{{item.coachAvatar}}" class="coach-avatar" src="{{item.coachAvatar}}" mode="aspectFill" />
						<text wx:else class="coach-avatar-fallback">{{item.coachName ? item.coachName[0] : '教'}}</text>
					</view>
						<text class="coach-name">{{item.coachName}}</text>
					</view>
				</view>

				<view class="card-action-section">
					<view class="slots-info">
						<block wx:if="{{item.status === 'available'}}">
							<text class="slots-number">{{item.slots}}</text>
							<text class="slots-label">余位</text>
						</block>
						<block wx:elif="{{item.status === 'booked'}}">
							<text class="slots-status booked">已预约</text>
						</block>
						<block wx:elif="{{item.status === 'full'}}">
							<text class="slots-status full">已满员</text>
						</block>
						<block wx:else>
							<text class="slots-number">{{item.slots}}</text>
							<text class="slots-label">余位</text>
						</block>
					</view>
					<view class="book-btn {{item.status === 'full' ? 'disabled' : ''}}">
						<text>{{item.status === 'booked' ? '查看' : item.status === 'full' ? '候补' : '预约'}}</text>
					</view>
				</view>
			</view>
		</view>

		<!-- 空状态 -->
		<view class="empty-state" wx:if="{{!courseList || courseList.length === 0}}">
			<view class="empty-illustration">
				<image class="empty-image" src="/images/empty_yoga.png" mode="aspectFit" />
			</view>
			<view class="empty-text">{{emptyText}}</view>
			<van-button size="small" round bindtap="bindReload" custom-style="margin-top: 30rpx; padding: 0 40rpx;">
				重新加载
			</van-button>
		</view>

	</view>

	<!-- 底部安全区 -->
	<view class="safe-bottom" wx:if="{{isLoad}}"></view>

</template>
<!-- [AI_END LINES=97 TIMESTAMP=2025-01-24 12:20:00] -->
