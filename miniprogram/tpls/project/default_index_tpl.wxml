<template name="defaultIndexTpl">

	<cmpt-tenant-switch title="首页" theme-color="{{themeColor}}" />

	<view class="home-page">

		<!-- 顶部横幅 -->
		<view class="home-hero">
			<view class="home-banner" wx:if="{{banners.length > 0}}">
				<swiper class="banner-swiper" indicator-dots autoplay circular interval="4000" duration="500">
					<swiper-item wx:for="{{banners}}" wx:key="_id">
						<view class="banner-item" bindtap="bindBannerTap" data-url="{{item.linkUrl}}">
							<video wx:if="{{item.type === 'video' && item.video}}" class="banner-media" src="{{item.video}}" poster="{{item.pic}}" object-fit="cover" show-center-play-btn="{{false}}" controls="{{false}}"></video>
							<image wx:else class="banner-media" mode="aspectFill" src="{{item.pic || skin.IMG_DEFAULT_INDEX_BG}}" />
						</view>
					</swiper-item>
				</swiper>
			</view>
			<view class="home-banner home-banner-fallback" wx:else>
				<image mode="aspectFill" src="{{skin.IMG_DEFAULT_INDEX_BG}}" />
			</view>
		</view>

		<!-- 场馆名 + 电话 -->
		<view class="home-studio-card">
			<text class="home-studio-name text-cut">{{tenantName || '瑜伽馆'}}</text>
			<view class="home-studio-divider"></view>
			<view class="home-studio-phone" bindtap="bindPhoneTap">
				<van-icon name="phone-o" size="40rpx" color="{{themeColor}}" />
			</view>
		</view>

		<!-- 公告条 -->
		<view class="home-announce-strip" bindtap="bindAnnounceStripTap">
			<van-icon name="volume-o" size="28rpx" color="{{themeColor}}" custom-class="home-announce-icon" />
			<text class="home-announce-text text-cut">{{announcements.length ? announcements[0].title : '暂无公告'}}</text>
		</view>

		<!-- 金牌老师（横向滑动） -->
		<view class="home-section" wx:if="{{teachers.length > 0}}">
			<view class="section-head">
				<text class="section-title">金牌老师</text>
			</view>
			<scroll-view class="hscroll" scroll-x enhanced show-scrollbar="{{false}}">
				<view class="hscroll-inner">
					<view class="teacher-card" wx:for="{{teachers}}" wx:key="_id" bindtap="bindTeacherTap" data-id="{{item._id}}">
						<image class="teacher-cover" mode="aspectFill" src="{{item.cover || item.avatar}}" />
						<view class="teacher-name text-cut">{{item.name}}</view>
					</view>
				</view>
			</scroll-view>
		</view>

		<!-- 照片墙（横向滑动） -->
		<view class="home-section" wx:if="{{photos.length > 0}}">
			<view class="section-head">
				<text class="section-title">照片墙</text>
			</view>
			<scroll-view class="hscroll" scroll-x enhanced show-scrollbar="{{false}}">
				<view class="hscroll-inner">
					<view
						class="photo-card"
						wx:for="{{photos}}"
						wx:key="_id"
						bindtap="bindPhotoTap"
						data-index="{{index}}"
					>
						<image class="photo-cover" mode="aspectFill" src="{{item.pic}}" />
						<view class="photo-title text-cut">{{item.title || item.album || '馆舍风采'}}</view>
					</view>
				</view>
			</scroll-view>
		</view>

		<view class="home-safe-bottom"></view>
	</view>

	<block wx:if="{{skin.IS_SUB}}">
		<import src="../../tpls/public/menu_tpl.wxml" />
		<template is="menuTpl" data="{{skin,themeColor,curMenu:'home_index',returnHome}}" />
	</block>

</template>
