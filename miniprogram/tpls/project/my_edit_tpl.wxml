<template name="myEditTpl">
	<!-- 加载中 -->
	<view wx:if="{{isLoad===null}}" class="loading-wrap">
		<van-loading size="48rpx" color="#5b8a72" type="spinner" />
	</view>
	<!-- 加载失败 -->
	<van-empty wx:if="{{isLoad===false}}" description="数据加载失败" />

	<view wx:if="{{isLoad}}" class="main padding-project">
		<!-- VANT 表单 -->
		<van-cell-group inset custom-class="form-card">
			<van-field
				value="{{ formName }}"
				label="姓名"
				required
				placeholder="填写您的姓名"
				maxlength="20"
				data-field="formName"
				bind:change="bindFormChange"
			/>
			<van-field
				value="{{ formMobile }}"
				label="手机"
				required
				type="number"
				placeholder="填写您的手机号码"
				maxlength="11"
				data-field="formMobile"
				bind:change="bindFormChange"
			/>
			<van-field
				value="{{ formCity }}"
				label="所在城市"
				placeholder="填写您的所在城市"
				maxlength="100"
				data-field="formCity"
				bind:change="bindFormChange"
			/>
			<van-field
				value="{{ formWork }}"
				label="所在单位"
				placeholder="填写您的所在单位"
				maxlength="100"
				data-field="formWork"
				bind:change="bindFormChange"
			/>
			<van-field
				value="{{ formTrade }}"
				label="行业领域"
				placeholder="填写您的行业领域"
				maxlength="100"
				data-field="formTrade"
				bind:change="bindFormChange"
			/>
		</van-cell-group>

		<view class="form-submit-wrap">
			<van-button type="primary" block round bindtap="bindSubmitTap">提交</van-button>
		</view>
	</view>
</template>
<!-- [AI_END LINES=51 TIMESTAMP=2025-01-25 14:35:00] -->
