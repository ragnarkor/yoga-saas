<template name="meetDetailTpl">
	<view wx:if="{{isLoad===false}}" class="loading-wrap">
		<van-loading size="48rpx" color="#5b8a72" type="spinner" />
	</view>
	<van-empty wx:if="{{isLoad===null}}" description="课程不存在" />

	<view wx:if="{{isLoad}}" class="md-page">
		<!-- 课程概要 -->
		<view class="md-summary card-project shadow-project">
			<image class="md-cover" src="{{coverPic}}" mode="aspectFill" />
			<view class="md-summary-body">
				<view class="md-title-row">
					<text class="md-title">{{meet.MEET_TITLE}}</text>
					<text class="md-limit-tag">{{limitHint}}</text>
				</view>
				<view class="md-seat-row">
					<view class="md-progress-track">
						<view class="md-progress-bar" style="width: {{seatPercent}}%;"></view>
					</view>
					<text class="md-seat-text">{{seatText}}</text>
				</view>
				<view class="md-level-row">
					<text class="md-meta-label">难度/级别</text>
					<view class="md-stars">
						<text wx:for="{{levelStars}}" wx:key="index" class="md-star {{item ? 'on' : ''}}">★</text>
					</view>
				</view>
			</view>
		</view>

		<!-- 上课信息 -->
		<view class="md-info card-project shadow-project">
			<view class="md-info-item">
				<text class="md-info-label">上课时间</text>
				<text class="md-info-value">{{classTimeText}}</text>
			</view>
			<view class="md-info-item">
				<text class="md-info-label">上课地点</text>
				<text class="md-info-value">{{locationText}}</text>
			</view>
			<view class="md-info-item md-info-item--coach">
				<text class="md-info-label">授课老师</text>
				<view class="md-coach-row">
					<image class="md-coach-avatar" src="{{coachAvatar}}" mode="aspectFill" />
					<text class="md-info-value">{{coachName}}</text>
				</view>
			</view>
		</view>

		<!-- 已预约会员 -->
		<view class="md-roster card-project shadow-project" wx:if="{{joinRosterTotal > 0}}">
			<view class="md-section-title">已预约 {{joinRosterTotal}} 人</view>
			<view class="md-roster-list">
				<view class="md-roster-item" wx:for="{{joinRoster}}" wx:key="userId">
					<image class="md-roster-avatar" src="{{item.avatarSrc}}" mode="aspectFill" />
					<text class="md-roster-name">{{item.name}}</text>
				</view>
			</view>
		</view>

		<!-- 时段选择 -->
		<view class="md-times card-project shadow-project" wx:if="{{meet.MEET_DAYS_SET && meet.MEET_DAYS_SET.length > 0}}">
			<view class="md-section-title">选择时段</view>
			<scroll-view wx:if="{{meet.MEET_DAYS_SET.length > 1}}" class="md-day-scroll" scroll-x enhanced show-scrollbar="{{false}}">
				<view class="md-day-list">
					<view wx:for="{{meet.MEET_DAYS_SET}}" wx:key="day"
						class="md-day-chip {{selectedDayIdx === index ? 'active' : ''}}"
						bindtap="bindSelectDayTap" data-dayidx="{{index}}">
						{{item.dayDesc || item.day}}
					</view>
				</view>
			</scroll-view>
			<view class="md-time-grid">
				<view wx:for="{{currentDayTimes}}" wx:key="mark"
					class="md-time-chip {{selectedTimeIdx === index ? 'active' : ''}} {{item.error ? 'disabled' : ''}}"
					bindtap="bindSelectTimeTap" data-timeidx="{{index}}">
					<text class="md-time-range">{{item.start}}–{{item.end}}</text>
					<text wx:if="{{item.isLimit && meet.MEET_IS_SHOW_LIMIT==1}}" class="md-time-limit">
						{{item.stat.succCnt || 0}}/{{item.limit}}
					</text>
					<text wx:elif="{{item.error}}" class="md-time-limit">{{item.error}}</text>
				</view>
			</view>
		</view>

		<!-- 注意事项 -->
		<view class="md-notes">
			<view class="md-notes-title">注意事项</view>
			<view wx:for="{{bookNotes}}" wx:key="index" class="md-note-item">
				<text class="md-note-num">{{index + 1}}.</text>
				<text class="md-note-text">{{item}}</text>
			</view>
		</view>

		<!-- 课程介绍 -->
		<view class="md-intro card-project shadow-project">
			<view class="md-intro-head">
				<text class="md-intro-line"></text>
				<text class="md-intro-title">课程介绍</text>
				<text class="md-intro-line"></text>
			</view>
			<swiper wx:if="{{introPics.length > 0}}" class="md-intro-swiper" indicator-dots circular autoplay interval="4000">
				<swiper-item wx:for="{{introPics}}" wx:key="index">
					<image class="md-intro-img" src="{{item}}" mode="aspectFill"
						bindtap="url" data-type="img" data-url="{{item}}" show-menu-by-longpress="{{true}}" />
				</swiper-item>
			</swiper>
			<view wx:if="{{introText}}" class="md-intro-text">{{introText}}</view>
			<block wx:if="{{meet.MEET_CONTENT && meet.MEET_CONTENT.length > 0}}">
				<block wx:for="{{meet.MEET_CONTENT}}" wx:key="key">
					<view wx:if="{{item.type=='text'}}" class="md-intro-text">{{item.val}}</view>
					<image wx:if="{{item.type=='img'}}" class="md-intro-img-block"
						bindtap="url" data-type="img" data-url="{{item.val}}"
						mode="widthFix" lazy-load src="{{item.val}}" show-menu-by-longpress="{{true}}" />
				</block>
			</block>
		</view>

		<view class="md-bottom-spacer"></view>

		<!-- 会员卡提示 -->
		<view wx:if="{{cardHint}}" class="md-card-hint">
			<van-icon name="info-o" size="28rpx" color="#969799" />
			<text>{{cardHint}}</text>
		</view>

		<!-- 底部预约 -->
		<view class="md-footer">
			<button
				class="md-book-btn {{bookDisabled || submitting ? 'disabled' : ''}}"
				bindtap="bindBookTap"
				disabled="{{bookDisabled || submitting}}">
				{{submitting ? '预约中...' : bookBtnText}}
			</button>
		</view>
	</view>

	<van-popup
		show="{{cardSheetShow}}"
		position="bottom"
		round
		bind:close="bindCloseCardSheet"
		custom-class="md-card-popup"
	>
		<view class="md-card-sheet">
			<view class="md-card-sheet-head">
				<text class="md-card-sheet-title">选择划扣会员卡</text>
				<text class="md-card-sheet-sub">本次预约需扣 {{cardNeedTimes}} 次</text>
			</view>
			<view wx:if="{{cardPickLoading}}" class="md-card-sheet-loading">
				<van-loading size="40rpx" color="{{themeColor}}">加载中...</van-loading>
			</view>
			<scroll-view wx:else scroll-y class="md-card-sheet-scroll" enhanced show-scrollbar="{{false}}">
				<view
					class="md-card-option"
					wx:for="{{joinCardOptions}}"
					wx:key="id"
					bindtap="bindCardPick"
					data-id="{{item.id}}"
				>
					<view class="md-card-option-visual" style="background: {{item.color}};">
						<text class="md-card-option-type">{{item.typeLabel}}</text>
					</view>
					<view class="md-card-option-body">
						<text class="md-card-option-name">{{item.name}}</text>
						<text class="md-card-option-balance">{{item.balanceText}}</text>
						<text class="md-card-option-hint">{{item.deductHint}}</text>
					</view>
					<van-icon name="arrow" size="32rpx" color="#c8c9cc" />
				</view>
			</scroll-view>
		</view>
	</van-popup>
</template>
