<template name="myCourseTpl">
  <view class="my-course-page">
    <view class="filter-bar">
      <view
        class="filter-pill {{activeFilter === item.type ? 'active' : ''}}"
        wx:for="{{filterTabs}}"
        wx:key="type"
        bindtap="bindFilterTap"
        data-type="{{item.type}}"
      >
        {{item.label}}
      </view>
    </view>

    <view wx:if="{{isLoad===false}}" class="loading-wrap">
      <van-loading size="48rpx" color="{{themeColor}}" type="spinner" />
    </view>

    <view wx:elif="{{list && list.length > 0}}" class="course-list">
      <block wx:for="{{list}}" wx:key="_id">
        <view
          class="course-item"
          bindtap="bindItemTap"
          data-id="{{item._id}}"
        >
          <image
            class="course-cover"
            src="{{item.coverPic}}"
            mode="aspectFill"
          />
          <view class="course-info">
            <view class="course-title text-cut">{{item.JOIN_MEET_TITLE}}</view>
            <view class="course-meta text-cut">{{item.tenantName}}</view>
            <view class="course-meta text-cut">{{item.scheduleText}}</view>
            <view class="course-meta text-cut">{{item.locationText}}</view>
          </view>
        </view>
        <view class="course-sep" wx:if="{{index < list.length - 1}}"></view>
      </block>

      <view class="list-footer" wx:if="{{loading}}">
        <van-loading size="36rpx" color="{{themeColor}}" type="spinner" />
      </view>
      <view class="list-footer list-footer--text" wx:elif="{{!hasMore}}">
        没有更多了
      </view>
    </view>

    <view class="empty-wrap" wx:elif="{{isLoad}}">
      <van-empty description="{{emptyText}}" />
    </view>
  </view>
</template>
