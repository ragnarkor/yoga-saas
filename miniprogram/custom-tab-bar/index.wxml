<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="key"
    class="tab-bar-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <van-icon
      name="{{item.icon}}"
      size="44rpx"
      color="{{selected === index ? selectedColor : color}}"
    />
    <text
      class="tab-bar-text"
      style="color: {{selected === index ? selectedColor : color}}"
    >{{item.text}}</text>
  </view>
</view>
