<cover-view class="tab-bar">
  <cover-view
    wx:for="{{list}}"
    wx:key="key"
    class="tab-bar-item"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <cover-image
      class="tab-bar-icon"
      src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
    />
    <cover-view
      style="color: {{selected === index ? selectedColor : color}}"
    >{{item.text}}</cover-view>
  </cover-view>
</cover-view>
