.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  z-index: 999;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  position: relative;
  transition: opacity var(--transition-base, 0.25s ease);
}

.tab-bar-item:active {
  opacity: 0.7;
}

.tab-bar-item.active::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 0 0 6rpx 6rpx;
  background: currentColor;
  animation: tabIndicator 0.3s ease-out;
}

.tab-bar-item.active {
  color: var(--tab-active-color, #5b8a72);
}

@keyframes tabIndicator {
  from {
    width: 0;
    opacity: 0;
  }
  to {
    width: 48rpx;
    opacity: 1;
  }
}

.tab-bar-text {
  font-size: 22rpx;
  line-height: 1;
  transition: font-weight var(--transition-base, 0.25s ease);
}

.tab-bar-item.active .tab-bar-text {
  font-weight: 600;
}
/* [AI_END LINES=18 TIMESTAMP=2025-01-26 10:30:00] */
