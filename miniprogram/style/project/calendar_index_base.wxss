/* [AI_START TIMESTAMP=2025-01-24 12:40:00] */
page {
  background-color: var(--neutralBg, #f5f6f8);
}

.booking-main {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ==================== 页面标题区 ==================== */
.page-header {
  position: relative;
  overflow: hidden;
  padding: 48rpx 32rpx 36rpx;
  margin-bottom: 8rpx;
}

.page-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    145deg,
    var(--projectColor, #5b8a72) 0%,
    var(--projectColorDark, #4a7160) 100%
  );
  border-radius: 0 0 40rpx 40rpx;
  opacity: 1;
}

.page-header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}

.page-header-date {
  display: inline-block;
  margin-top: 16rpx;
  padding: 6rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.18);
}

/* ==================== 课程分类 Tab ==================== */
.category-tabs {
  width: 100%;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx var(--neutralShadow, rgba(31, 35, 41, 0.06));
  white-space: nowrap;
}

.category-tabs-inner {
  display: inline-flex;
  align-items: center;
  min-width: 100%;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.category-tab {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 24rpx 28rpx 20rpx;
}

.category-tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--neutralTextTertiary, #8f959e);
  line-height: 1.2;
  white-space: nowrap;
}

.category-tab.active .category-tab-text {
  color: var(--themeColor, var(--projectColor, #5b8a72));
  font-weight: 600;
}

.category-tab-line {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: var(--themeColor, var(--projectColor, #5b8a72));
}

/* ==================== 日期选择条 ==================== */
.date-selector {
  background: #ffffff;
  padding: 20rpx 0 24rpx;
  margin-top: -12rpx;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -4rpx 20rpx var(--neutralShadow, rgba(31, 35, 41, 0.05));
}

.date-scroll {
  width: 100%;
  white-space: nowrap;
}

.date-list {
  display: inline-flex;
  align-items: center;
  padding: 0 16rpx;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 120rpx;
  margin: 0 6rpx;
  border-radius: 20rpx;
  background: var(--neutralIconBg, #f2f3f5);
  position: relative;
  transition: all 0.25s ease;
}

.date-item.active {
  background: linear-gradient(
    145deg,
    var(--projectColor, #5b8a72),
    var(--projectColorDark, #4a7160)
  );
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.18);
  transform: translateY(-4rpx);
}

.date-item.active .date-weekday,
.date-item.active .date-day,
.date-item.active .date-month {
  color: #ffffff !important;
}

.date-weekday {
  font-size: 22rpx;
  color: var(--calendarLightColor, #8ba399);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.date-day {
  font-size: 36rpx;
  font-weight: 700;
  color: #3a3a3a;
  line-height: 1.2;
}

.date-month {
  font-size: 18rpx;
  color: var(--calendarLightColor, #b0c4b8);
  margin-top: 2rpx;
}

.date-indicator {
  position: absolute;
  bottom: 8rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--projectCompareColor, #d4956b);
}

.date-item.active .date-indicator {
  background: #ffffff;
  opacity: 0.8;
}

/* ==================== 课程列表 ==================== */
.course-list {
  padding: 24rpx 24rpx 0;
}

.course-card {
  display: flex;
  align-items: stretch;
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx var(--neutralShadow, rgba(31, 35, 41, 0.06));
  transition: all 0.2s ease;
}

.course-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx var(--neutralShadow, rgba(31, 35, 41, 0.1));
}

/* 时间区域 */
.card-time-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  min-height: 180rpx;
  background: linear-gradient(
    180deg,
    var(--projectColorLight, #e3efe8) 0%,
    var(--neutralBg, #f5f6f8) 100%
  );
  padding: 20rpx 0;
  flex-shrink: 0;
}

.time-primary {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--neutralText, #1f2329);
  line-height: 1.2;
}

.time-secondary {
  font-size: 22rpx;
  color: var(--calendarLightColor, #8ba399);
  margin-top: 4rpx;
  line-height: 1.2;
}

.time-duration {
  font-size: 18rpx;
  color: var(--calendarLightColor, #b0c4b8);
  margin-top: 8rpx;
  padding: 2rpx 12rpx;
  background: var(--projectColorLight, #e3efe8);
  border-radius: 8rpx;
}

/* 信息区域 */
.card-info-section {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
  line-height: 1.4;
}

.course-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.course-stars {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.course-star {
  font-size: 24rpx;
  color: #ddd;
  line-height: 1;
}

.course-star.on {
  color: #ffb74d;
}

.course-tag {
  font-size: 20rpx !important;
}

.course-coach {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.coach-avatar-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx solid var(--projectColorLight, #e3efe8);
  flex-shrink: 0;
  background: #f0f0f0;
}

.coach-avatar {
  width: 100%;
  height: 100%;
}

.coach-avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--neutralTextSecondary, #646a73);
  background: var(--neutralIconBg, #f2f3f5);
}

.coach-name {
  font-size: 24rpx;
  color: var(--neutralTextSecondary, #646a73);
  margin-left: 10rpx;
}

/* 操作区域 */
.card-action-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 24rpx;
  min-width: 130rpx;
  border-left: 2rpx solid var(--neutralBorder, #e8e9eb);
}

.slots-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.slots-number {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--projectColor, #5b8a72);
  line-height: 1.1;
}

.slots-label {
  font-size: 20rpx;
  color: var(--calendarLightColor, #b0c4b8);
  margin-top: 2rpx;
}

.slots-status {
  font-size: 26rpx;
  font-weight: 600;
  padding: 4rpx 0;
}

.slots-status.booked {
  color: var(--projectColor, #5b8a72);
}

.slots-status.full {
  color: #d4956b;
}

.book-btn {
  margin-top: 12rpx;
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(
    135deg,
    var(--projectColor, #5b8a72),
    var(--projectColorDark, #4a7160)
  );
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 6rpx 16rpx rgba(31, 35, 41, 0.12);
  transition: all 0.2s ease;
}

.book-btn:active {
  transform: scale(0.95);
}

.book-btn.disabled {
  background: var(--neutralBorder, #e8e9eb);
  color: #999;
  box-shadow: none;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-illustration {
  width: 320rpx;
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-image {
  width: 100%;
  height: 100%;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  letter-spacing: 1rpx;
}

/* ==================== 底部安全区 ==================== */
.safe-bottom {
  height: env(safe-area-inset-bottom);
}
