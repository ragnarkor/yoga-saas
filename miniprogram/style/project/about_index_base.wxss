.main {
	padding: 40rpx;
	height: 100vh;
	display: flex;
	flex-direction: column;
	justify-content: flex-start;
}

.main .main-content {
	width: 100%;
	flex: 1;
}

.main .content {
	width: 100%;
	background-color: #fff;
	padding: 50rpx;
	border-radius: 20rpx;
	margin-top: 15rpx;
}

.main .content .title {
	width: 100%;
	text-align: left;
	font-size: 36rpx;
	line-height: 1.8;
	margin-bottom: 30rpx;
}

.main .content .txt {
	color: #666;
	margin-bottom: 30rpx;
	font-size: 28rpx;
	line-height: 1.6;
}

.main .content.content-err {
	padding-top: 120rpx;
	padding-bottom: 120rpx;
}

.main .content .err-icon {
	text-align: center;
	font-size: 150rpx;
}

.main .content .err-info {
	text-align: center;
	font-size: 30rpx;
	color: #666;
}

.main .content .err-apply {
	display: flex;
	justify-content: center;
	align-items: center;
	margin-top: 60rpx;
}

.main .comm-list {
	width: 100%;
}


.main .pics {
	width: 60%;
	margin-top: 30rpx;
	display: flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
}

.main .pics image {
	flex: 1;
	border-radius: 10rpx;
	margin-bottom: 20rpx;
}

.store-intro-head {
	display: flex;
	flex-direction: column;
	align-items: center;
	margin-bottom: 24rpx;
}

.store-intro-logo {
	width: 120rpx;
	height: 120rpx;
	border-radius: 20rpx;
	margin-bottom: 16rpx;
	background: #f5f5f5;
}

.store-intro-name {
	font-size: 36rpx;
	font-weight: 600;
	text-align: center;
}

.store-intro-desc {
  color: #888;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 32rpx;
}

.contact-map {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.contact-map-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 24rpx;
}