.main {
  padding: 0rpx 0rpx !important;
}

.meet-no-time {
  width: 100%;
  background-color: #fff;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.meet-no-time {
  width: 100%;
  height: 100vh;
  background-color: #fff;
  padding: 80rpx 30rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  font-size: 30rpx;
}

.meet-no-time text {
  font-size: 90rpx;
}

/* 顶部区域 */
/* [AI_START TIMESTAMP=2025-01-20 12:40:00] */
.top-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  background-color: var(--white, #fff);
  border-bottom: 1rpx solid #eef0ed;
  position: fixed;
  top: 0;
  z-index: 999;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.top-area .top-title {
  width: 100%;
  font-size: 36rpx;
  color: #2d332e;
  line-height: 100rpx;
  padding: 0 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.top-area .top-menu {
  width: 100%;
  font-size: 28rpx;
  color: #555;
  line-height: 80rpx;
  padding: 0 30rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  font-weight: 500;
  background-color: var(--projectBgSoft, #fafbf9);
  gap: 20rpx;
}

.top-area .top-menu .item {
  padding: 0 24rpx;
  position: relative;
  border-radius: 8rpx;
  transition: all 0.25s ease;
}

.top-area .top-menu .item.cur {
  color: var(--projectColor, #5b8a72);
  font-weight: 600;
}

.top-area .top-menu .item.cur::after {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: var(--projectColor, #5b8a72);
  content: " ";
  animation: hightlightning_in 0.3s ease-out;
  transform-origin: center;
}
/* [AI_END LINES=40 TIMESTAMP=2025-01-20 12:40:00] */

.top-area .top-menu .item {
  padding: 0 20rpx;
  position: relative;
}

@keyframes hightlightning_in {
  from {
    transform: scaleX(0);
  }

  to {
    transform: scaleX(1);
  }
}

.big-box {
  width: 100%;
  padding: 0;
  margin-top: 193rpx;
  display: flex;
}

/*** 详情盒子 ***/
.article-box {
  box-sizing: border-box;
  width: 100%;
  box-sizing: border-box;
  padding: 30rpx 20rpx;
}

/* [AI_START TIMESTAMP=2025-01-20 12:50:00] */
.article-box .article {
  background-color: var(--white, #fff);
  padding: 24rpx 30rpx 30rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  box-shadow: 0 4rpx 20rpx rgba(91, 138, 114, 0.06);
}
/* [AI_END LINES=1 TIMESTAMP=2025-01-20 12:50:00] */

.article-box .article .info {
  color: #333;
  margin: 0rpx 0rpx;
  box-sizing: border-box;
  width: 100%;
  line-height: 1.6;
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
  padding: 10rpx 0rpx 10rpx;
}

.article-box .article .info .info-left {
  width: 50rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
}

.article-box .article .info .info-right {
  height: 100%;
  flex: 1;
  font-size: 26rpx;
}

.article-box .article .info .info-end {
  height: 100%;
  width: 40rpx;
  font-size: 26rpx;
  color: #ccc;
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.article-box .article .content {
  margin-top: 24rpx;
  color: #333;
  font-size: 28rpx;
  text-align: justify;
  line-height: 1.6;
}

.article-box .article .pics {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.article-box .article .pics image {
  flex: 1;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

/* 垂直导航 */
.nav {
  white-space: nowrap;
}

::-webkit-scrollbar {
  display: none;
}

.nav .item {
  display: inline-block;
  margin: 0 10rpx;
  padding: 0 20rpx;
}

.nav .item.cur {
  border-bottom: 4rpx solid;
}

.vertical-nav.nav {
  width: 200rpx;
  white-space: initial;
}

.vertical-nav.nav .item {
  width: 100%;
  text-align: center;
  margin: 0;
  border: none;
  height: 50px;
  line-height: 50px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* [AI_START TIMESTAMP=2025-01-20 12:50:00] */
.vertical-nav.nav .item.cur {
  background-color: var(--projectColorLight, #e3efe8);
  color: var(--projectColor, #5b8a72);
  font-weight: 600;
}
/* [AI_END LINES=1 TIMESTAMP=2025-01-20 12:50:00] */

.vertical-nav.nav .item.cur::after {
  content: "";
  width: 8rpx;
  height: 30rpx;
  border-radius: 10rpx 0 0 10rpx;
  position: absolute;
  background-color: currentColor;
  top: 0;
  right: 0rpx;
  bottom: 0;
  margin: auto;
}

.vertical-box {
  display: flex;
  width: 100%;
  background-color: #fff;
}

/* [AI_START TIMESTAMP=2025-01-20 12:50:00] */
.vertical-main {
  background-color: var(--projectBgSoft, #fafbf9);
  flex: 1;
}
/* [AI_END LINES=1 TIMESTAMP=2025-01-20 12:50:00] */

.vertical-main .vertical-main-box {
  padding: 30rpx 30rpx 0rpx 30rpx;
  width: 100%;
}

.vertical-main .righ-tab-bar {
  width: 100%;
  text-align: left;
}

.vertical-main .right-tab-tilte {
  font-weight: bold;
}

.vertical-main .text-list {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-items: center;
  background-color: #fff;
  padding-bottom: 20rpx;
  padding: 0rpx 10rpx 20rpx 10rpx;
  padding-top: 10rpx;
}

.vertical-main .text-list .item {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #333;
  width: 50%;
  text-align: center;
  padding: 10rpx 10rpx;
}

/* [AI_START TIMESTAMP=2025-01-20 12:50:00] */
.vertical-main .text-list .item .time-text {
  width: 92%;
  border-radius: 16rpx;
  border: none;
  background-color: var(--projectBgSoft, #fafbf9);
  height: 70rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #2d332e;
  transition: all 0.2s ease;
  font-weight: 500;
}

.vertical-main .text-list .item .time-text:active {
  transform: scale(0.96);
  background-color: var(--projectColorLight, #e3efe8);
}

.vertical-main .text-list .item .time-text.error {
  background-color: #f5f5f3;
  color: #bbb;
}
/* [AI_END LINES=1 TIMESTAMP=2025-01-20 12:50:00] */

.vertical-main .text-list .item .time-text.limit {
  height: 95rpx;
}

.vertical-main .text-list .item .time-text .limit-text {
  width: 100%;
  font-size: 24rpx;
  color: #999;
}
