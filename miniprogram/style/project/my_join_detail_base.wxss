/* [AI_START TIMESTAMP=2025-01-25 15:30:00] */

.jd-wrap {
  min-height: 100vh;
  background-color: var(--neutralBg);
}

/* ==================== 页面容器 ==================== */
.jd-page {
  min-height: 100vh;
  background-color: var(--neutralBg);
  padding: 24rpx 30rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ==================== 加载状态 ==================== */
.jd-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  background-color: var(--neutralBg);
}

/* ==================== 卡片基础 ==================== */
.jd-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(31, 35, 41, 0.05);
}

/* ==================== 课程卡片 ==================== */
.jd-course {
  position: relative;
  overflow: hidden;
}

.jd-status-tag {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 2;
  padding: 18rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
  border-radius: 0 24rpx 0 20rpx;
}

.jd-status-tag--success {
  color: #059669;
  background-color: #ecfdf5;
}

.jd-status-tag--pending {
  color: #d97706;
  background-color: #fffbeb;
}

.jd-status-tag--cancel {
  color: #6b7280;
  background-color: #f3f4f6;
}

.jd-status-tag--system {
  color: #dc2626;
  background-color: #fef2f2;
}

.jd-course-body {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.jd-course-layout {
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.jd-course-name-wrap {
  padding-right: 168rpx;
  box-sizing: border-box;
}

.jd-course-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--neutralText);
  line-height: 1.45;
}

.jd-course-arrow {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  align-self: center;
}

.jd-course-time {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.jd-course-time text {
  font-size: 28rpx;
  color: var(--neutralTextSecondary);
  margin-left: 10rpx;
}

.jd-course-hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--neutralTextSecondary);
}

.jd-course-reason {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background-color: #fef2f2;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #dc2626;
  line-height: 1.5;
}

/* ==================== 预约码卡片 ==================== */
.jd-qr-card {
  text-align: center;
}

.jd-qr-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 28rpx;
}

.jd-qr-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--neutralText);
}

.jd-qr-hint {
  font-size: 24rpx;
  color: var(--neutralTextTertiary);
}

.jd-qr-body {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
}

.jd-qr-img {
  width: 400rpx;
  height: 400rpx;
  border-radius: 12rpx;
}

/* ==================== 操作按钮 ==================== */
.jd-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding-top: 8rpx;
}

.jd-btn {
  flex: 1 1 200rpx;
  min-width: 200rpx;
  max-width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.jd-btn:active {
  opacity: 0.75;
}

.jd-btn--primary {
  background-color: var(--projectColor);
  color: #fff;
}

.jd-btn--ghost {
  background-color: #fff;
  color: var(--neutralTextSecondary);
  border: 2rpx solid var(--neutralBorder);
}

/* [AI_END LINES=115 TIMESTAMP=2025-01-25 15:30:00] */
