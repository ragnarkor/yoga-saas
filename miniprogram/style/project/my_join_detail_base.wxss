/* ==================== 页面容器 ==================== */
.jd-page {
  min-height: 100vh;
  background-color: var(--neutralBg);
  padding: 24rpx 30rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ==================== 加载状态 ==================== */
.jd-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  background-color: var(--neutralBg);
}

/* ==================== 状态横幅 ==================== */
.jd-status-bar {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
}

.jd-status-text {
  margin-left: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.jd-status--success {
  background: linear-gradient(135deg, #6fae96, #5d9a82);
}

.jd-status--pending {
  background: linear-gradient(135deg, #e8a951, #d6963e);
}

.jd-status--cancel {
  background: linear-gradient(135deg, #b5b8bd, #a0a3a8);
}

.jd-status--system {
  background: linear-gradient(135deg, #e06c5e, #cc5a4c);
}

/* ==================== 卡片基础 ==================== */
.jd-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(31, 35, 41, 0.05);
}

/* ==================== 课程卡片 ==================== */
.jd-course {
  position: relative;
}

.jd-course-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.jd-course-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--neutralText);
  line-height: 1.4;
  flex: 1;
}

.jd-course-time {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.jd-course-time text {
  font-size: 28rpx;
  color: var(--neutralTextSecondary);
  margin-left: 10rpx;
}

.jd-course-reason {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background-color: #fef0ee;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #d4584c;
  line-height: 1.5;
}

/* ==================== 预约码卡片 ==================== */
.jd-qr-card {
  text-align: center;
}

.jd-qr-header {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 28rpx;
}

.jd-qr-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--neutralText);
}

.jd-qr-hint {
  font-size: 24rpx;
  color: var(--neutralTextTertiary);
  margin-left: 12rpx;
}

.jd-qr-body {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
}

.jd-qr-img {
  width: 400rpx;
  height: 400rpx;
  border-radius: 12rpx;
}

/* ==================== 操作按钮 ==================== */
.jd-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding-top: 8rpx;
}

.jd-btn {
  flex: 1;
  max-width: 320rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: opacity 0.2s ease;
}

.jd-btn:active {
  opacity: 0.75;
}

.jd-btn--primary {
  background-color: var(--projectColor);
  color: #fff;
}

.jd-btn--ghost {
  background-color: #fff;
  color: var(--neutralTextSecondary);
  border: 2rpx solid var(--neutralBorder);
}

