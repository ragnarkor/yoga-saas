/* [AI_START TIMESTAMP=2025-01-20 12:35:00] */

.main {
  padding: 0;
}

.main .upside {
  background: linear-gradient(
    135deg,
    var(--projectColor, #5b8a72) 0%,
    var(--projectColorDark, #4a7160) 100%
  );
  height: 250rpx;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.main .upside::before {
  content: "";
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.main .upside::after {
  content: "";
  position: absolute;
  bottom: -120rpx;
  left: -40rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.main .upside .upImg {
  height: inherit;
  width: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.main .upside .user-bar {
  width: 100%;
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
  padding-left: 40rpx;
  z-index: 9999;
}

.main .upside .user-bar .avatar {
  height: 120rpx;
  width: 120rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  flex-shrink: 0;
  padding: 0;
}

.main .upside .user-bar .avatar .avatar-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
}

.main .upside .user-bar .detail {
  flex: 1;
  margin-left: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  color: #fff;
  box-sizing: border-box;
  min-width: 0;
}

.main .upside .user-bar .detail .name {
  width: 100%;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.main .upside .user-bar .detail .desc {
  width: 100%;
  font-size: 26rpx;
  margin-top: 15rpx;
  opacity: 0.9;
}

.main .down {
  box-sizing: border-box;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 20rpx 24rpx;
  margin-top: 20rpx;
}

.main .down .data {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx 20rpx;
  width: 100%;
  background-color: var(--white, #fff);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 138, 114, 0.08);
}

.main .down .data view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.main .down .data view + view::before {
  content: "";
  position: absolute;
  left: 0;
  top: 10%;
  height: 80%;
  width: 1rpx;
  background-color: #eef0ed;
}

.main .down .data view .num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--themeColor, #5b8a72);
  line-height: 1.4;
}

.main .down .data view .txt {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.main .comm-list .item.arrow::before,
.main .comm-list .item .content .item-icon {
  color: var(--projectColor, #5b8a72);
}

.main .down .today {
  width: 100%;
  padding: 30rpx 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--white, #fff);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 138, 114, 0.08);
  margin-top: 20rpx;
}

.main .down .today .title {
  width: 100%;
  text-align: left;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.2;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--neutralBorder, #e8e9eb);
  color: var(--neutralText, #1f2329);
}

.main .down .today .list {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
}

.main .down .today .list .item {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2ef;
}

.main .down .today .list .item:last-child {
  margin-bottom: 0rpx;
  border: 0;
}

.main .down .today .list .item .time {
  font-size: 28rpx;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  line-height: 2;
  font-weight: 600;
  color: #2d332e;
}

.main .down .today .list .item .time .status {
  font-weight: normal;
  font-size: 24rpx;
  color: var(--neutralTextSecondary, #646a73);
  background-color: var(--neutralIconBg, #f2f3f5);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.main .down .today .list .item .project {
  color: #666;
  font-size: 24rpx;
  width: 100%;
  text-align: left;
  line-height: 1.6;
}

.main .site-footer {
  width: 100%;
  align-self: flex-end;
}
