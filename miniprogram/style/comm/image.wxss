
/* ==================
          图片
 ==================== */

 image {
	max-width: 100%;
	display: inline-block;
	position: relative;
	z-index: 0;
}

image.loading::before {
	content: "";
	background-color: #f5f5f5;
	display: block;
	position: absolute;
	width: 100%;
	height: 100%;
	z-index: -2;
}

image.loading::after {
	content: "";
	position: absolute;
	top: 0;
	left: 0;
	width: 32rpx;
	height: 32rpx;
	right: 0;
	bottom: 0;
	z-index: -1;
	margin: auto;
	border: 4rpx solid #ddd;
	border-top-color: #ccc;
	border-radius: 50%;
	animation: icon-spin 1s infinite linear;
	display: block;
}