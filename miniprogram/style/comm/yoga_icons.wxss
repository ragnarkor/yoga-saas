/* === Base Icon Container === */
.yoga-icon {
  display: inline-block;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  vertical-align: middle;
}

/* === Size Variants === */
.yoga-icon--xs {
  width: 28rpx;
  height: 28rpx;
}
.yoga-icon--sm {
  width: 36rpx;
  height: 36rpx;
}
.yoga-icon--md {
  width: 48rpx;
  height: 48rpx;
}
.yoga-icon--lg {
  width: 64rpx;
  height: 64rpx;
}
.yoga-icon--xl {
  width: 96rpx;
  height: 96rpx;
}
.yoga-icon--xxl {
  width: 128rpx;
  height: 128rpx;
}

