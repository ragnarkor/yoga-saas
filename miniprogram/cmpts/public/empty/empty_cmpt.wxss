.empty-cmpt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 80rpx 0;
}

.empty-cmpt__image-wrap {
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-cmpt__image {
  width: 100%;
  height: 100%;
}

.empty-cmpt__desc {
  margin-top: 32rpx;
  padding: 0 80rpx;
  color: var(--neutralTextSecondary, #646a73);
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.empty-cmpt__bottom:not(:empty) {
  margin-top: 48rpx;
}
