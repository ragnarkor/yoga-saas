.tenant-top-spacer {
  width: 100%;
  flex-shrink: 0;
}

.tenant-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 28rpx;
  padding-right: 190rpx;
  background: var(--themeColorLight, #c4b5fd);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.08);
}

.tenant-top--sub {
  padding-left: 12rpx;
}

.tenant-top--no-switch {
  padding-right: 28rpx;
}

.tenant-back {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 4rpx;
}

.tenant-title {
  min-width: 0;
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.tenant-title--sub {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  flex: none;
  max-width: 42%;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  pointer-events: none;
}

.tenant-action {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  max-width: 360rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  flex-shrink: 0;
}

.tenant-name {
  min-width: 0;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
}

.tenant-switch {
  flex-shrink: 0;
  font-size: 22rpx;
  opacity: 0.9;
}
