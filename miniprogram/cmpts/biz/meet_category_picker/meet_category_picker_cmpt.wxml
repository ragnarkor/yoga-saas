<!-- 与 van-field / 卡面颜色等表单项同一套 inline 行样式 -->
<view class="mcp-field course-edit-field course-edit-field--inline" bindtap="bindFieldTap">
  <text class="course-edit-field-label-inline {{required ? 'course-edit-field-label-inline--required' : ''}}">{{label}}</text>
  <view class="course-edit-field-row course-edit-field-row--inline">
    <text class="course-edit-field-value {{fieldValueIsPlaceholder ? 'course-edit-field-placeholder-text' : ''}}">{{fieldValue}}</text>
    <van-icon name="arrow" size="32rpx" color="#c8c9cc" />
  </view>
</view>

<van-popup
  show="{{sheetShow}}"
  position="bottom"
  round
  bind:close="bindCloseSheet"
  custom-class="course-edit-popup"
>
  <view class="course-edit-sheet">
    <view class="course-edit-sheet-head">
      <text class="course-edit-sheet-title">{{sheetTitle}}</text>
      <text class="course-edit-sheet-sub">{{sheetSub}}</text>
    </view>
    <scroll-view scroll-y class="course-edit-sheet-scroll" enhanced show-scrollbar="{{false}}">
      <view
        wx:if="{{mode === 'scope'}}"
        class="course-edit-type-item {{scopeMode === 'all' ? 'is-active' : ''}}"
        bindtap="bindScopeAllTap"
      >
        <view class="course-edit-type-dot"></view>
        <text class="course-edit-type-name">全馆课程</text>
        <view class="course-edit-type-check" wx:if="{{scopeMode === 'all'}}">
          <van-icon name="success" size="32rpx" color="{{themeColor}}" />
        </view>
      </view>

      <block wx:if="{{mode === 'single'}}">
        <view
          class="course-edit-type-item {{value === item.id ? 'is-active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="bindTypePick"
        >
          <view class="course-edit-type-dot"></view>
          <text class="course-edit-type-name">{{item.name}}</text>
          <view class="course-edit-type-check" wx:if="{{value === item.id}}">
            <van-icon name="success" size="32rpx" color="{{themeColor}}" />
          </view>
        </view>
      </block>
      <block wx:else>
        <view
          class="course-edit-type-item {{item.selected ? 'is-active' : ''}}"
          wx:for="{{scopeCategories}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="bindScopeCategoryTap"
        >
          <view class="course-edit-type-dot"></view>
          <text class="course-edit-type-name">{{item.name}}</text>
          <view class="course-edit-type-check" wx:if="{{item.selected}}">
            <van-icon name="success" size="32rpx" color="{{themeColor}}" />
          </view>
        </view>
      </block>

      <van-empty
        wx:if="{{!categories.length && !loading}}"
        description="暂无课程分类，请先在「我的门店」配置"
      />
    </scroll-view>
  </view>
</van-popup>
