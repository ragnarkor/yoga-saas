/* 表单项行（与 coach_course_edit course-edit-field--inline 一致） */
.mcp-field.course-edit-field {
  padding: var(--cell-vertical-padding, 24rpx) var(--cell-horizontal-padding, 32rpx);
  background: #fff;
  border-bottom: 1rpx solid var(--neutralBorder, #ebedf0);
  box-sizing: border-box;
}

.mcp-field.course-edit-field--inline {
  display: flex;
  align-items: center;
  gap: var(--cell-horizontal-padding, 32rpx);
  min-height: var(--cell-line-height, 48rpx);
}

.course-edit-field-label-inline {
  width: 6.2em;
  max-width: 6.2em;
  font-size: var(--cell-font-size, 28rpx);
  color: #646566;
  flex-shrink: 0;
  line-height: var(--cell-line-height, 48rpx);
}

.course-edit-field-label-inline--required::before {
  content: "*";
  color: #ee0a24;
  margin-right: 4rpx;
}

.course-edit-field-row--inline {
  flex: 1;
  min-width: 0;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 8rpx;
}

.course-edit-field-row--inline .course-edit-field-value,
.course-edit-field-row--inline .course-edit-field-placeholder-text {
  flex: 1;
  min-width: 0;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-edit-field-value {
  font-size: var(--cell-font-size, 28rpx);
  color: #323233;
}

.course-edit-field-placeholder-text {
  font-size: var(--cell-font-size, 28rpx);
  color: #969799;
}

/* 弹层选项列表（与课程编辑 type-item 一致） */
.course-edit-type-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  margin: 0 0 12rpx;
  border-radius: 16rpx;
  background: var(--neutralBg, #f7f8fa);
  transition: all 0.2s ease;
}

.course-edit-type-dot {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c8c9cc;
  transition: background 0.2s ease;
}

.course-edit-type-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--neutralText, #323233);
}

.course-edit-type-check {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.course-edit-type-item.is-active {
  background: var(--projectColorLight, #e5f1ec);
}

.course-edit-type-item.is-active .course-edit-type-name {
  color: var(--themeColor, #5b8a72);
  font-weight: 600;
}

.course-edit-type-item.is-active .course-edit-type-dot {
  background: var(--themeColor, #5b8a72);
  box-shadow: 0 0 0 6rpx rgba(91, 138, 114, 0.15);
}

.course-edit-popup {
  border-radius: 20rpx 20rpx 0 0 !important;
}

.course-edit-sheet {
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.course-edit-sheet-head {
  padding: 28rpx 32rpx 12rpx;
  flex-shrink: 0;
}

.course-edit-sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #323233;
}

.course-edit-sheet-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #969799;
}

.course-edit-sheet-scroll {
  max-height: calc(75vh - 120rpx);
  padding: 8rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}
