<root-portal>
<van-popup
  show="{{ show }}"
  position="bottom"
  round
  z-index="{{10000}}"
  safe-area-inset-bottom
  bind:close="bindCloseTap"
>
  <view class="panel">
    <view class="panel-header">
      <view class="panel-title-wrap">
        <van-icon name="manager-o" size="40rpx" color="#2499f2" />
        <text class="panel-title">后台管理登录</text>
      </view>
      <view class="panel-close" bindtap="bindCloseTap">
        <van-icon name="cross" size="36rpx" color="#999" />
      </view>
    </view>

    <view class="tenant-info" bindtap="bindSwitchTenantTap">
      <van-icon name="home-o" size="32rpx" color="#8799a3" />
      <text class="tenant-name">{{ tenantName || '未选择场馆' }}</text>
      <van-icon name="arrow" size="28rpx" color="#999" />
    </view>

    <van-cell-group inset custom-class="login-form">
      <van-field
        value="{{ phone }}"
        label="手机号"
        type="number"
        placeholder="请输入管理员手机号"
        maxlength="11"
        data-field="phone"
        bind:change="bindFormChange"
      />
      <van-field
        value="{{ pwd }}"
        label="密码"
        type="password"
        placeholder="请输入管理员密码"
        maxlength="30"
        data-field="pwd"
        bind:change="bindFormChange"
      />
    </van-cell-group>

    <view class="submit-wrap">
      <van-button type="primary" block bind:click="bindLoginTap">登录</van-button>
    </view>
  </view>
</van-popup>
</root-portal>
