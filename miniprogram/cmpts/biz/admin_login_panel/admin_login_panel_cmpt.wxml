<root-portal>
<van-popup
  show="{{ show }}"
  position="bottom"
  round
  z-index="{{10000}}"
  safe-area-inset-bottom
  custom-class="admin-login-popup"
  bind:close="bindCloseTap"
>
  <view class="admin-panel admin-theme">
    <view class="admin-panel-head bg-admin">
      <view class="admin-panel-close" bindtap="bindCloseTap">
        <van-icon name="cross" size="32rpx" color="rgba(255,255,255,0.9)" />
      </view>
      <view class="admin-panel-head-main">
        <view class="admin-panel-avatar">
          <van-icon name="manager-o" size="44rpx" color="#fff" />
        </view>
        <view class="admin-panel-head-text">
          <text class="admin-panel-title">{{ panelTitle }}</text>
          <text class="admin-panel-sub">瑜伽馆管理后台</text>
        </view>
      </view>
    </view>

    <view class="admin-panel-body">
      <view class="admin-form-card">
        <van-field
          value="{{ phone }}"
          label="手机号"
          type="number"
          placeholder="请输入管理员手机号"
          maxlength="11"
          data-field="phone"
          bind:change="bindFormChange"
          custom-class="admin-field"
        />
        <van-field
          value="{{ pwd }}"
          label="密码"
          type="password"
          placeholder="请输入管理员密码"
          maxlength="30"
          data-field="pwd"
          bind:change="bindFormChange"
          custom-class="admin-field"
        />
      </view>

      <van-button type="primary" block custom-class="admin-login-btn" bind:click="bindLoginTap">
        登录
      </van-button>
    </view>
  </view>
</van-popup>
</root-portal>
