<root-portal>
<van-popup
  show="{{ show }}"
  position="bottom"
  round
  z-index="{{10000}}"
  safe-area-inset-bottom
  custom-class="admin-login-popup"
  bind:close="bindCloseTap"
>
  <view class="login-sheet admin-theme">
    <view class="login-sheet-bar"></view>
    <view class="login-sheet-head">
      <text class="login-sheet-title">{{ panelTitle }}</text>
      <view class="login-sheet-close" bindtap="bindCloseTap">
        <van-icon name="cross" size="32rpx" color="#9aabb3" />
      </view>
    </view>

    <view class="login-fields">
      <input
        class="login-input"
        type="number"
        maxlength="11"
        placeholder="手机号"
        value="{{ phone }}"
        data-field="phone"
        bindinput="bindFormChange"
      />
      <input
        class="login-input"
        password
        maxlength="30"
        placeholder="密码"
        value="{{ pwd }}"
        data-field="pwd"
        bindinput="bindFormChange"
      />
    </view>

    <button class="login-submit" bindtap="bindLoginTap">登录</button>
  </view>
</van-popup>
</root-portal>
