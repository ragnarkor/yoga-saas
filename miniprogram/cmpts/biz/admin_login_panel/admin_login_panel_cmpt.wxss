@import '../../../style/project/base/admin_theme_vars.wxss';

.admin-login-popup {
  background: transparent !important;
}

.login-sheet {
  background: var(--adminSurface);
  border-radius: 24rpx 24rpx 0 0;
  padding: 12rpx 40rpx calc(32rpx + env(safe-area-inset-bottom));
}

.login-sheet-bar {
  width: 64rpx;
  height: 8rpx;
  background: var(--adminBorder);
  border-radius: 4rpx;
  margin: 8rpx auto 28rpx;
}

.login-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 36rpx;
}

.login-sheet-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--adminText);
}

.login-sheet-close {
  padding: 8rpx;
}

.login-fields {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.login-input {
  height: 96rpx;
  padding: 0 28rpx;
  background: var(--adminPageBg);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--adminText);
  border: 1rpx solid var(--adminBorder);
}

.login-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: var(--adminColor);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
}

.login-submit::after {
  border: none;
}
