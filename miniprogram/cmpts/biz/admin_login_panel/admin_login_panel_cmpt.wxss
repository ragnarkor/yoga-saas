@import '../../../style/project/base/admin_theme.wxss';

.admin-login-popup {
  background: transparent !important;
  overflow: visible !important;
}

.admin-panel {
  background: var(--adminPageBg);
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.admin-panel-head.bg-admin {
  background: linear-gradient(
    135deg,
    var(--adminColor) 0%,
    var(--adminColorDark) 100%
  );
  color: #fff;
}

.admin-panel-head {
  position: relative;
  padding: 36rpx 32rpx 40rpx;
  box-sizing: border-box;
}

.admin-panel-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.admin-panel-head-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding-right: 64rpx;
}

.admin-panel-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.admin-panel-head-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.admin-panel-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.3;
}

.admin-panel-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.4;
}

.admin-panel-body {
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
}

.admin-form-card {
  background: var(--adminSurface);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
  box-shadow: var(--adminShadow);
  border: 1rpx solid var(--adminBorder);
}

.admin-form-card .admin-field {
  background: transparent;
}

.admin-login-btn {
  height: 88rpx !important;
  border-radius: 16rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  background: linear-gradient(
    135deg,
    var(--adminColor) 0%,
    var(--adminColorDark) 100%
  ) !important;
  border: none !important;
  box-shadow: 0 10rpx 24rpx rgba(74, 124, 140, 0.28);
}
