.mcp-field {
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #ebedf0;
  box-sizing: border-box;
}

.mcp-field-label {
  font-size: 28rpx;
  color: #646566;
  margin-bottom: 16rpx;
}

.mcp-required {
  color: #ee0a24;
  margin-left: 4rpx;
}

.mcp-field-body--disabled {
  opacity: 0.72;
}

.mcp-selected,
.mcp-placeholder {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.mcp-placeholder {
  justify-content: space-between;
  font-size: 28rpx;
  color: #969799;
  padding: 8rpx 0;
}

.mcp-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.mcp-info {
  flex: 1;
  min-width: 0;
}

.mcp-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mcp-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #969799;
}

.mcp-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #c8c9cc;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.mcp-sheet {
  max-height: 75vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.mcp-sheet-head {
  padding: 28rpx 32rpx 12rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-shrink: 0;
}

.mcp-sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #323233;
}

.mcp-sheet-sub {
  font-size: 24rpx;
  color: #969799;
}

.mcp-sheet-loading {
  padding: 48rpx;
  display: flex;
  justify-content: center;
}

.mcp-sheet-scroll {
  max-height: calc(75vh - 100rpx);
  padding: 8rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.mcp-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  border-left: 8rpx solid #81c784;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.mcp-option.is-active {
  background: var(--projectColorLight, #e5f1ec);
}

.mcp-option-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.mcp-option-body {
  flex: 1;
  min-width: 0;
}

.mcp-option-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mcp-option-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #969799;
  line-height: 1.5;
}

.mcp-option-tag {
  display: inline-block;
  margin-right: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--themeColor, #5b8a72);
  background: var(--projectColorLight, #e5f1ec);
}

.mcp-option-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #c8c9cc;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
