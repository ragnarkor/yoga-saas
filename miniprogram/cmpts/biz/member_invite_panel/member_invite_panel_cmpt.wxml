<root-portal>
<van-popup
  show="{{ show }}"
  position="bottom"
  round
  z-index="{{10000}}"
  safe-area-inset-bottom
  bind:close="bindCloseTap"
>
  <view class="panel">
    <view class="panel-header">
      <text class="panel-title">邀请会员</text>
      <view class="panel-close" bindtap="bindCloseTap">
        <van-icon name="cross" size="36rpx" color="#999" />
      </view>
    </view>

    <view wx:if="{{loading}}" class="panel-loading">
      <van-loading size="48rpx" color="{{accentColor}}">生成邀请码...</van-loading>
    </view>

    <block wx:else>
      <view class="invite-poster">
        <view class="invite-poster-head">约课就用小程序</view>
        <view class="invite-poster-body">
          <image
            wx:if="{{qrUrl}}"
            class="invite-qr"
            src="{{qrUrl}}"
            mode="aspectFit"
            show-menu-by-longpress="{{true}}"
          />
          <view wx:else class="invite-qr-placeholder">二维码加载失败</view>
        </view>
        <view class="invite-poster-hint">微信扫一扫或长按识别</view>
        <view class="invite-poster-foot">{{tenantName}}（门店）</view>
      </view>

      <view class="invite-actions">
        <button class="invite-action-btn" open-type="share">
          <van-icon name="share-o" size="44rpx" color="{{accentColor}}" />
          <text>发送给朋友</text>
        </button>
        <view class="invite-action-btn" bindtap="bindSaveTap">
          <van-icon name="down" size="44rpx" color="{{accentColor}}" />
          <text>保存图片</text>
        </view>
      </view>

      <view class="invite-tip">会员扫码后将自动加入本馆</view>
    </block>
  </view>
</van-popup>
</root-portal>
