@import "./coach_common.wxss";

.member-page {
  padding-bottom: 48rpx;
}

.member-toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
}

.member-search {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f7;
  border-radius: 999rpx;
}

.member-search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.member-add-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 0 24rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: var(--themeColor, #5b8a72);
  color: #fff;
  font-size: 28rpx;
}

.member-filters {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.member-filter-item {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--neutralTextSecondary, #646a73);
  background: var(--neutralIconBg, #f2f3f5);
}

.member-filter-item.active {
  color: #fff;
  background: var(--themeColor, #5b8a72);
}

.member-list {
  background: #fff;
}

.member-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f3f3f3;
  gap: 12rpx;
}

.member-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
  flex-shrink: 0;
  overflow: hidden;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.member-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--projectColorLight, #e3efe8);
}

.member-info {
  flex: 1;
  min-width: 0;
  margin: 0 20rpx;
}

.member-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
}

.member-phone {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #999;
}

.member-issue-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: var(--themeColor, #5b8a72);
  color: #fff;
  font-size: 26rpx;
  flex-shrink: 0;
}

.member-cards-btn {
  background: #fff;
  color: var(--themeColor, #5b8a72);
  border: 2rpx solid var(--themeColor, #5b8a72);
}

.issue-page,
.card-edit-page {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.issue-footer,
.card-edit-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}
