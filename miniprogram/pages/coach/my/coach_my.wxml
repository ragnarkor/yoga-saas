<page-meta page-style="{{themeStyle}}" />
<view class="coach-page">
  <coach-tenant-switch title="我的" theme-color="{{themeColor}}" nav-bg="{{themeNavBg}}" bind:change="bindCoachTenantChange" />

  <view class="coach-profile-card">
    <view class="coach-profile-avatar">
      <image wx:if="{{showAvatar}}" src="{{avatarSrc}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
        <van-icon name="user-o" size="56rpx" color="{{themeColor}}" />
      </view>
    </view>
    <view>
      <view class="coach-profile-name">{{userName}}</view>
      <view class="coach-profile-tag">{{roleTag}}</view>
    </view>
  </view>

  <view class="coach-menu-group">
    <view class="coach-menu-item" wx:for="{{menus}}" wx:key="name" bindtap="onMenuTap" data-url="{{item.url}}">
      <text>{{item.name}}</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="coach-menu-group">
    <view class="coach-menu-item" bindtap="onSwitchMember">
      <text>切换回会员版</text>
      <text class="arrow">›</text>
    </view>
    <view class="coach-menu-item" wx:if="{{isSuperAdmin}}" bindtap="onPlatformTap">
      <text>平台管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="coach-menu-item" wx:if="{{!isSuperAdmin}}" bindtap="onAdminLogin">
      <text>超管密码登录</text>
      <text class="arrow">›</text>
    </view>
    <view class="coach-menu-item" bindtap="onLogout">
      <text>{{isSuperAdmin ? '退出超管模式' : '退出当前会话'}}</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <coach-tab-bar active="{{3}}" />
</view>

<cmpt-admin-login-panel
  show="{{adminLoginShow}}"
  mode="{{adminLoginMode}}"
  redirect="{{adminLoginRedirect}}"
  bind:close="bindAdminLoginCloseTap"
  bind:success="bindAdminLoginSuccessTap"
/>
