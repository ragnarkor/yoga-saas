<!-- [AI_START TIMESTAMP=2025-01-27 10:25:00] -->
<page-meta page-style="{{themeStyle}}" />
<view class="coach-page">
  <coach-tenant-switch
    title="客户"
    theme-color="{{themeColor}}"
    nav-bg="{{themeNavBg}}"
    bind:change="bindCoachTenantChange"
  />

  <view class="coach-customer-wrap">
    <!-- Hero 汇总卡片 -->
    <view class="customer-hero" style="background: {{themeColor}};">
      <view class="customer-hero-num">{{totalMembers}}</view>
      <view class="customer-hero-label">总会员数</view>
    </view>

    <!-- 分组卡片 -->
    <block wx:for="{{sections}}" wx:key="title" wx:for-item="section">
      <view class="customer-section {{section.alert ? 'customer-section--alert' : ''}}">
        <view class="customer-section-head">
          <text class="customer-section-title">{{section.title}}</text>
          <text class="customer-section-desc">{{section.desc}}</text>
        </view>
        <view class="customer-card-grid">
          <view
            class="customer-card-item"
            wx:for="{{section.cards}}"
            wx:key="key"
            wx:for-item="card"
            bindtap="onCardTap"
            data-key="{{card.key}}"
          >
            <view class="customer-card-icon {{section.alert ? 'customer-card-icon--alert' : ''}}">
              <van-icon name="{{card.icon}}" size="36rpx" color="{{section.alert ? '#DD9168' : themeColor}}" />
            </view>
            <view class="customer-card-num">{{card.num}}</view>
            <view class="customer-card-label">{{card.label}}</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <coach-tab-bar active="{{1}}" />
</view>
<!-- [AI_END LINES=44 TIMESTAMP=2025-01-27 10:25:00] -->
