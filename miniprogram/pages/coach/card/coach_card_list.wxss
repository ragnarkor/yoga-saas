@import "../coach_common.wxss";

.card-page {
  padding-bottom: 160rpx;
}

.card-loading,
.card-empty {
  /* 见 coach_common.wxss */
}

.card-list {
  padding: 24rpx 32rpx;
}

.card-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-row:active {
  opacity: 0.88;
}

.card-chip {
  width: 112rpx;
  height: 72rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: flex-end;
  padding: 10rpx 12rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  color: #fff;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.18);
}

.card-chip-type {
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.2;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.card-meta-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  background: #f5f6f8;
  font-size: 22rpx;
  line-height: 1.3;
}

.card-meta-tag-label {
  color: #969799;
}

.card-meta-tag-value {
  color: #323233;
  font-weight: 500;
}

.card-meta-tag--price {
  background: var(--projectColorLight, #e5f1ec);
}

.card-meta-tag--price .card-meta-tag-label {
  color: var(--themeColor, #5b8a72);
  opacity: 0.85;
}

.card-meta-tag--price .card-meta-tag-value {
  color: var(--themeColor, #5b8a72);
  font-weight: 600;
}

.card-fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--themeColorLight, #c4b5fd), var(--themeColor, #5b8a72));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}
