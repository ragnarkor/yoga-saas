<page-meta page-style="{{themeStyle}}" />
<view class="coach-page issue-page">
  <coach-tenant-switch
    title="发卡"
    show-back="{{true}}"
    theme-color="{{themeColor}}"
    nav-bg="{{themeNavBg}}"
  />

  <view wx:if="{{pageLoading}}" class="issue-loading">
    <van-loading size="48rpx" color="{{themeColor}}">加载中...</van-loading>
  </view>

  <block wx:else>
    <van-cell-group custom-class="course-edit-group issue-form-group">
      <view class="course-edit-field course-edit-field--inline issue-form-row">
        <text class="course-edit-field-label-inline">会员</text>
        <view class="course-edit-field-row course-edit-field-row--inline">
          <text class="course-edit-field-value">{{userName || '—'}}</text>
          <view class="issue-field-icon-slot"></view>
        </view>
      </view>
      <!-- [AI_START TIMESTAMP=2025-01-27 16:00:00] -->
      <card-tpl-picker
        value="{{selectedTplId}}"
        theme-color="{{themeColor}}"
        label="会员卡"
        required="{{true}}"
        field-class="issue-form-row"
        bind:pick="onCardTplPick"
      />
      <!-- [AI_END LINES=7 TIMESTAMP=2025-01-27 16:00:00] -->

      <view class="course-edit-field course-edit-field--inline issue-form-row" bindtap="bindActivateFieldTap">
        <text class="course-edit-field-label-inline">激活方式</text>
        <view class="course-edit-field-row course-edit-field-row--inline">
          <text class="course-edit-field-value">{{form.activateLabel}}</text>
          <van-icon name="arrow" size="32rpx" color="#c8c9cc" />
        </view>
      </view>

      <!-- [AI_START TIMESTAMP=2025-01-27 16:00:00] -->
      <coach-picker
        value="{{form.coachId}}"
        default-coach-id="{{defaultCoachId}}"
        theme-color="{{themeColor}}"
        label="归属教练"
        field-class="issue-form-row"
        bind:pick="onCoachPick"
      />
      <!-- [AI_END LINES=9 TIMESTAMP=2025-01-27 16:00:00] -->

      <view class="course-edit-field issue-form-row issue-form-row--memo">
        <text class="course-edit-field-label-inline">备注</text>
        <textarea
          class="issue-memo-input"
          value="{{form.memo}}"
          placeholder="选填（最多50字）"
          maxlength="50"
          auto-height
          bindinput="bindMemoInput"
        />
      </view>
    </van-cell-group>
  </block>

  <view class="issue-footer">
    <van-button block round color="{{themeColor}}" bind:click="bindSubmitTap">确定发卡</van-button>
  </view>

  <van-popup
    show="{{activateSheetShow}}"
    position="bottom"
    round
    bind:close="bindCloseActivateSheet"
    custom-class="course-edit-popup"
  >
    <view class="course-edit-sheet">
      <view class="course-edit-sheet-head">
        <text class="course-edit-sheet-title">选择激活方式</text>
        <text class="course-edit-sheet-sub">决定会员卡有效期从何时开始计算</text>
      </view>
      <view class="issue-activate-list">
        <view
          class="issue-activate-item {{form.activate === item.value ? 'is-active' : ''}}"
          wx:for="{{activateOptions}}"
          wx:key="value"
          data-value="{{item.value}}"
          data-label="{{item.label}}"
          bindtap="bindActivatePick"
        >
          <view class="issue-activate-info">
            <text class="issue-activate-label">{{item.label}}</text>
            <text class="issue-activate-desc">{{item.desc}}</text>
          </view>
          <van-icon
            wx:if="{{form.activate === item.value}}"
            name="success"
            size="36rpx"
            color="{{themeColor}}"
          />
        </view>
      </view>
    </view>
  </van-popup>
</view>
