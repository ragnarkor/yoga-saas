<page-meta page-style="{{themeStyle}}" />
<view class="coach-page card-page">
  <coach-tenant-switch
    title="会员卡列表"
    show-back="{{true}}"
    theme-color="{{themeColor}}"
    nav-bg="{{themeNavBg}}"
  />

  <view wx:if="{{loading}}" class="card-loading">
    <van-loading size="48rpx" color="{{themeColor}}">加载中...</van-loading>
  </view>

  <view wx:elif="{{!cardList.length}}" class="card-empty">
    <van-empty description="暂无会员卡">
      <van-button round color="{{themeColor}}" size="small" bind:click="bindAddTap">添加会员卡</van-button>
    </van-empty>
  </view>

  <view wx:else class="card-list">
    <view
      class="card-row"
      wx:for="{{cardList}}"
      wx:key="CARD_TPL_ID"
      data-id="{{item.CARD_TPL_ID}}"
      bindtap="bindCardTap"
    >
      <view class="card-chip" style="background: {{item.CARD_TPL_COLOR}};">
        <text class="card-chip-type">{{item.typeDesc}}</text>
      </view>
      <view class="card-info">
        <view class="card-name">{{item.CARD_TPL_NAME}}</view>
        <view class="card-meta-row" wx:if="{{item.metaTags.length}}">
          <view
            class="card-meta-tag {{tag.highlight ? 'card-meta-tag--price' : ''}}"
            wx:for="{{item.metaTags}}"
            wx:for-item="tag"
            wx:key="key"
          >
            <text class="card-meta-tag-label">{{tag.label}}</text>
            <text class="card-meta-tag-value">{{tag.value}}</text>
          </view>
        </view>
      </view>
      <van-icon name="arrow" size="32rpx" color="#ccc" />
    </view>
  </view>

  <view class="card-fab" bindtap="bindAddTap">
    <van-icon name="add" size="48rpx" color="#fff" />
  </view>
</view>
