@import "../coach_common.wxss";

.ucard-page {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.ucard-list {
  padding: 24rpx 32rpx;
}

.ucard-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.ucard-row:active {
  opacity: 0.88;
}

.ucard-chip {
  width: 112rpx;
  height: 72rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: flex-end;
  padding: 10rpx 12rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.ucard-info {
  flex: 1;
  min-width: 0;
}

.ucard-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.ucard-meta {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #999;
}

.ucard-scope {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #969799;
}

.ucard-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}
