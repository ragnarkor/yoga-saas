@import "../coach_member_card.wxss";
@import "../course/coach_course_edit.wxss";

.issue-form-group {
  --issue-label-width: 6.2em;
}

.issue-form-row {
  box-sizing: border-box;
}

.issue-form-row.course-edit-field--inline {
  align-items: center;
}

.issue-form-row .course-edit-field-label-inline {
  width: var(--issue-label-width);
  max-width: var(--issue-label-width);
  display: flex;
  align-items: center;
  line-height: var(--cell-line-height, 48rpx);
}

.issue-form-row .course-edit-field-row--inline {
  align-items: center;
  min-height: var(--cell-line-height, 48rpx);
}

.issue-form-row .course-edit-field-value,
.issue-form-row .course-edit-field-placeholder-text {
  line-height: var(--cell-line-height, 48rpx);
}

.issue-field-icon-slot {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.issue-form-row.coach-picker-field .coach-picker-label {
  width: var(--issue-label-width);
  max-width: var(--issue-label-width);
  line-height: var(--cell-line-height, 48rpx);
}

.issue-form-row.coach-picker-field .coach-picker-value-wrap {
  align-items: center;
  min-height: var(--cell-line-height, 48rpx);
}

.issue-form-row.coach-picker-field .coach-picker-main {
  justify-content: flex-end;
}

.issue-form-row.coach-picker-field .coach-picker-name {
  line-height: var(--cell-line-height, 48rpx);
  text-align: left;
}

.issue-form-row--memo {
  display: flex;
  align-items: flex-start;
  gap: var(--cell-horizontal-padding, 32rpx);
  padding: var(--cell-vertical-padding, 24rpx)
    var(--cell-horizontal-padding, 32rpx);
  background: #fff;
  border-bottom: 1rpx solid var(--neutralBorder, #ebedf0);
}

.issue-form-row--memo .course-edit-field-label-inline {
  margin-top: 4rpx;
  line-height: 1.4;
}

.issue-form-row.coach-picker-field {
  align-items: center;
}

.issue-form-row.coach-picker-field .coach-picker-label {
  width: var(--issue-label-width);
  max-width: var(--issue-label-width);
  line-height: var(--cell-line-height, 48rpx);
}

.issue-form-row.coach-picker-field .coach-picker-value-wrap {
  align-items: center;
  min-height: var(--cell-line-height, 48rpx);
}

.issue-form-row.coach-picker-field .coach-picker-main {
  justify-content: flex-end;
}

.issue-form-row.coach-picker-field .coach-picker-name {
  line-height: var(--cell-line-height, 48rpx);
  text-align: left;
}

.issue-memo-input {
  flex: 1;
  min-width: 0;
  min-height: 72rpx;
  padding: 0;
  font-size: var(--cell-font-size, 28rpx);
  color: #323233;
  line-height: 1.5;
  text-align: left;
}

.issue-memo-input::placeholder {
  color: #969799;
}

.issue-loading {
  /* 见 coach_common.wxss */
}

.course-edit-field-value--placeholder {
  color: #969799;
}
.issue-activate-list {
  padding: 8rpx 24rpx 32rpx;
}

.issue-activate-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
}

.issue-activate-item.is-active {
  background: var(--projectColorLight, #e5f1ec);
}

.issue-activate-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.issue-activate-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.issue-activate-desc {
  font-size: 24rpx;
  color: #969799;
  line-height: 1.45;
}
