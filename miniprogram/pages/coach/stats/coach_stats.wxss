@import "../coach_common.wxss";

.stats-page {
  padding-bottom: 48rpx;
}

/* [AI_START TIMESTAMP=2025-01-27 09:40:00] */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 32rpx 24rpx 16rpx;
  background: var(--neutralSurface, #fff);
}
/* [AI_END LINES=8 TIMESTAMP=2025-01-27 09:40:00] */

.stats-grid-item {
  width: 33.33%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 8rpx 36rpx;
}

.stats-grid-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--neutralIconBg, #f2f3f5);
  margin-bottom: 16rpx;
}

.stats-grid-text {
  font-size: 26rpx;
  color: var(--neutralTextSecondary, #646a73);
  text-align: center;
}

.stats-tip {
  margin: 16rpx 24rpx 24rpx;
  padding: 20rpx 24rpx;
  background: var(--neutralIconBg, #f2f3f5);
  border-radius: var(--radius-md, 16rpx);
  display: flex;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--neutralTextTertiary, #8f959e);
  line-height: 1.6;
}

.stats-section {
  margin: 0 0 16rpx;
  background: var(--neutralSurface, #fff);
}

.stats-section-title {
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
  background: var(--neutralIconBg, #f2f3f5);
}

.stats-table-head,
.stats-table-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--neutralBorder, #e8e9eb);
}

.stats-table-head {
  font-size: 26rpx;
  color: var(--neutralTextSecondary, #646a73);
  background: var(--neutralIconBg, #f2f3f5);
}

.stats-table-row:last-child {
  border-bottom: none;
}

.stats-col-name {
  flex: 1.2;
  min-width: 0;
  font-size: 28rpx;
  color: var(--neutralText, #1f2329);
}

.stats-col-num {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: var(--themeColor, #5b8a72);
  font-weight: 600;
}

.stats-col-amt {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: var(--themeColor, #5b8a72);
  font-weight: 600;
}

.stats-summary-card {
  margin: 24rpx;
  padding: 32rpx 24rpx;
  background: var(--neutralSurface, #fff);
  border-radius: var(--radius-xl, 24rpx);
  display: flex;
  flex-wrap: wrap;
  box-shadow: var(--projectShadowSm, 0 2rpx 12rpx rgba(91, 138, 114, 0.08));
}

.stats-summary-item {
  width: 50%;
  box-sizing: border-box;
  padding: 16rpx 12rpx;
  text-align: center;
}

.stats-summary-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--themeColor, #5b8a72);
}

.stats-summary-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--neutralTextTertiary, #8f959e);
}

.stats-loading,
.stats-empty {
  padding: 80rpx 0;
  text-align: center;
  color: var(--neutralTextTertiary, #8f959e);
  font-size: 28rpx;
}

.stats-rank-no {
  width: 48rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: var(--neutralTextTertiary, #8f959e);
  text-align: center;
}

.stats-rank-no.top {
  color: var(--themeColor, #5b8a72);
  font-weight: 700;
}

.stats-col-user {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  line-height: 1.35;
}

.stats-user-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--neutralTextTertiary, #8f959e);
  font-weight: 400;
  width: 100%;
}

.stats-filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: var(--neutralSurface, #fff);
  flex-wrap: wrap;
}

.stats-filter-item {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--neutralTextSecondary, #646a73);
  background: var(--neutralIconBg, #f2f3f5);
}

.stats-filter-item.active {
  color: #fff;
  background: var(--themeColor, #5b8a72);
}

.stats-search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 0 24rpx 16rpx;
  padding: 0 24rpx;
  height: 72rpx;
  background: var(--neutralSurface, #fff);
  border-radius: 999rpx;
}

.stats-search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--neutralText, #1f2329);
}

.stats-list-row {
  padding: 24rpx 32rpx;
  background: var(--neutralSurface, #fff);
  border-bottom: 1rpx solid var(--neutralBorder, #e8e9eb);
}

.stats-list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
}

.stats-list-meta {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--neutralTextTertiary, #8f959e);
  line-height: 1.5;
}

.stats-list-tag {
  display: inline-block;
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--themeColor, #5b8a72);
  background: var(--projectColorLight, #ede9fe);
}

/* ==================== 约课排名 TOP3 + 表格 ==================== */
.rank-page {
  padding-bottom: 48rpx;
}

.rank-podium-card {
  margin: 24rpx;
  padding: 28rpx 20rpx 24rpx;
  background: var(--neutralSurface, #fff);
  border-radius: 20rpx;
  border: 1rpx solid var(--neutralBorder, #e8e9eb);
  box-shadow: 0 4rpx 24rpx var(--neutralShadow, rgba(31, 35, 41, 0.06));
}

.rank-podium-title {
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--neutralTextTertiary, #8f959e);
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.rank-podium {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 16rpx;
  min-height: 380rpx;
  padding-top: 16rpx;
}

.rank-podium-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.rank-podium-head {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 12rpx;
  z-index: 2;
}

.rank-podium-crown {
  font-size: 36rpx;
  line-height: 1;
  margin-bottom: -8rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(255, 193, 7, 0.45));
  transform: translateY(-4rpx);
}

.rank-podium-item--1 .rank-podium-crown {
  font-size: 48rpx;
  margin-bottom: -10rpx;
}

.rank-podium-item--2 .rank-podium-crown {
  font-size: 38rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(144, 164, 174, 0.45));
}

.rank-podium-item--3 .rank-podium-crown {
  font-size: 34rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(255, 138, 101, 0.4));
}

.rank-podium-avatar {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: visible;
  box-sizing: border-box;
  border: 4rpx solid #cfd8dc;
  background: var(--neutralIconBg, #f2f3f5);
}

.rank-podium-item--1 .rank-podium-avatar {
  width: 112rpx;
  height: 112rpx;
  border-color: #ffc947;
  box-shadow: 0 6rpx 20rpx rgba(255, 179, 0, 0.35);
}

.rank-podium-item--2 .rank-podium-avatar {
  border-color: #90a4ae;
  box-shadow: 0 4rpx 16rpx rgba(144, 164, 174, 0.3);
}

.rank-podium-item--3 .rank-podium-avatar {
  border-color: #ff8a65;
  box-shadow: 0 4rpx 16rpx rgba(255, 138, 101, 0.28);
}

.rank-podium-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.rank-podium-avatar-ph {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(145deg, var(--themeColor, #5b8a72), #7cb89a);
}

.rank-podium-item--1 .rank-podium-avatar-ph {
  font-size: 42rpx;
}

.rank-podium-rank-badge {
  position: absolute;
  right: -6rpx;
  bottom: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  line-height: 36rpx;
  text-align: center;
  border: 2rpx solid #fff;
  box-sizing: border-box;
}

.rank-podium-item--1 .rank-podium-rank-badge {
  background: linear-gradient(145deg, #ffc947, #ffb300);
}

.rank-podium-item--2 .rank-podium-rank-badge {
  background: linear-gradient(145deg, #b0bec5, #78909c);
}

.rank-podium-item--3 .rank-podium-rank-badge {
  background: linear-gradient(145deg, #ffab91, #ff7043);
}

.rank-podium-bar {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx 16rpx;
  border-radius: 16rpx 16rpx 8rpx 8rpx;
  background: var(--neutralIconBg, #f2f3f5);
  text-align: center;
}

.rank-podium-item--1 .rank-podium-bar {
  min-height: 260rpx;
  background: linear-gradient(180deg, #fff8e8 0%, #fff3d6 100%);
  border: 2rpx solid #ffe0a3;
}

.rank-podium-item--2 .rank-podium-bar {
  min-height: 220rpx;
  background: linear-gradient(180deg, #f5f7fa 0%, #eceff1 100%);
  border: 2rpx solid #cfd8dc;
}

.rank-podium-item--3 .rank-podium-bar {
  min-height: 160rpx;
  background: linear-gradient(180deg, #fff6f0 0%, #ffe8d9 100%);
  border: 2rpx solid #ffccbc;
}

.rank-podium-name {
  width: 100%;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
}

.rank-podium-sub {
  width: 100%;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--neutralTextTertiary, #8f959e);
}

.rank-podium-count {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--themeColor, #5b8a72);
  line-height: 1.1;
}

.rank-podium-unit {
  font-size: 22rpx;
  font-weight: 500;
  margin-left: 2rpx;
}

.rank-podium-checkin {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--neutralTextSecondary, #646a73);
}

.rank-table-section {
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid var(--neutralBorder, #e8e9eb);
  box-shadow: 0 4rpx 24rpx var(--neutralShadow, rgba(31, 35, 41, 0.06));
}

.rank-only-top-tip {
  margin: 0 24rpx 24rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--neutralTextTertiary, #8f959e);
  background: var(--neutralSurface, #fff);
  border-radius: 12rpx;
}
