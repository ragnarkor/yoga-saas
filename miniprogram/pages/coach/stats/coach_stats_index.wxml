<page-meta page-style="{{themeStyle}}" />
<view class="coach-page stats-page">
  <coach-tenant-switch
    title="数据统计"
    show-back="{{true}}"
    theme-color="{{themeColor}}"
    nav-bg="{{themeNavBg}}"
  />

  <view class="stats-grid">
    <view
      class="stats-grid-item"
      wx:for="{{menus}}"
      wx:key="name"
      bindtap="onMenuTap"
      data-url="{{item.url}}"
    >
      <view class="stats-grid-icon" style="background: {{item.color}}20;">
        <van-icon name="{{item.icon}}" size="48rpx" color="{{item.color}}" />
      </view>
      <text class="stats-grid-text">{{item.name}}</text>
    </view>
  </view>

  <view class="stats-tip">
    <van-icon name="info-o" size="32rpx" color="#bbb" />
    <text>预约查询和排课查询已经合并为「上课统计」，它们可能在后续的版本迭代中移除。</text>
  </view>
</view>
