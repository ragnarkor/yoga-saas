@import "./coach_stats.wxss";

.class-stats-page {
  padding-bottom: 48rpx;
}

.cs-date-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: var(--neutralSurface, #fff);
  border-bottom: 1rpx solid var(--neutralBorder, #e8e9eb);
}

.cs-date-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: var(--neutralText, #1f2329);
}

.cs-filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 24rpx;
  font-size: 28rpx;
}

.cs-summary-card {
  margin: 0;
  background: var(--neutralSurface, #fff);
}

.cs-table-head,
.cs-table-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--neutralBorder, #e8e9eb);
}

.cs-table-head {
  background: var(--neutralIconBg, #f2f3f5);
  font-size: 26rpx;
  color: var(--neutralTextSecondary, #646a73);
}

.cs-col-type {
  flex: 1.1;
  min-width: 0;
  font-size: 28rpx;
  color: var(--neutralText, #1f2329);
}

.cs-col-num {
  width: 128rpx;
  text-align: center;
  flex-shrink: 0;
}

.cs-col-amt {
  width: 148rpx;
  text-align: right;
  flex-shrink: 0;
}

.cs-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #c17f59;
}

.cs-coach-empty {
  padding: 80rpx 32rpx;
}

.cs-coach-block {
  margin-top: 16rpx;
  background: var(--neutralSurface, #fff);
}

.cs-coach-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
}

.cs-coach-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.cs-coach-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: var(--projectColorLight, #e8f2ed);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cs-coach-avatar image {
  width: 100%;
  height: 100%;
}

.cs-coach-avatar text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--themeColor, #5b8a72);
}

.cs-coach-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
}

.cs-coach-total {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #d56a7a;
}

.cs-course-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--neutralBorder, #e8e9eb);
}

.cs-course-row:active {
  background: var(--neutralIconBg, #f7f8fa);
}

.cs-course-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: var(--neutralText, #1f2329);
  line-height: 1.45;
}

.cs-course-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.cs-course-cnt {
  font-size: 28rpx;
  color: var(--neutralTextSecondary, #646a73);
}

.cs-filter-sheet {
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
}

.cs-filter-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
  margin-bottom: 24rpx;
}

.cs-filter-field {
  margin-bottom: 24rpx;
}

.cs-filter-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: var(--neutralTextSecondary, #646a73);
}

.cs-filter-value-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: var(--neutralIconBg, #f2f3f5);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--neutralText, #1f2329);
}

.cs-coach-scroll {
  white-space: nowrap;
}

.cs-coach-chip {
  display: inline-block;
  margin-right: 16rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--neutralTextSecondary, #646a73);
  background: var(--neutralIconBg, #f2f3f5);
  border: 2rpx solid transparent;
}

.cs-coach-chip.is-active {
  color: #fff;
  font-weight: 600;
}

.cs-filter-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}
