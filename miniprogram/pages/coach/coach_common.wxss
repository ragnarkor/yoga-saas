/** 教练版公共样式 */
.coach-page {
  min-height: 100vh;
  background: #f5f3f8;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.coach-header {
  position: relative;
  padding: 24rpx 32rpx 120rpx;
  background: linear-gradient(160deg, #c4b5fd 0%, #ddd6fe 40%, #f5d0fe 100%);
}

.coach-header-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  padding-top: 8rpx;
}

.coach-header-compact {
  padding: 16rpx 32rpx 72rpx;
}

.coach-header-sub {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.coach-stats-card {
  margin: -80rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  display: flex;
  box-shadow: 0 8rpx 32rpx rgba(155, 111, 212, 0.12);
}

.coach-stat-item {
  flex: 1;
  text-align: center;
}

.coach-stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
}

.coach-stat-label {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.coach-section {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.coach-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.coach-grid-3 .coach-grid-item {
  width: calc(33.33% - 14rpx);
}

.coach-grid-item {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 8rpx;
  border-radius: 20rpx;
  background: #faf8fc;
}

.coach-grid-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.coach-grid-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.coach-notice {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: #666;
}

.coach-notice-time {
  margin-left: auto;
  font-size: 22rpx;
  color: #aaa;
  flex-shrink: 0;
}

.coach-customer-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 24rpx;
}

.coach-customer-card {
  width: calc(33.33% - 14rpx);
  box-sizing: border-box;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.coach-customer-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-top: 16rpx;
}

.coach-customer-label {
  font-size: 22rpx;
  color: #888;
  margin-top: 8rpx;
  line-height: 1.4;
}

.coach-revenue-card {
  margin: -60rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(155, 111, 212, 0.12);
}

.coach-revenue-sub {
  font-size: 26rpx;
  color: #999;
}

.coach-revenue-num {
  font-size: 64rpx;
  font-weight: 700;
  color: #e6a23c;
  margin: 16rpx 0;
}

.coach-revenue-link {
  font-size: 28rpx;
  color: #9b6fd4;
}

.coach-profile-header {
  padding: 40rpx 32rpx 100rpx;
  background: linear-gradient(160deg, #c4b5fd 0%, #ddd6fe 100%);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.coach-profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  overflow: hidden;
}

.coach-profile-avatar image {
  width: 100%;
  height: 100%;
}

.coach-profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.coach-profile-tag {
  display: inline-block;
  margin-top: 8rpx;
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
}

.coach-menu-group {
  margin: -60rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.coach-menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 30rpx;
  color: #333;
}

.coach-menu-item:last-child {
  border-bottom: none;
}

.coach-menu-item .arrow {
  margin-left: auto;
  color: #ccc;
}
