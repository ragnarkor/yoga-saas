/** 教练版公共样式：主题色仅用于顶栏、选中态与图标点缀 */
.coach-page {
  min-height: 100vh;
  background: var(--neutralBg, #f5f6f8);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ==================== 首页 ==================== */
.coach-home-body {
  padding: 24rpx 24rpx 0;
}

.coach-welcome {
  padding: 8rpx 8rpx 20rpx;
}

.coach-welcome-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--neutralText, #1f2329);
  line-height: 1.35;
}

.coach-welcome-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--neutralTextTertiary, #8f959e);
}

.coach-stats-card {
  background: var(--neutralSurface, #fff);
  border-radius: var(--radius-xl, 24rpx);
  padding: 32rpx 0;
  display: flex;
  margin-bottom: 20rpx;
  box-shadow: var(--projectShadowSm, 0 2rpx 12rpx rgba(91, 138, 114, 0.08));
}

.coach-stat-item {
  flex: 1;
  text-align: center;
  position: relative;
}

.coach-stat-item + .coach-stat-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18%;
  height: 64%;
  width: 1rpx;
  background: var(--neutralBorder, #e8e9eb);
}

.coach-stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--themeColor, #5b8a72);
  line-height: 1.2;
}

.coach-stat-label {
  font-size: 24rpx;
  color: var(--neutralTextTertiary, #8f959e);
  margin-top: 8rpx;
}

.coach-section {
  margin-bottom: 20rpx;
  background: var(--neutralSurface, #fff);
  border-radius: var(--radius-xl, 24rpx);
  padding: 24rpx 20rpx 12rpx;
  box-shadow: var(--projectShadowSm, 0 2rpx 12rpx rgba(91, 138, 114, 0.08));
}

.coach-section-head {
  padding: 0 8rpx 16rpx;
}

.coach-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
}

.coach-section-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--neutralTextTertiary, #8f959e);
}

.coach-grid {
  display: flex;
  flex-wrap: wrap;
}

.coach-grid-3 .coach-grid-item {
  width: 33.33%;
}

.coach-grid-item {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 8rpx 24rpx;
  border-radius: var(--radius-md, 16rpx);
  transition:
    background var(--transition-fast, 0.15s ease),
    transform var(--transition-fast, 0.15s ease);
}

.coach-grid-item:active {
  background: var(--projectColorLight, #e3efe8);
  transform: scale(0.96);
}

.coach-grid-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg, 22rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  background: var(--neutralIconBg, #f2f3f5);
  transition: transform var(--transition-base, 0.25s ease);
}

.coach-grid-item:active .coach-grid-icon {
  transform: scale(0.9);
}

.coach-grid-text {
  font-size: 24rpx;
  color: var(--neutralTextSecondary, #646a73);
  text-align: center;
  line-height: 1.35;
}

/* ==================== 兼容旧页头（客户/营销等） ==================== */
.coach-header {
  display: none;
}

.coach-header-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.coach-header-compact {
  display: none;
}

.coach-notice {
  margin-bottom: 20rpx;
  background: var(--projectColorLight, #e3efe8);
  border-radius: var(--radius-md, 16rpx);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: var(--neutralTextSecondary, #646a73);
}

.coach-notice-time {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--neutralTextTertiary, #8f959e);
  flex-shrink: 0;
}

/* ==================== 客户页 ==================== */
.coach-customer-wrap {
  padding: 24rpx;
}

.coach-customer-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.coach-customer-card {
  width: calc(33.33% - 11rpx);
  box-sizing: border-box;
  background: var(--neutralSurface, #fff);
  border-radius: var(--radius-md, 16rpx);
  padding: 24rpx 12rpx;
  box-shadow: var(--projectShadowSm, 0 2rpx 12rpx rgba(91, 138, 114, 0.08));
  transition: transform var(--transition-fast, 0.15s ease);
}

.coach-customer-card:active {
  transform: scale(0.96);
}

.coach-customer-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--themeColor, #5b8a72);
  margin-top: 12rpx;
}

.coach-customer-label {
  font-size: 22rpx;
  color: var(--neutralTextTertiary, #8f959e);
  margin-top: 8rpx;
  line-height: 1.4;
}

/* ==================== 营销页 ==================== */
.coach-revenue-card {
  margin: 24rpx;
  background: linear-gradient(
    135deg,
    var(--projectColorLight, #e3efe8) 0%,
    var(--neutralSurface, #fff) 100%
  );
  border-radius: var(--radius-xl, 24rpx);
  padding: 48rpx 24rpx;
  text-align: center;
  box-shadow: var(--projectShadow, 0 4rpx 20rpx rgba(91, 138, 114, 0.1));
}

.coach-revenue-sub {
  font-size: 26rpx;
  color: var(--neutralTextTertiary, #8f959e);
}

.coach-revenue-num {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--themeColor, #5b8a72);
  margin: 16rpx 0;
}

.coach-revenue-link {
  font-size: 28rpx;
  color: var(--themeColor, #5b8a72);
}

/* ==================== 我的页 ==================== */
.coach-profile-card {
  margin: 24rpx 24rpx 20rpx;
  padding: 32rpx 28rpx;
  background: var(--neutralSurface, #fff);
  border-radius: var(--radius-xl, 24rpx);
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: var(--projectShadowSm, 0 2rpx 12rpx rgba(91, 138, 114, 0.08));
}

.coach-profile-header {
  display: none;
}

.coach-profile-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--neutralIconBg, #f2f3f5);
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid var(--projectColorLight, #e3efe8);
  box-shadow: 0 2rpx 12rpx rgba(91, 138, 114, 0.1);
}

.coach-profile-avatar image {
  width: 100%;
  height: 100%;
}

.coach-profile-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
}

.coach-profile-tag {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 14rpx;
  background: var(--neutralIconBg, #f2f3f5);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--neutralTextSecondary, #646a73);
}

.coach-menu-group {
  margin: 0 24rpx 20rpx;
  background: var(--neutralSurface, #fff);
  border-radius: var(--radius-xl, 24rpx);
  overflow: hidden;
  box-shadow: var(--projectShadowSm, 0 2rpx 12rpx rgba(91, 138, 114, 0.08));
}

.coach-menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--neutralBorder, #e8e9eb);
  font-size: 30rpx;
  color: var(--neutralText, #1f2329);
}

.coach-menu-item:last-child {
  border-bottom: none;
}

.coach-menu-item:active {
  background: var(--neutralIconBg, #f2f3f5);
}

.coach-menu-item .arrow {
  margin-left: auto;
  color: var(--neutralTextTertiary, #c8c9cc);
  font-size: 28rpx;
}

.coach-theme-text {
  color: var(--themeColor, #5b8a72);
}
