@import "../coach_common.wxss";

.schedule-page {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.schedule-tabs {
  background: var(--neutralSurface, #fff);
}

.schedule-tabs .van-tabs__wrap {
  height: 88rpx !important;
}

.schedule-tabs .van-tab {
  font-size: 28rpx !important;
  padding: 0 16rpx !important;
}

.schedule-tabs .van-tabs__line {
  border-radius: 6rpx !important;
}

.schedule-week-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: var(--neutralSurface, #fff);
  border-bottom: 1rpx solid var(--neutralBorderLight, #f0f1f3);
}

.schedule-week-btn {
  font-size: 26rpx;
  color: var(--themeColor, #5b8a72);
  padding: 8rpx 12rpx;
  transition: opacity var(--transition-fast, 0.15s ease);
}

.schedule-week-btn:active {
  opacity: 0.7;
}

.schedule-week-range {
  font-size: 26rpx;
  color: var(--neutralTextSecondary, #646a73);
  font-weight: 500;
}

.schedule-loading {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.schedule-scroll {
  width: 100%;
  white-space: nowrap;
}

/* [AI_START TIMESTAMP=2025-01-26 10:20:00] */
.schedule-grid {
  display: inline-block;
  min-width: 100%;
  background: var(--neutralSurface, #fff);
}

.schedule-row {
  display: flex;
  border-bottom: 1rpx solid var(--neutralBorderLight, #f0f1f3);
}

.schedule-head .schedule-day-col {
  background: var(--projectColorLight, #e3efe8);
  font-weight: 600;
  color: var(--projectColorDark, #4a7160);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
}

.schedule-time-col {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--neutralTextTertiary, #8f959e);
  background: var(--projectBgSoft, #fafbf9);
  border-right: 1rpx solid var(--neutralBorderLight, #f0f1f3);
  min-height: 160rpx;
}

.schedule-day-col {
  flex: 1;
  min-width: 140rpx;
  min-height: 160rpx;
  padding: 8rpx;
  box-sizing: border-box;
  border-right: 1rpx solid var(--neutralBorderLight, #f0f1f3);
  white-space: normal;
}

.schedule-card {
  height: 100%;
  min-height: 144rpx;
  border-radius: var(--radius-sm, 12rpx);
  padding: 12rpx;
  box-sizing: border-box;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: transform var(--transition-fast, 0.15s ease);
}

.schedule-card:active {
  transform: scale(0.97);
}
/* [AI_END LINES=14 TIMESTAMP=2025-01-26 10:20:00] */

.schedule-card-teacher {
  opacity: 0.95;
  font-size: 20rpx;
}

.schedule-card-title {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.schedule-card-meta {
  margin-top: auto;
  font-size: 20rpx;
  opacity: 0.92;
}

.schedule-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.schedule-bottom van-button {
  flex: 1;
}

.schedule-canvas-hidden {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 750px;
  height: 1200px;
}

.schedule-preview {
  padding: 32rpx;
  width: 620rpx;
  box-sizing: border-box;
}

.schedule-preview-img {
  width: 100%;
  border-radius: 16rpx;
}

.schedule-preview-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.schedule-preview-actions van-button {
  flex: 1;
}

.schedule-stars {
  letter-spacing: 2rpx;
  font-size: 20rpx;
}
