@import "../coach_common.wxss";

.schedule-edit-page {
  min-height: 100vh;
  background: #f5f6f7;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.schedule-edit-loading {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.schedule-edit-group {
  margin-top: 24rpx !important;
}

.schedule-edit-save {
  margin: 48rpx 32rpx 0;
}

.schedule-edit-del {
  margin: 24rpx 32rpx 0;
}

.schedule-edit-tip {
  padding: 16rpx 32rpx 0;
  font-size: 24rpx;
  line-height: 1.5;
  color: #969799;
}

.schedule-calendar-wrap {
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.schedule-calendar-head {
  padding: 28rpx 32rpx 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.schedule-calendar-wrap .van-calendar {
  height: 640rpx !important;
}

.schedule-course-field {
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #ebedf0;
}

.schedule-course-field-label {
  font-size: 28rpx;
  color: #646566;
  margin-bottom: 16rpx;
}

.schedule-course-required {
  color: #ee0a24;
  margin-left: 4rpx;
}

.schedule-course-selected,
.schedule-course-placeholder {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.schedule-course-placeholder {
  justify-content: space-between;
  font-size: 28rpx;
  color: #969799;
  padding: 8rpx 0;
}

.schedule-course-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.schedule-course-info {
  flex: 1;
  min-width: 0;
}

.schedule-course-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.schedule-course-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #969799;
}

.schedule-course-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #c8c9cc;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.schedule-course-sheet {
  max-height: 75vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.schedule-course-sheet-head {
  padding: 28rpx 32rpx 12rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-shrink: 0;
}

.schedule-course-sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #323233;
}

.schedule-course-sheet-sub {
  font-size: 24rpx;
  color: #969799;
}

.schedule-course-sheet-scroll {
  max-height: calc(75vh - 100rpx);
  padding: 8rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.schedule-course-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  border-left: 8rpx solid #81c784;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.schedule-course-option.is-active {
  background: var(--projectColorLight, #e5f1ec);
}

.schedule-course-option-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.schedule-course-option-body {
  flex: 1;
  min-width: 0;
}

.schedule-course-option-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.schedule-course-option-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #969799;
  line-height: 1.5;
}

.schedule-course-option-tag {
  display: inline-block;
  margin-right: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--themeColor, #5b8a72);
  background: var(--projectColorLight, #e5f1ec);
}

.schedule-course-option-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #c8c9cc;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
