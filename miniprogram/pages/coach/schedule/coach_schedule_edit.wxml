<page-meta page-style="{{themeStyle}}" />
<view class="coach-page schedule-edit-page">
  <coach-tenant-switch
    title="{{pageTitle}}"
    show-back="{{true}}"
    theme-color="{{themeColor}}"
    nav-bg="{{themeNavBg}}"
  />

  <view wx:if="{{loading}}" class="schedule-edit-loading">
    <van-loading size="48rpx" color="{{themeColor}}">加载中...</van-loading>
  </view>

  <block wx:else>

    <van-cell-group title="排课信息" custom-class="schedule-edit-group">
      <meet-course-picker
        value="{{formMeetId}}"
        theme-color="{{themeColor}}"
        label="课程"
        required="{{true}}"
        disabled="{{isEdit}}"
        empty-text="请先在课程管理中添加课程"
        bind:pick="onCoursePick"
      />
      <van-cell
        title="上课日期"
        required
        is-link="{{!isEdit}}"
        value="{{formDayDisplay || '请选择'}}"
        label="{{isEdit ? '编辑时不可改日期' : '支持多选'}}"
        bind:click="bindDayTap"
      />
      <van-cell
        title="开始时间"
        required
        is-link
        value="{{formStartTime || '请选择'}}"
        bind:click="bindStartTimeTap"
      />
      <van-cell
        title="结束时间"
        value="{{formEndTime}}"
        label="按课程时长 {{duration}} 分钟自动计算"
      />
      <coach-picker
        id-mode="teacher"
        value="{{formTeacherId}}"
        theme-color="{{themeColor}}"
        label="授课老师"
        required="{{true}}"
        field-class="schedule-edit-coach-field"
        bind:pick="onCoachPick"
      />
      <van-field
        label="人数上限"
        type="number"
        value="{{formLimit}}"
        placeholder="0 表示不限"
        bind:change="bindLimitChange"
      />
    </van-cell-group>

    <view class="schedule-edit-save">
      <van-button
        block
        round
        color="{{themeColor}}"
        loading="{{saving}}"
        disabled="{{saving}}"
        bind:click="bindSaveTap"
      >{{isEdit ? '保存修改' : '确认排课'}}</van-button>
    </view>

    <view wx:if="{{isEdit}}" class="schedule-edit-del">
      <van-button block plain type="danger" loading="{{saving}}" bind:click="bindDeleteTap">删除此排课</van-button>
    </view>
  </block>

  <van-popup
    show="{{datePickerShow}}"
    position="bottom"
    round
    bind:close="bindDatePickerClose"
    custom-class="schedule-calendar-popup"
  >
    <view class="schedule-calendar-wrap">
      <view class="schedule-calendar-head">{{isEdit ? '选择日期' : '选择日期（可多选）'}}</view>
      <van-calendar
        poppable="{{ false }}"
        type="{{isEdit ? 'single' : 'multiple'}}"
        show-confirm="{{ true }}"
        color="{{themeColor}}"
        min-date="{{datePickerMin}}"
        default-date="{{calendarDefaultDate}}"
        bind:confirm="bindCalendarConfirm"
      />
    </view>
  </van-popup>

  <van-popup show="{{timePickerShow}}" position="bottom" round bind:close="bindTimePickerClose">
    <van-datetime-picker
      type="time"
      value="{{formStartTime}}"
      bind:confirm="bindTimeConfirm"
      bind:cancel="bindTimePickerClose"
    />
  </van-popup>
</view>
