@import "../coach_common.wxss";

.cq-page {
  min-height: 100vh;
  padding: 16rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  background: #f5f6f8;
  box-sizing: border-box;
}

.cq-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cq-course-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2329;
  text-align: center;
}

.cq-course-time {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #646a73;
}

.cq-notice {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 32rpx;
  font-size: 28rpx;
  color: var(--themeColor, #5b8a72);
}

.cq-rules {
  width: 100%;
  margin-top: 28rpx;
  padding: 24rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  font-size: 24rpx;
  color: #646a73;
  line-height: 1.6;
  box-sizing: border-box;
}

.cq-rules-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 4rpx;
}

.cq-loading {
  padding: 80rpx 0;
}

.cq-qr {
  width: 480rpx;
  height: 480rpx;
  margin-top: 32rpx;
}

.cq-hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #969799;
}

.cq-empty {
  margin-top: 48rpx;
  font-size: 28rpx;
  color: #969799;
}
