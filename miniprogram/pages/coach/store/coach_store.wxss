@import "../coach_common.wxss";

.store-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: 0;
  box-sizing: border-box;
  background: #f5f6f8;
}

.store-tab-scroll {
  background: #fff;
  border-bottom: 1rpx solid #eee;
  white-space: nowrap;
  flex-shrink: 0;
}

.store-tab-bar {
  display: inline-flex;
  min-width: 100%;
  padding: 0 8rpx;
}

.store-tab-item {
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  padding: 24rpx 12rpx 20rpx;
  font-size: 28rpx;
  color: #646566;
  border-bottom: 4rpx solid transparent;
}

.store-tab-item--active {
  font-weight: 600;
}

.store-body {
  flex: 1;
  height: 0;
}

.store-panel {
  padding-bottom: 24rpx;
}

.store-panel--card {
  padding: 24rpx 32rpx 0;
}

.store-section {
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.store-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.store-panel--categories {
  padding-bottom: 24rpx;
}

.store-section--gap {
  margin-top: 24rpx;
}

.store-section-tip--inner {
  margin: 8rpx 0 20rpx;
}

.store-cate-area {
  width: 100%;
}

.store-cate-mv {
  width: 100%;
  z-index: 1;
}

.store-cate-mv.is-dragging {
  z-index: 3;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.store-panel--categories .store-cate-row {
  margin-bottom: 16rpx;
}

.store-cate-mv .store-cate-row {
  margin-bottom: 0;
}

.store-cate-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 88rpx;
  box-sizing: border-box;
}

.store-cate-handle {
  flex-shrink: 0;
  width: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.store-cate-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.store-cate-readonly {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.store-cate-link {
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--themeColor, #5b8a72);
  padding: 8rpx;
}

.store-cate-link--muted {
  color: #969799;
}

.store-cate-del {
  flex-shrink: 0;
  padding: 8rpx;
}

.store-cate-empty {
  padding: 24rpx 0 8rpx;
  font-size: 26rpx;
  color: #c8c9cc;
}

.store-cate-empty--private {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.store-private-picks {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx 16rpx;
}

.store-private-picks-label {
  font-size: 24rpx;
  color: #969799;
}

.store-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0 4rpx;
  color: var(--themeColor, #5b8a72);
  font-size: 28rpx;
}

.store-theme-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.store-theme-row--readonly {
  opacity: 0.55;
}

.store-theme-swatch {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.store-theme-swatch.active {
  border-color: #333;
  transform: scale(1.08);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.store-theme-current {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888;
}

.store-theme-readonly {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #bbb;
}

.store-group {
  margin-top: 24rpx !important;
}

.store-uploader {
  margin-top: 8rpx;
}

.store-logo-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f2f3f5;
}

.store-about-readonly {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.store-about-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f2f3f5;
}

.store-empty-text {
  font-size: 28rpx;
  color: #c8c9cc;
}

.store-map-wrap {
  width: 100%;
}

.store-map {
  width: 100%;
  height: 320rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.store-map-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #969799;
  text-align: center;
}

.store-section-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.store-danger-text {
  color: #ee0a24 !important;
}

.store-loading {
  /* 见 coach_common.wxss */
}

.store-save-bar {
  flex-shrink: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #f5f6f8;
}

.store-save-btn {
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 32rpx !important;
}

.store-readonly-tip {
  flex-shrink: 0;
  text-align: center;
  font-size: 24rpx;
  color: #969799;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #f5f6f8;
}
