@import "../coach_common.wxss";

.course-page {
  padding-bottom: 160rpx;
}

.course-tabs {
  background: #fff;
}

.course-loading,
.course-empty {
  padding: 80rpx 0;
}

.course-list {
  padding: 24rpx 32rpx;
}

.course-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.course-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.course-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.course-info {
  flex: 1;
  min-width: 0;
}

.course-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-duration {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #999;
}

.course-tag {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  border: 2rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.course-tag-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.course-fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--themeColorLight, #c4b5fd), var(--themeColor, #5b8a72));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}
