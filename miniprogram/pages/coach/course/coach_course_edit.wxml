<page-meta page-style="{{themeStyle}}" />
<view class="coach-page course-edit-page">
  <coach-tenant-switch title="{{pageTitle}}" show-back="{{true}}" theme-color="{{themeColor}}" nav-bg="{{themeNavBg}}" />

  <view wx:if="{{loading}}" class="course-edit-loading">
    <van-loading size="48rpx" color="{{themeColor}}">加载中...</van-loading>
  </view>

  <block wx:else>
    <!-- [AI_START TIMESTAMP=2025-01-25 17:30:00] -->
    <view class="course-edit-section">基本信息</view>
    <!-- [AI_END LINES=1 TIMESTAMP=2025-01-25 17:30:00] -->
    <van-cell-group custom-class="course-edit-group">
      <view class="course-edit-field" bindtap="bindTemplateTap">
        <view class="course-edit-field-label">课程模板</view>
        <view wx:if="{{selectedTemplatePreview}}" class="course-edit-field-selected">
          <image class="course-edit-field-cover" src="{{selectedTemplatePreview.cover}}" mode="aspectFill" />
          <view class="course-edit-field-info">
            <view class="course-edit-field-title">{{selectedTemplatePreview.title}}</view>
            <view class="course-edit-field-meta">
              {{selectedTemplatePreview.typeName}} · {{selectedTemplatePreview.durationText}}
            </view>
          </view>
          <van-icon name="arrow" size="32rpx" color="#c8c9cc" />
        </view>
        <view wx:else class="course-edit-field-placeholder">
          <text>选择已有课程作为模板</text>
          <van-icon name="arrow" size="32rpx" color="#c8c9cc" />
        </view>
      </view>

      <van-field
        label="课程名称"
        required
        value="{{formTitle}}"
        placeholder="请输入课程名称"
        maxlength="50"
        bind:change="bindTitleChange"
      />

      <meet-category-picker
        value="{{formTypeId}}"
        theme-color="{{themeColor}}"
        required="{{true}}"
        bind:pick="onTypePick"
      />
      <van-field
        label="时长(分钟)"
        required
        type="number"
        value="{{formStyleSet.duration}}"
        placeholder="60"
        data-field="duration"
        bind:change="bindStyleFieldChange"
      />
      <van-field
        label="扣卡金额"
        type="digit"
        value="{{formStyleSet.cardAmount}}"
        placeholder="0"
        data-field="cardAmount"
        bind:change="bindStyleFieldChange"
      />
      <van-field
        label="扣卡次数"
        type="number"
        value="{{formStyleSet.cardTimes}}"
        placeholder="1"
        data-field="cardTimes"
        bind:change="bindStyleFieldChange"
      />

      <view class="course-edit-field course-edit-field--inline" bindtap="bindColorFieldTap">
        <!-- [AI_START TIMESTAMP=2025-01-25 17:45:00] -->
        <view class="course-edit-field-label-inline">课程颜色</view>
        <!-- [AI_END LINES=1 TIMESTAMP=2025-01-25 17:45:00] -->
        <view class="course-edit-field-row course-edit-field-row--inline">
          <view class="course-edit-color-inline">
            <view
              class="course-color-dot course-color-dot--md"
              style="background: {{formStyleSet.color}};"
            ></view>
            <text class="course-edit-field-value">{{selectedColorLabel}}</text>
          </view>
          <van-icon name="arrow" size="32rpx" color="#c8c9cc" />
        </view>
      </view>
    </van-cell-group>

    <!-- [AI_START TIMESTAMP=2025-01-25 17:30:00] -->
    <view class="course-edit-section">图片</view>
    <!-- [AI_END LINES=1 TIMESTAMP=2025-01-25 17:30:00] -->
    <van-cell-group custom-class="course-edit-group">
      <van-cell title="缩略图" use-label-slot>
        <view slot="label" class="course-edit-upload">
          <view class="course-edit-upload-hint">选填，未上传时将随机使用默认封面</view>
          <van-uploader
            file-list="{{thumbList}}"
            max-count="{{1}}"
            bind:after-read="bindThumbAfterRead"
            bind:delete="bindThumbDelete"
          />
        </view>
      </van-cell>
      <van-cell title="轮播图" use-label-slot>
        <view slot="label" class="course-edit-upload">
          <van-uploader
            file-list="{{carouselList}}"
            max-count="{{6}}"
            bind:after-read="bindCarouselAfterRead"
            bind:delete="bindCarouselDelete"
          />
        </view>
      </van-cell>
    </van-cell-group>

    <!-- [AI_START TIMESTAMP=2025-01-25 17:30:00] -->
    <view class="course-edit-section">课程详情</view>
    <!-- [AI_END LINES=1 TIMESTAMP=2025-01-25 17:30:00] -->
    <van-cell-group custom-class="course-edit-group">
      <van-field
        label="简介"
        type="textarea"
        autosize
        maxlength="500"
        value="{{formStyleSet.desc}}"
        placeholder="课程简介"
        data-field="desc"
        bind:change="bindStyleFieldChange"
      />
      <van-field
        label="注意事项"
        type="textarea"
        autosize
        maxlength="500"
        value="{{formStyleSet.notice}}"
        placeholder="上课须知、着装要求等"
        data-field="notice"
        bind:change="bindStyleFieldChange"
      />
    </van-cell-group>

    <!-- [AI_START TIMESTAMP=2025-01-25 17:30:00] -->
    <view class="course-edit-section">课程设置</view>
    <!-- [AI_END LINES=1 TIMESTAMP=2025-01-25 17:30:00] -->
    <van-cell-group custom-class="course-edit-group">
      <van-field
        label="容纳人数"
        type="number"
        value="{{formStyleSet.capacity}}"
        data-field="capacity"
        bind:change="bindStyleFieldChange"
      />
      <van-field
        label="最低开课人数"
        type="number"
        value="{{formStyleSet.minJoin}}"
        data-field="minJoin"
        bind:change="bindStyleFieldChange"
      />
      <van-cell title="难度" center>
        <van-rate
          slot="right-icon"
          value="{{formStyleSet.difficulty}}"
          count="{{5}}"
          color="#ffb74d"
          void-color="#ddd"
          bind:change="bindRateChange"
        />
      </van-cell>
    </van-cell-group>

    <view class="course-edit-save">
      <van-button type="primary" block color="{{themeColor}}" bind:click="bindSaveTap">
        {{id ? '保存课程' : '创建课程'}}
      </van-button>
    </view>

    <view wx:if="{{id}}" class="course-edit-del-wrap">
      <van-button type="danger" plain block bind:click="bindDeleteTap">删除课程</van-button>
    </view>
  </block>

  <van-popup
    show="{{templateSheetShow}}"
    position="bottom"
    round
    bind:close="bindCloseTemplateSheet"
    custom-class="course-edit-popup"
  >
    <view class="course-edit-sheet">
      <view class="course-edit-sheet-head">
        <text class="course-edit-sheet-title">选择课程模板</text>
        <text class="course-edit-sheet-sub">复制封面、时长、颜色等配置</text>
      </view>
      <scroll-view scroll-y class="course-edit-sheet-scroll" enhanced show-scrollbar="{{false}}">
        <view
          class="course-edit-option {{formStyleSet.templateId === item._id ? 'is-active' : ''}}"
          wx:for="{{templatePickerList}}"
          wx:key="_id"
          data-id="{{item._id}}"
          bindtap="bindTemplatePick"
        >
          <view class="course-color-dot course-color-dot--md" style="background: {{item.color}};"></view>
          <image class="course-edit-option-cover" src="{{item.cover}}" mode="aspectFill" />
          <view class="course-edit-option-body">
            <view class="course-edit-option-title">{{item.title}}</view>
            <view class="course-edit-option-meta">
              <text class="course-edit-option-tag">{{item.typeName}}</text>
              <text>{{item.durationText}}</text>
            </view>
            <view wx:if="{{item.desc}}" class="course-edit-option-desc">{{item.desc}}</view>
          </view>
          <van-icon
            wx:if="{{formStyleSet.templateId === item._id}}"
            name="success"
            size="40rpx"
            color="{{themeColor}}"
          />
        </view>
      </scroll-view>
    </view>
  </van-popup>

  <van-popup
    show="{{colorSheetShow}}"
    position="bottom"
    round
    bind:close="bindCloseColorSheet"
    custom-class="course-edit-popup"
  >
    <view class="course-edit-sheet">
      <view class="course-edit-sheet-head">
        <text class="course-edit-sheet-title">选择课程颜色</text>
        <text class="course-edit-sheet-sub">排课表与约课页将显示此颜色</text>
      </view>
      <view class="course-edit-color-list">
        <view
          class="course-edit-color-item {{formStyleSet.color === item.value ? 'active' : ''}}"
          wx:for="{{colorOptions}}"
          wx:key="value"
          data-color="{{item.value}}"
          data-label="{{item.label}}"
          bindtap="bindColorTap"
        >
          <view class="course-edit-color-dot" style="background: {{item.value}};"></view>
          <view class="course-edit-color-item-info">
            <text class="course-edit-color-label">{{item.label}}</text>
            <text class="course-edit-color-hex">{{item.value}}</text>
          </view>
          <van-icon
            wx:if="{{formStyleSet.color === item.value}}"
            name="success"
            size="36rpx"
            color="{{themeColor}}"
          />
        </view>
      </view>
    </view>
  </van-popup>

</view>
