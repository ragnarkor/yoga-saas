@import "../coach_common.wxss";

.course-edit-page {
  padding-bottom: 48rpx;
}

.course-edit-loading {
  /* 见 coach_common.wxss */
}

/* [AI_START TIMESTAMP=2025-01-25 17:30:00] */
.course-edit-group {
  margin: 0 !important;
}

.course-edit-section {
  padding: 32rpx 32rpx 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--neutralTextSecondary, #646a73);
  letter-spacing: 1rpx;
}
/* [AI_END LINES=12 TIMESTAMP=2025-01-25 17:30:00] */

.course-color-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.course-color-dot--md {
  width: 44rpx;
  height: 44rpx;
}

.course-edit-color-inline {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.course-edit-color-list {
  padding: 0 24rpx 32rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.course-edit-color-field {
  background: #fff;
}

.course-edit-color-preview {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx 16rpx;
}

.course-edit-color-swatch {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  flex-shrink: 0;
}

.course-edit-color-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.course-edit-color-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.course-edit-color-hex {
  font-size: 24rpx;
  color: #969799;
}

.course-edit-color-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
  width: calc(50% - 8rpx);
  box-sizing: border-box;
}

.course-edit-color-item.active {
  background: var(--projectColorLight, #e5f1ec);
}

.course-edit-color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.course-edit-color-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.course-edit-color-label {
  font-size: 28rpx;
  color: #323233;
}

.course-edit-colors-old {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 32rpx 24rpx;
}

.course-edit-color {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.course-edit-color.active {
  border-color: var(--themeColor, #5b8a72);
  transform: scale(1.08);
}

.course-edit-upload {
  margin-top: 12rpx;
}

.course-edit-upload-hint {
  font-size: 24rpx;
  color: #969799;
  margin-bottom: 12rpx;
}

.course-edit-save {
  margin: 32rpx;
}

.course-edit-del-wrap {
  margin: 0 32rpx 32rpx;
}

/* [AI_START TIMESTAMP=2025-01-25 17:30:00] */
.course-edit-field {
  padding: var(--cell-vertical-padding, 24rpx) var(--cell-horizontal-padding, 32rpx);
  background: #fff;
  border-bottom: 1rpx solid var(--neutralBorder, #ebedf0);
  box-sizing: border-box;
}

.course-edit-cell-title {
  color: #646566 !important;
}

.course-edit-cell-value {
  color: #323233 !important;
}

.course-edit-cell-placeholder {
  color: #969799 !important;
}

.course-edit-picker-cell .van-cell__value {
  color: #323233;
}

/* [AI_END LINES=5 TIMESTAMP=2025-01-25 17:30:00] */

/* [AI_START TIMESTAMP=2025-01-25 17:30:00] */
.course-edit-field-label {
  font-size: 28rpx;
  color: #646566;
  margin-bottom: 16rpx;
}
/* [AI_END LINES=4 TIMESTAMP=2025-01-25 17:30:00] */

/* [AI_START TIMESTAMP=2025-01-25 17:45:00] */
.course-edit-required {
  color: #ee0a24;
  margin-right: 4rpx;
}
/* [AI_END LINES=4 TIMESTAMP=2025-01-25 17:45:00] */

.course-edit-field-selected,
.course-edit-field-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.course-edit-field-row {
  justify-content: space-between;
}

/* [AI_START TIMESTAMP=2025-01-25 17:30:00] */
.course-edit-field--inline {
  display: flex;
  align-items: center;
  gap: var(--cell-horizontal-padding, 32rpx);
  min-height: var(--cell-line-height, 48rpx);
}

/* [AI_START TIMESTAMP=2025-01-25 18:00:00] */
.course-edit-field-label-inline {
  width: 6.2em;
  max-width: 6.2em;
  font-size: var(--cell-font-size, 28rpx);
  color: #646566;
  flex-shrink: 0;
  margin-bottom: 0;
  line-height: var(--cell-line-height, 48rpx);
}

.course-edit-field-label-inline--required::before {
  content: "*";
  color: #ee0a24;
  margin-right: 4rpx;
}
/* [AI_END LINES=10 TIMESTAMP=2025-01-25 18:00:00] */

.course-edit-field-row--inline {
  flex: 1;
  min-width: 0;
  justify-content: flex-end;
  align-items: center;
  gap: 8rpx;
}

.course-edit-field-row--inline .course-edit-field-value,
.course-edit-field-row--inline .course-edit-field-placeholder-text {
  flex: 1;
  min-width: 0;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-edit-field-placeholder {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #969799;
}

.course-edit-field-placeholder-text {
  font-size: 28rpx;
  color: #969799;
}

.course-edit-field-value {
  font-size: 28rpx;
  color: #323233;
}

.course-edit-field-cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.course-edit-field-info {
  flex: 1;
  min-width: 0;
}

.course-edit-field-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.course-edit-field-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #969799;
}

.course-edit-sheet {
  max-height: 75vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.course-edit-sheet-head {
  padding: 28rpx 32rpx 12rpx;
  flex-shrink: 0;
}

.course-edit-sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #323233;
}

.course-edit-sheet-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #969799;
}

.course-edit-sheet-scroll {
  max-height: calc(75vh - 120rpx);
  padding: 8rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.course-edit-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.course-edit-option.is-active {
  background: var(--projectColorLight, #e5f1ec);
}

.course-edit-option-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.course-edit-option-body {
  flex: 1;
  min-width: 0;
}

.course-edit-option-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.course-edit-option-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #969799;
}

.course-edit-option-tag {
  display: inline-block;
  margin-right: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--themeColor, #5b8a72);
  background: var(--projectColorLight, #e5f1ec);
}

.course-edit-option-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #c8c9cc;
  line-height: 1.4;
}
