@import "../coach_common.wxss";

.course-edit-page {
  padding-bottom: 48rpx;
}

.course-edit-loading {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.course-edit-group {
  margin: 24rpx 0 !important;
}

.course-edit-color-swatch--sm {
  width: 28rpx;
  height: 28rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.course-edit-color-inline {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.course-edit-color-list {
  padding: 0 24rpx 32rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.course-edit-color-field {
  background: #fff;
}

.course-edit-color-preview {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx 16rpx;
}

.course-edit-color-swatch {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  flex-shrink: 0;
}

.course-edit-color-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.course-edit-color-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.course-edit-color-hex {
  font-size: 24rpx;
  color: #969799;
}

.course-edit-color-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
  width: calc(50% - 8rpx);
  box-sizing: border-box;
}

.course-edit-color-item.active {
  background: var(--projectColorLight, #e5f1ec);
}

.course-edit-color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.course-edit-color-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.course-edit-color-label {
  font-size: 28rpx;
  color: #323233;
}

.course-edit-colors-old {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 32rpx 24rpx;
}

.course-edit-color {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.course-edit-color.active {
  border-color: var(--themeColor, #5b8a72);
  transform: scale(1.08);
}

.course-edit-upload {
  margin-top: 12rpx;
}

.course-edit-save {
  margin: 32rpx;
}

.course-edit-del-wrap {
  margin: 0 32rpx 32rpx;
}

.course-edit-field {
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #ebedf0;
}

.course-edit-field-label {
  font-size: 28rpx;
  color: #646566;
  margin-bottom: 16rpx;
}

.course-edit-required {
  color: #ee0a24;
  margin-left: 4rpx;
}

.course-edit-field-selected,
.course-edit-field-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.course-edit-field-row {
  justify-content: space-between;
}

.course-edit-field--inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.course-edit-field-label-inline {
  font-size: 28rpx;
  color: #646566;
  flex-shrink: 0;
  margin-bottom: 0;
}

.course-edit-field-row--inline {
  flex: 1;
  min-width: 0;
  justify-content: flex-end;
  gap: 12rpx;
}

.course-edit-field-placeholder {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #969799;
}

.course-edit-field-placeholder-text {
  font-size: 28rpx;
  color: #969799;
}

.course-edit-field-value {
  font-size: 28rpx;
  color: #323233;
}

.course-edit-field-cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.course-edit-field-info {
  flex: 1;
  min-width: 0;
}

.course-edit-field-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.course-edit-field-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #969799;
}

.course-edit-sheet {
  max-height: 75vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.course-edit-sheet-head {
  padding: 28rpx 32rpx 12rpx;
  flex-shrink: 0;
}

.course-edit-sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #323233;
}

.course-edit-sheet-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #969799;
}

.course-edit-sheet-scroll {
  max-height: calc(75vh - 120rpx);
  padding: 8rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.course-edit-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  border-left: 8rpx solid #81c784;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.course-edit-option.is-active {
  background: var(--projectColorLight, #e5f1ec);
}

.course-edit-option-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.course-edit-option-body {
  flex: 1;
  min-width: 0;
}

.course-edit-option-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.course-edit-option-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #969799;
}

.course-edit-option-tag {
  display: inline-block;
  margin-right: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--themeColor, #5b8a72);
  background: var(--projectColorLight, #e5f1ec);
}

.course-edit-option-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #c8c9cc;
  line-height: 1.4;
}

.course-edit-type-list {
  padding: 8rpx 24rpx 32rpx;
}

.course-edit-type-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 16rpx;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
  font-size: 30rpx;
  color: #323233;
}

.course-edit-type-item.is-active {
  background: var(--projectColorLight, #e5f1ec);
  color: var(--themeColor, #5b8a72);
  font-weight: 600;
}
