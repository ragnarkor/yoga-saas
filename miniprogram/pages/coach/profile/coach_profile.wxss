@import "../coach_common.wxss";

.profile-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: 0;
  box-sizing: border-box;
  background: #f5f6f7;
}

.profile-loading {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-edit-page {
  flex: 1;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.profile-tip {
  padding: 24rpx 32rpx 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #969799;
}

.profile-group-gap {
  margin-top: 24rpx;
}

.avatar-cell {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar-box {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f2f3f5;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  padding: 0;
  margin: 0;
}

.avatar-btn::after {
  border: none;
}

.profile-uploader {
  margin-top: 8rpx;
}

.submit-wrap {
  margin: 48rpx 32rpx 0;
}
