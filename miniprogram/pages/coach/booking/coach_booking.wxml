<page-meta page-style="{{themeStyle}}" />
<view class="coach-page booking-page">
  <coach-tenant-switch title="预约" show-back="{{true}}" theme-color="{{themeColor}}" nav-bg="{{themeNavBg}}" />

  <van-tabs
    wx:if="{{tabsReady}}"
    id="bookingTabs"
    active="{{activeTab}}"
    color="{{themeColor}}"
    title-active-color="{{themeColor}}"
    line-width="40rpx"
    line-height="6rpx"
    ellipsis="{{false}}"
    bind:change="bindTabChange"
    custom-class="schedule-tabs"
  >
    <van-tab wx:for="{{tabs}}" wx:key="id" title="{{item.name}}" />
  </van-tabs>

  <view class="schedule-week-bar">
    <view class="schedule-week-btn" bindtap="bindPrevWeek">◀ 上周</view>
    <view class="schedule-week-range">{{weekLabel}}</view>
    <view class="schedule-week-btn" bindtap="bindNextWeek">下周 ▶</view>
  </view>

  <view wx:if="{{loading}}" class="schedule-loading">
    <van-loading size="48rpx" color="{{themeColor}}">加载中...</van-loading>
  </view>

  <van-empty wx:elif="{{!hasCourses}}" description="{{emptyText}}" />

  <scroll-view wx:else scroll-x enhanced show-scrollbar="{{false}}" class="schedule-scroll" enable-flex="{{false}}">
    <view class="schedule-grid-wrap">
      <view class="schedule-grid">
        <view class="schedule-row schedule-head">
          <view class="schedule-time-col schedule-time-col--head"></view>
          <view class="schedule-day-col schedule-day-col--head" wx:for="{{weekDays}}" wx:key="day">
            <text class="schedule-day-date">{{item.shortLabel}}</text>
            <text class="schedule-day-week">{{item.weekday}}</text>
          </view>
        </view>
        <view class="schedule-row" wx:for="{{gridRows}}" wx:for-index="rowIdx" wx:key="time">
          <view class="schedule-time-col">{{item.time}}</view>
          <view
            class="schedule-day-col {{cell ? 'schedule-day-col--filled' : 'schedule-day-col--empty'}}"
            wx:for="{{item.cells}}"
            wx:for-item="cell"
            wx:for-index="dayIdx"
            wx:key="dayIdx"
            data-row="{{rowIdx}}"
            data-col="{{dayIdx}}"
          >
            <block wx:if="{{cell && cell.mode === 'multi'}}">
              <view class="schedule-cell-stack">
                <view
                  wx:for="{{cell.items}}"
                  wx:for-item="slot"
                  wx:key="cardId"
                  class="schedule-card schedule-card--mini"
                  style="{{slot.cardStyle}}"
                  catchtap="bindSlotTap"
                  data-row="{{rowIdx}}"
                  data-col="{{dayIdx}}"
                  data-item-idx="{{index}}"
                >
                  <text wx:if="{{slot.isPrivate}}" class="schedule-card-tag">私教</text>
                  <text class="schedule-card-teacher">{{slot.teacherName || '教练'}}</text>
                  <text class="schedule-card-title">{{slot.title}}</text>
                </view>
                <view
                  wx:if="{{cell.overflow > 0}}"
                  class="schedule-card-overflow"
                  catchtap="bindOverflowTap"
                  data-row="{{rowIdx}}"
                  data-col="{{dayIdx}}"
                >+{{cell.overflow}}</view>
              </view>
            </block>
            <view
              wx:elif="{{cell}}"
              class="schedule-card"
              style="{{cell.cardStyle}}"
              catchtap="bindSlotTap"
              data-row="{{rowIdx}}"
              data-col="{{dayIdx}}"
              data-item-idx="0"
            >
              <text wx:if="{{cell.isPrivate}}" class="schedule-card-tag">私教</text>
              <text class="schedule-card-teacher">{{cell.teacherName || '教练'}}</text>
              <text class="schedule-card-title">{{cell.title}}</text>
              <text class="schedule-stars">{{cell.starText}}</text>
              <text class="schedule-card-meta">{{cell.duration}}m · {{cell.typeName}}</text>
            </view>
            <view wx:else class="schedule-empty-hint schedule-empty-hint--readonly">—</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="booking-legend" wx:if="{{statusLegend.length && !loading}}">
    <view class="booking-legend-item" wx:for="{{statusLegend}}" wx:key="key">
      <view
        class="booking-legend-swatch"
        style="background: {{item.bg}}; {{item.border ? 'border: 2rpx solid ' + item.border : ''}}"
      ></view>
      <text class="booking-legend-label">{{item.label}}</text>
    </view>
  </view>
</view>
