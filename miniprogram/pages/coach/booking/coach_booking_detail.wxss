@import "../coach_member_card.wxss";

/* [AI_START TIMESTAMP=2025-01-25 16:30:00] */

/* ==================== 页面容器 ==================== */
.bd-page {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ==================== 渐变信息头 ==================== */
.bd-hero {
  margin: 0;
  padding: 36rpx 32rpx 36rpx;
  background: linear-gradient(
    160deg,
    var(--themeColor, #5b8a72),
    var(--themeColorDark, #4a7860)
  );
  border-radius: 0 0 32rpx 32rpx;
}

.bd-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.bd-hero-title {
  flex: 1;
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.35;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.bd-hero-status {
  flex-shrink: 0;
  padding: 8rpx 22rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--themeColor, #5b8a72);
  background: rgba(255, 255, 255, 0.95);
}

.bd-hero-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.bd-hero-tag {
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.22);
}

.bd-hero-stars {
  font-size: 22rpx;
  color: #ffd56a;
  letter-spacing: 2rpx;
}

/* ==================== 头部元信息 ==================== */
.bd-hero-meta {
  margin-top: 24rpx;
}

.bd-hero-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.7;
}

/* ==================== 容量进度 ==================== */
.bd-hero-capacity {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.15);
}

.bd-hero-capacity-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.bd-hero-capacity-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.bd-hero-capacity-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.bd-hero-progress-track {
  margin-top: 16rpx;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  overflow: hidden;
}

.bd-hero-progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #fff;
  transition: width 0.3s ease;
}

/* ==================== 搜索 + 分段筛选 ==================== */
.bd-toolbar {
  padding: 20rpx 24rpx 0;
}

.bd-search {
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(31, 35, 41, 0.06);
}

.bd-segments {
  display: flex;
  margin-top: 16rpx;
  padding: 6rpx;
  background: #ebedf0;
  border-radius: 100rpx;
}

.bd-segment {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  height: 64rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: #646a73;
  transition: all 0.25s ease;
}

.bd-segment.active {
  background: #fff;
  color: var(--themeColor, #5b8a72);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.bd-segment-num {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 100rpx;
  background: var(--themeColor, #5b8a72);
  color: #fff;
}

.bd-segment.active .bd-segment-num {
  background: var(--themeColor, #5b8a72);
}

/* ==================== 成员列表 ==================== */
.bd-body {
  padding: 20rpx 24rpx 24rpx;
}

.bd-section {
  margin-bottom: 24rpx;
}

.bd-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 8rpx 16rpx;
}

.bd-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
}

.bd-section-count {
  font-size: 24rpx;
  color: #8f959e;
}

/* ==================== 成员卡片（状态色条） ==================== */
.bd-card {
  position: relative;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(31, 35, 41, 0.04);
}

.bd-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.bd-card--pending::before {
  background: #ed6a0c;
}

.bd-card--checked::before {
  background: var(--themeColor, #5b8a72);
}

.bd-card--cancelled::before {
  background: #c8c9cc;
}

.bd-card-inner {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 24rpx 24rpx 28rpx;
}

/* ==================== 头像 ==================== */
.bd-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: #f2f3f5;
}

.bd-avatar image {
  width: 100%;
  height: 100%;
}

.bd-avatar-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 成员信息 ==================== */
.bd-card-main {
  flex: 1;
  min-width: 0;
}

.bd-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bd-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

/* ==================== 状态芯片 ==================== */
.bd-status-chip {
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.5;
}

.bd-status-chip--pending {
  color: #ed6a0c;
  background: #fff7e8;
}

.bd-status-chip--checked {
  color: var(--themeColor, #5b8a72);
  background: var(--projectColorLight, #e3efe8);
}

.bd-status-chip--cancelled {
  color: #969799;
  background: #f2f3f5;
}

/* ==================== 联系信息 ==================== */
.bd-phone {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #646a73;
}

.bd-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8f959e;
  line-height: 1.45;
}

.bd-reason {
  margin-top: 8rpx;
  padding: 10rpx 16rpx;
  background: #fef0ee;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #d4584c;
  line-height: 1.45;
}

/* ==================== 操作按钮 ==================== */
.bd-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.bd-act {
  padding: 12rpx 28rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #646a73;
  background: #f2f3f5;
  transition: opacity 0.2s ease;
}

.bd-act:active {
  opacity: 0.7;
}

.bd-act--primary {
  color: #fff;
  background: var(--themeColor, #5b8a72);
}

/* ==================== 底部操作栏 ==================== */
.bd-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 24rpx rgba(31, 35, 41, 0.08);
}

.bd-footer-btn {
  flex: 1 1 calc(50% - 8rpx) !important;
  min-width: 0 !important;
}

.bd-footer-btn--primary {
  font-weight: 600;
}

/* ==================== 弹窗 ==================== */
.bd-popup {
  border-radius: 32rpx 32rpx 0 0 !important;
}

.bd-sheet {
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bd-sheet-handle {
  width: 64rpx;
  height: 8rpx;
  margin: 20rpx auto 0;
  border-radius: 100rpx;
  background: #e0e0e0;
}

.bd-sheet-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 32rpx auto 24rpx;
}

.bd-sheet-icon--cancel {
  background: #fef0ee;
}

.bd-sheet-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
  text-align: center;
}

.bd-sheet-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #8f959e;
  text-align: center;
}

.bd-sheet-body {
  width: 100%;
  box-sizing: border-box;
  padding: 36rpx 32rpx 40rpx;
}

.bd-sheet-textarea {
  width: 100%;
  box-sizing: border-box;
  min-height: 180rpx;
  padding: 24rpx;
  background: #f5f6f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2329;
  line-height: 1.6;
}

.bd-sheet-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.bd-sheet-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: opacity 0.2s ease;
}

.bd-sheet-btn:active {
  opacity: 0.75;
}

.bd-sheet-btn--ghost {
  background: #f2f3f5;
  color: #646a73;
}

.bd-sheet-btn--danger {
  background: linear-gradient(135deg, #e06c5e, #cc5a4c);
  color: #fff;
}

.bd-sheet-btn--primary {
  background: var(--themeColor, #5b8a72);
  color: #fff;
}

.bd-sheet--book {
  align-items: stretch;
  padding: 0 0 calc(24rpx + env(safe-area-inset-bottom));
}

.bd-book-fields {
  width: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.bd-book-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.bd-book-label {
  font-size: 28rpx;
  color: #646566;
  flex-shrink: 0;
  width: 120rpx;
}

.bd-book-value-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.bd-book-value {
  font-size: 28rpx;
  color: #1f2329;
}

.bd-book-memo {
  padding: 20rpx 0 8rpx;
}

.bd-book-memo-input {
  min-height: 120rpx;
}

.bd-sheet-btns--book {
  padding: 24rpx 32rpx 0;
  box-sizing: border-box;
}

.bd-card-list {
  width: 100%;
  padding: 16rpx 32rpx 32rpx;
  box-sizing: border-box;
}

.bd-card-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #1f2329;
}

.bd-card-item-sub {
  font-size: 24rpx;
  color: #969799;
}

/* [AI_END LINES=320 TIMESTAMP=2025-01-25 16:30:00] */
