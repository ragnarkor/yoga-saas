@import "../coach_common.wxss";

.hc-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: 0;
}

.hc-tip {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin: 16rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: var(--projectColorLight, #e8f2ed);
  border-radius: 16rpx;
}

.hc-tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #646566;
  line-height: 1.6;
}

.hc-tab-scroll {
  flex-shrink: 0;
  margin-top: 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.hc-tab-bar {
  display: inline-flex;
  min-width: 100%;
  padding: 0 8rpx;
}

.hc-tab-item {
  flex: 1;
  min-width: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx 16rpx 18rpx;
  font-size: 28rpx;
  color: #646566;
  border-bottom: 4rpx solid transparent;
  box-sizing: border-box;
}

.hc-tab-item--active {
  font-weight: 600;
}

.hc-tab-count {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #f2f3f5;
  font-size: 20rpx;
  color: #969799;
  line-height: 32rpx;
  text-align: center;
}

.hc-tab-item--active .hc-tab-count {
  background: var(--projectColorLight, #e8f2ed);
  color: var(--themeColor, #6fae96);
}

.hc-body {
  flex: 1;
  height: 0;
  padding: 24rpx;
  box-sizing: border-box;
}

.hc-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
  padding: 22rpx;
  border: 2rpx dashed var(--themeColor, #6fae96);
  border-radius: 16rpx;
  background: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.hc-photo-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #969799;
}

.hc-banner-card {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.hc-banner-img {
  width: 100%;
  height: 280rpx;
  background: #f2f3f5;
}

.hc-banner-img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hc-banner-meta {
  padding: 20rpx 24rpx 24rpx;
}

.hc-list-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.hc-list-icon {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hc-list-body {
  flex: 1;
  min-width: 0;
}

.hc-card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hc-card-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #969799;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hc-card-actions {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}

.hc-action-btn {
  padding: 12rpx;
}

.hc-action-btn--sm {
  padding: 8rpx;
}

.hc-photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hc-photo-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.hc-photo-img {
  width: 100%;
  height: 200rpx;
  background: #f2f3f5;
}

.hc-photo-img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hc-photo-info {
  padding: 16rpx;
}

.hc-photo-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #323233;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hc-photo-album {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #969799;
}

.hc-photo-actions {
  display: flex;
  justify-content: flex-end;
  gap: 4rpx;
  padding: 0 8rpx 12rpx;
}

.hc-popup-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 12rpx;
}

.hc-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.hc-popup-close {
  padding: 8rpx;
}

.hc-popup-form {
  padding: 0 16rpx;
}

.hc-popup-foot {
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
}

.hc-upload {
  padding: 16rpx 32rpx 8rpx;
}

.hc-upload-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #323233;
}

.hc-upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #dcdee0;
  border-radius: 16rpx;
  background: #f7f8fa;
  font-size: 24rpx;
  color: #969799;
}

.hc-upload-preview {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.hc-upload-img {
  width: 100%;
  height: 100%;
}

.hc-upload-del {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}
