@import "../coach_common.wxss";

.coach-hero {
  position: relative;
  height: 340rpx;
  overflow: hidden;
  background: #f0ebe3;
}

.coach-hero-bg {
  width: 100%;
  height: 100%;
  display: block;
}

.coach-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.04) 0%,
    rgba(0, 0, 0, 0.22) 100%
  );
  pointer-events: none;
}

.coach-hero-text {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 88rpx;
  z-index: 1;
}

.coach-hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.35;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.18);
}

.coach-hero-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
}

.coach-home .coach-home-body {
  margin-top: -76rpx;
  padding-top: 0;
  position: relative;
  z-index: 2;
}

.coach-stats-card--hero {
  position: relative;
  z-index: 3;
  box-shadow: 0 12rpx 40rpx rgba(31, 35, 41, 0.14);
}
