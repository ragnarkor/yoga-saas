@import "../../skin/skin.wxss";
@import "../../../../style/project/my_index_base.wxss";

/*投影*/
.main .upside {
  height: 450rpx;
  padding: 0 0 0rpx 0;
}

.main .upside .user-bar .detail .desc {
  color: #fff;
}

.main .down {
  margin-top: -130rpx;
  z-index: 9999;
}

.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  background: rgba(255, 255, 255, 0.95);
}

.avatar-choose-btn {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  opacity: 0;
  z-index: 2;
}

.avatar-choose-btn::after {
  border: none;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder van-icon {
  line-height: 1;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.name-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  height: 52rpx;
  line-height: 52rpx;
}

.name-text {
  width: 100%;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  height: 52rpx;
  line-height: 52rpx;
  display: flex;
  align-items: center;
}

.name-edit-hint {
  font-size: 22rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.65);
  margin-left: 12rpx;
}

.phone-auth-btn {
  margin: 0;
  padding: 0;
  background: transparent;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.4;
  text-align: left;
}

.phone-auth-btn::after {
  border: none;
}

.phone-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
}

/* 菜单列表图标：中性灰，主题色留给顶栏与 Tab */
.menu-group .van-cell__left-icon-wrap,
.menu-group .van-icon {
  color: var(--neutralTextSecondary, #646a73) !important;
}
