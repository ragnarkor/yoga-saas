@import "../../skin/skin.wxss";
@import "../../../../style/project/my_index_base.wxss";

.main {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/*投影*/
.main .upside {
  height: 450rpx;
  padding: 0 0 0rpx 0;
}

.main .upside .user-bar .detail .desc {
  color: #fff;
}

.main .down {
  margin-top: -130rpx;
  z-index: 3;
}

.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  background: rgba(255, 255, 255, 0.95);
}

.avatar-choose-btn {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  opacity: 0;
  z-index: 2;
}

.avatar-choose-btn::after {
  border: none;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder van-icon {
  line-height: 1;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.name-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  height: 52rpx;
  line-height: 52rpx;
}

.name-text {
  width: 100%;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  height: 52rpx;
  line-height: 52rpx;
  display: flex;
  align-items: center;
}

.name-edit-hint {
  font-size: 22rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.65);
  margin-left: 12rpx;
}

.phone-auth-btn {
  margin: 0;
  padding: 0;
  background: transparent;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.4;
  text-align: left;
}

.phone-auth-btn::after {
  border: none;
}

.phone-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
}

.profile-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

.profile-arrow {
  margin-left: auto;
  flex-shrink: 0;
}

.main .upside .user-bar {
  align-items: center;
  padding-right: 32rpx;
}

/* 菜单列表图标：统一主题色，次要项略降透明度 */
.menu-group .van-icon {
  color: var(--themeColor, #5b8a72) !important;
}

.menu-group .mi-coach .van-icon,
.menu-group .mi-setting .van-icon {
  opacity: 0.82;
}

/* ==================== 今日约课 ==================== */
.today-card {
  margin-top: 20rpx;
  padding: 28rpx 28rpx 8rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(91, 138, 114, 0.08);
}

.today-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--neutralBorderLight, #f0f1f3);
}

.today-head-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.today-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
}

.today-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: var(--projectColorLight, #e8f2ed);
  color: var(--themeColor, #5b8a72);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 36rpx;
  text-align: center;
}

.today-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #969799;
}

.today-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 48rpx 24rpx 56rpx;
}

.today-state-text {
  font-size: 28rpx;
  color: #969799;
}

.today-state-sub {
  font-size: 24rpx;
  color: #c8c9cc;
}

.today-list {
  display: flex;
  flex-direction: column;
}

.today-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--neutralBorderLight, #f0f1f3);
}

.today-item:last-child {
  border-bottom: none;
}

.today-item:active {
  opacity: 0.85;
}

.today-time-col {
  flex-shrink: 0;
  width: 108rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--themeColor, #5b8a72);
}

.today-time-start {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #323233;
  line-height: 1.3;
}

.today-time-end {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #969799;
  line-height: 1.3;
}

.today-info {
  flex: 1;
  min-width: 0;
}

.today-course-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.today-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
}

.today-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.today-tag--book {
  color: var(--themeColor, #5b8a72);
  background: var(--projectColorLight, #e8f2ed);
}

.today-tag--checkin {
  color: #1989fa;
  background: #ecf5ff;
}

.today-tag--wait {
  color: #ed6a0c;
  background: #fff7e8;
}

.today-tag--cancel,
.today-tag--system {
  color: #969799;
  background: #f2f3f5;
}

.today-tag--pending {
  color: #646566;
  background: #f2f3f5;
}

.today-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #c8c9cc;
  line-height: 1.45;
}

.today-arrow {
  flex-shrink: 0;
  margin-top: 8rpx;
}
