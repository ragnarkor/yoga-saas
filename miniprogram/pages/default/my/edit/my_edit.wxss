.profile-edit-page {
  min-height: 100vh;
  background: #f5f6f7;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.avatar-cell {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar-box {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f2f3f5;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  padding: 0;
  margin: 0;
}

.avatar-btn::after {
  border: none;
}

.phone-cell {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.phone-auth-btn {
  margin: 0;
  padding: 0 16rpx;
  height: 52rpx;
  line-height: 52rpx;
  font-size: 24rpx;
  color: #5b8a72;
  background: #fff;
  border: 1rpx solid #5b8a72;
  border-radius: 8rpx;
}

.phone-auth-btn::after {
  border: none;
}

.phone-text {
  font-size: 28rpx;
  color: #333;
}

.submit-wrap {
  margin: 48rpx 32rpx 0;
}
