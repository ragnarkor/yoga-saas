@import "../../../style/project/base/appt.wxss";
@import "../skin/skin.wxss";
@import "../../../style/project/default_index_base.wxss";

.home-page {
  padding-bottom: 120rpx;
}

.home-banner,
.home-banner-fallback {
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.banner-swiper,
.banner-item,
.banner-media,
.home-banner-fallback image {
  width: 100%;
  height: 360rpx;
}

.banner-item {
  position: relative;
}

.banner-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.45));
}

.banner-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.home-toolbar {
  display: flex;
  align-items: center;
  margin: -40rpx 24rpx 24rpx;
  padding: 16rpx 20rpx;
  position: relative;
  z-index: 2;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid var(--neutralBorder, #e8e9eb);
  box-shadow: 0 4rpx 20rpx var(--neutralShadow, rgba(31, 35, 41, 0.06));
}

.home-search {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--neutralIconBg, #f2f3f5);
  border-radius: 999rpx;
}

.home-search-placeholder {
  color: #999;
  font-size: 26rpx;
}

.home-phone {
  width: 72rpx;
  height: 72rpx;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.home-section {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid var(--neutralBorder, #e8e9eb);
  box-shadow: 0 4rpx 20rpx var(--neutralShadow, rgba(31, 35, 41, 0.06));
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d332e;
}

.section-empty {
  color: #999;
  font-size: 26rpx;
  padding: 12rpx 0;
}

.announce-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.announce-item:last-child {
  border-bottom: none;
}

.announce-body {
  flex: 1;
  min-width: 0;
  margin: 0 16rpx;
}

.announce-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.announce-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
}

.teacher-scroll {
  width: 100%;
  white-space: nowrap;
}

.teacher-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.teacher-card {
  display: inline-block;
  width: 260rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: #fff;
}

.teacher-cover {
  width: 260rpx;
  height: 180rpx;
  display: block;
}

.teacher-info {
  padding: 16rpx;
}

.teacher-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.teacher-specialty {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: calc(50% - 8rpx);
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f6f8f5;
}

.photo-item image {
  width: 100%;
  height: 220rpx;
  display: block;
}

.photo-caption {
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  color: #666;
}

.home-safe-bottom {
  height: 40rpx;
}

.menu .item {
  width: 50%;
}
