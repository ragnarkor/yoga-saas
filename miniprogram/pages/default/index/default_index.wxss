@import "../../../style/project/base/appt.wxss";
@import "../skin/skin.wxss";
@import "../../../style/project/default_index_base.wxss";

.home-page {
  background: #f7f8fa;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* ---- 顶部横幅 ---- */

.home-hero {
  background: #fff;
}

.home-banner,
.home-banner-fallback {
  width: 100%;
  height: 380rpx;
  overflow: hidden;
}

.banner-swiper,
.banner-item,
.banner-media,
.home-banner-fallback image {
  width: 100%;
  height: 380rpx;
}

.banner-item {
  position: relative;
}

/* ---- 场馆信息卡 ---- */

.home-studio-card {
  display: flex;
  align-items: center;
  margin: -36rpx 24rpx 0;
  padding: 28rpx 32rpx;
  position: relative;
  z-index: 2;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 35, 41, 0.08);
}

.home-studio-name {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.home-studio-divider {
  width: 1rpx;
  height: 48rpx;
  margin: 0 28rpx;
  background: #e8e8e8;
}

.home-studio-phone {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--projectColor, #6fae96);
  border-radius: 50%;
  flex-shrink: 0;
}

.home-studio-phone:active {
  opacity: 0.7;
}

/* ---- 公告条 ---- */

.home-announce-strip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: var(--projectColorLight, #f0edf8);
  border-radius: 16rpx;
}

.home-announce-strip:active {
  opacity: 0.85;
}

.home-announce-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #666;
}

/* ---- 板块 ---- */

.home-section {
  margin: 32rpx 0 0;
  padding: 0 0 8rpx;
}

.section-head {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* ---- 横向滚动通用 ---- */

.hscroll {
  width: 100%;
}

.hscroll-inner {
  display: inline-flex;
  gap: 20rpx;
  padding: 4rpx 24rpx 12rpx;
}

/* ---- 金牌老师 ---- */

.teacher-card {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(31, 35, 41, 0.06);
  flex-shrink: 0;
}

.teacher-card:active {
  opacity: 0.88;
}

.teacher-cover {
  width: 188rpx;
  height: 188rpx;
  border-radius: 12rpx;
  background: #f0f1f3;
}

.teacher-name {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
}

/* ---- 照片墙 ---- */

.photo-card {
  display: inline-flex;
  flex-direction: column;
  width: 280rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(31, 35, 41, 0.06);
  flex-shrink: 0;
}

.photo-card:active {
  opacity: 0.88;
}

.photo-cover {
  width: 248rpx;
  height: 186rpx;
  border-radius: 12rpx;
  background: #f0f1f3;
}

.photo-title {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
}

.home-safe-bottom {
  height: 24rpx;
}

.menu .item {
  width: 50%;
}
