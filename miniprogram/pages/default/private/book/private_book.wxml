<page-meta page-style="{{pageStyle}}" />
<view class="theme-scope private-book-page" style="{{pageStyle}}">
  <cmpt-tenant-switch title="预约私教" show-back="{{true}}" theme-color="{{themeColor}}" />

  <view wx:if="{{loading}}" class="loading-wrap">
    <van-loading size="48rpx" color="{{themeColor}}">加载中...</van-loading>
  </view>

  <van-empty wx:elif="{{!courses.length}}" description="暂无私教课程，请联系馆方" />

  <block wx:else>
    <view class="pb-section">
      <view class="pb-field" bindtap="bindCourseTap">
        <text class="pb-label">私教课程</text>
        <view class="pb-value-row">
          <text class="pb-value">{{form.courseName || '请选择'}}</text>
          <van-icon name="arrow" size="32rpx" color="#c8c9cc" />
        </view>
      </view>
      <view class="pb-field" bindtap="bindTeacherTap">
        <text class="pb-label">授课教练</text>
        <view class="pb-value-row">
          <text class="pb-value">{{form.teacherName || '请选择'}}</text>
          <van-icon name="arrow" size="32rpx" color="#c8c9cc" />
        </view>
      </view>
    </view>

    <view class="pb-section">
      <view class="pb-section-title">选择日期</view>
      <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="pb-date-scroll">
        <view class="pb-date-list">
          <view
            class="pb-date-item {{form.day === item.day ? 'is-active' : ''}}"
            wx:for="{{dateList}}"
            wx:key="day"
            data-day="{{item.day}}"
            bindtap="bindDayTap"
          >
            <text class="pb-date-week">{{item.weekday}}</text>
            <text class="pb-date-day">{{item.shortLabel}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="pb-hint">{{scheduleHint}}</view>
    </view>

    <view class="pb-section pb-section--slots">
      <view class="pb-section-title">可选时段</view>
      <view wx:if="{{slotsLoading}}" class="pb-slots-loading">
        <van-loading size="40rpx" color="{{themeColor}}">计算中...</van-loading>
      </view>
      <view wx:elif="{{!slots.length}}" class="pb-slots-empty">当天暂无可约时段</view>
      <view wx:else class="pb-slot-grid">
        <view
          class="pb-slot {{form.start === item.start ? 'is-selected' : ''}}"
          wx:for="{{slots}}"
          wx:key="start"
          data-start="{{item.start}}"
          data-end="{{item.end}}"
          bindtap="bindSlotTap"
        >
          <text class="pb-slot-time">{{item.start}}</text>
          <text class="pb-slot-end">{{item.end}} 结束</text>
        </view>
      </view>
    </view>

    <view class="pb-footer">
      <view wx:if="{{cardHint}}" class="pb-card-hint">
        <van-icon name="info-o" size="28rpx" color="#969799" />
        <text>{{cardHint}}</text>
      </view>
      <van-button
        block
        round
        color="{{themeColor}}"
        loading="{{submitting}}"
        disabled="{{!form.start || submitting || !cardCanBook}}"
        bind:click="bindSubmitTap"
      >
        {{submitBtnText}}
      </van-button>
    </view>
  </block>

  <van-popup show="{{courseSheetShow}}" position="bottom" round bind:close="bindCloseCourseSheet">
    <view class="pb-sheet">
      <view class="pb-sheet-title">选择私教课程</view>
      <scroll-view scroll-y class="pb-sheet-scroll">
        <view
          class="pb-sheet-item {{form.meetId === item._id ? 'is-active' : ''}}"
          wx:for="{{courses}}"
          wx:key="_id"
          data-id="{{item._id}}"
          bindtap="bindCoursePick"
        >
          <text>{{item.title}}</text>
          <text class="pb-sheet-sub">{{item.duration}}分钟</text>
        </view>
      </scroll-view>
    </view>
  </van-popup>

  <van-popup show="{{teacherSheetShow}}" position="bottom" round bind:close="bindCloseTeacherSheet">
    <view class="pb-sheet">
      <view class="pb-sheet-title">选择教练</view>
      <scroll-view scroll-y class="pb-sheet-scroll">
        <view
          class="pb-sheet-item {{form.teacherId === item._id ? 'is-active' : ''}}"
          wx:for="{{teachers}}"
          wx:key="_id"
          data-id="{{item._id}}"
          bindtap="bindTeacherPick"
        >
          <text>{{item.name}}</text>
          <text wx:if="{{item.specialty}}" class="pb-sheet-sub">{{item.specialty}}</text>
        </view>
      </scroll-view>
    </view>
  </van-popup>

  <van-popup show="{{cardSheetShow}}" position="bottom" round bind:close="bindCloseCardSheet">
    <view class="pb-card-sheet">
      <view class="pb-card-sheet-head">
        <text class="pb-card-sheet-title">选择划扣会员卡</text>
        <text class="pb-card-sheet-sub">本次预约需扣 {{cardNeedTimes}} 次</text>
      </view>
      <view wx:if="{{cardPickLoading}}" class="pb-slots-loading">
        <van-loading size="40rpx" color="{{themeColor}}" />
      </view>
      <scroll-view wx:else scroll-y class="pb-card-sheet-scroll">
        <view
          class="pb-card-option {{selectedCardId === item.id ? 'is-selected' : ''}}"
          wx:for="{{joinCardOptions}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="bindCardPick"
        >
          <view class="pb-card-option-visual" style="background: {{item.color}};">
            <text class="pb-card-option-type">{{item.typeLabel}}</text>
          </view>
          <view class="pb-card-option-body">
            <text class="pb-card-option-name">{{item.name}}</text>
            <text class="pb-card-option-balance">{{item.balanceText}}</text>
          </view>
          <van-icon wx:if="{{selectedCardId === item.id}}" name="success" size="40rpx" color="{{themeColor}}" />
        </view>
      </scroll-view>
      <view class="pb-sheet-actions">
        <van-button block round color="{{themeColor}}" bind:click="bindConfirmBookTap">确认预约并扣卡</van-button>
      </view>
    </view>
  </van-popup>
</view>
