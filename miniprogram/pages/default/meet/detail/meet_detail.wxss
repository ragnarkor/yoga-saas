@import "../../../../style/project/base/appt.wxss";
@import "../../skin/skin.wxss";

.md-page {
	min-height: 100vh;
	background: var(--projectBgSoft, #f5f7f5);
	padding: 24rpx 24rpx 0;
	box-sizing: border-box;
}

.md-summary {
	display: flex;
	padding: 24rpx;
	margin-bottom: 20rpx;
	gap: 24rpx;
}

.md-cover {
	width: 180rpx;
	height: 180rpx;
	border-radius: 16rpx;
	flex-shrink: 0;
	background: #eef0ed;
}

.md-summary-body {
	flex: 1;
	min-width: 0;
	display: flex;
	flex-direction: column;
	justify-content: center;
	gap: 16rpx;
}

.md-title-row {
	display: flex;
	align-items: flex-start;
	justify-content: space-between;
	gap: 12rpx;
}

.md-title {
	font-size: 34rpx;
	font-weight: 700;
	color: #2d2d2d;
	flex: 1;
	line-height: 1.35;
}

.md-limit-tag {
	font-size: 22rpx;
	color: var(--projectColor, #5b8a72);
	background: var(--projectColorLight, #e3efe8);
	padding: 6rpx 14rpx;
	border-radius: 8rpx;
	flex-shrink: 0;
	white-space: nowrap;
}

.md-seat-row {
	display: flex;
	align-items: center;
	gap: 16rpx;
}

.md-progress-track {
	flex: 1;
	height: 12rpx;
	background: #e8ece9;
	border-radius: 6rpx;
	overflow: hidden;
}

.md-progress-bar {
	height: 100%;
	background: linear-gradient(90deg, #7aab92, var(--projectColor, #5b8a72));
	border-radius: 6rpx;
	transition: width 0.3s ease;
}

.md-seat-text {
	font-size: 24rpx;
	color: #888;
	flex-shrink: 0;
}

.md-level-row {
	display: flex;
	align-items: center;
	gap: 16rpx;
}

.md-meta-label {
	font-size: 24rpx;
	color: #999;
}

.md-stars {
	display: flex;
	gap: 4rpx;
}

.md-star {
	font-size: 28rpx;
	color: #ddd;
	line-height: 1;
}

.md-star.on {
	color: var(--projectColor, #5b8a72);
}

.md-info {
	padding: 8rpx 28rpx;
	margin-bottom: 20rpx;
}

.md-info-item {
	display: flex;
	padding: 22rpx 0;
	border-bottom: 1rpx solid #f0f2f0;
}

.md-info-item:last-child {
	border-bottom: none;
}

.md-info-label {
	width: 160rpx;
	font-size: 28rpx;
	color: #999;
	flex-shrink: 0;
}

.md-info-value {
	flex: 1;
	font-size: 28rpx;
	color: #333;
	line-height: 1.5;
}

.md-times {
	padding: 28rpx;
	margin-bottom: 20rpx;
}

.md-section-title {
	font-size: 30rpx;
	font-weight: 600;
	color: #2d2d2d;
	margin-bottom: 20rpx;
}

.md-day-scroll {
	margin-bottom: 20rpx;
	white-space: nowrap;
}

.md-day-list {
	display: inline-flex;
	gap: 16rpx;
	padding-bottom: 4rpx;
}

.md-day-chip {
	display: inline-block;
	padding: 12rpx 28rpx;
	font-size: 26rpx;
	color: #666;
	background: #f5f7f5;
	border-radius: 999rpx;
	border: 2rpx solid transparent;
}

.md-day-chip.active {
	color: var(--projectColor, #5b8a72);
	background: var(--projectColorLight, #e3efe8);
	border-color: var(--projectColor, #5b8a72);
	font-weight: 600;
}

.md-time-grid {
	display: flex;
	flex-wrap: wrap;
	gap: 16rpx;
}

.md-time-chip {
	min-width: calc(50% - 8rpx);
	box-sizing: border-box;
	padding: 20rpx 16rpx;
	background: #f8faf8;
	border-radius: 16rpx;
	border: 2rpx solid transparent;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 6rpx;
}

.md-time-chip.active {
	background: var(--projectColorLight, #e3efe8);
	border-color: var(--projectColor, #5b8a72);
}

.md-time-chip.disabled {
	opacity: 0.55;
}

.md-time-range {
	font-size: 28rpx;
	color: #333;
	font-weight: 500;
}

.md-time-limit {
	font-size: 22rpx;
	color: #999;
}

.md-notes {
	background: #fff9e6;
	border-radius: 16rpx;
	padding: 28rpx;
	margin-bottom: 20rpx;
	border: 1rpx solid #f5ebc8;
}

.md-notes-title {
	font-size: 30rpx;
	font-weight: 600;
	color: #8a6d2b;
	margin-bottom: 16rpx;
}

.md-note-item {
	display: flex;
	gap: 8rpx;
	margin-bottom: 12rpx;
	line-height: 1.6;
}

.md-note-item:last-child {
	margin-bottom: 0;
}

.md-note-num {
	font-size: 26rpx;
	color: #b8953a;
	flex-shrink: 0;
}

.md-note-text {
	font-size: 26rpx;
	color: #6b5a32;
	flex: 1;
}

.md-intro {
	padding: 28rpx;
	margin-bottom: 20rpx;
}

.md-intro-head {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 20rpx;
	margin-bottom: 24rpx;
}

.md-intro-line {
	flex: 1;
	height: 1rpx;
	background: #e0e0e0;
	max-width: 80rpx;
}

.md-intro-title {
	font-size: 30rpx;
	font-weight: 600;
	color: #2d2d2d;
}

.md-intro-swiper {
	width: 100%;
	height: 360rpx;
	border-radius: 16rpx;
	overflow: hidden;
	margin-bottom: 24rpx;
}

.md-intro-img {
	width: 100%;
	height: 100%;
}

.md-intro-text {
	font-size: 28rpx;
	color: #555;
	line-height: 1.75;
	margin-bottom: 16rpx;
	text-align: justify;
}

.md-intro-img-block {
	width: 100%;
	border-radius: 12rpx;
	margin-bottom: 16rpx;
}

.md-bottom-spacer {
	height: calc(140rpx + env(safe-area-inset-bottom));
}

.md-footer {
	position: fixed;
	left: 0;
	right: 0;
	bottom: 0;
	padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
	background: #fff;
	box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
	z-index: 100;
}

.md-book-btn {
	width: 100%;
	height: 88rpx;
	line-height: 88rpx;
	background: var(--projectColor, #5b8a72);
	color: #fff;
	font-size: 32rpx;
	font-weight: 600;
	border-radius: 999rpx;
	border: none;
	padding: 0;
}

.md-book-btn.disabled {
	background: #ccc;
	color: #fff;
}

.md-book-btn::after {
	border: none;
}

.loading-wrap {
	display: flex;
	justify-content: center;
	align-items: center;
	min-height: 60vh;
}
