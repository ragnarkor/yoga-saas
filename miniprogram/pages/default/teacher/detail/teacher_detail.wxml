<page-meta page-style="{{pageStyle}}" />
<view wx:if="{{!isLoad}}" class="loading-wrap">
  <van-loading size="48rpx" color="{{themeColor}}" />
</view>

<view wx:elif="{{!teacher}}" class="loading-wrap">
  <van-empty description="???????" />
</view>

<view class="teacher-detail" wx:else>
  <view class="hero">
    <image class="hero-avatar" mode="aspectFill" src="{{teacher.avatar}}" />
    <view class="hero-name">{{teacher.name}}</view>
    <view class="hero-specialty">{{teacher.specialty}}</view>
  </view>

  <view class="card" wx:if="{{teacher.desc}}">
    <view class="card-title">??</view>
    <view class="card-text">{{teacher.desc}}</view>
  </view>

  <view class="card" wx:if="{{teacher.pics.length > 0}}">
    <view class="card-title">????</view>
    <view class="pic-grid">
      <image wx:for="{{teacher.pics}}" wx:key="*this" mode="aspectFill" src="{{item}}" bindtap="bindPreviewPic" data-url="{{item}}" />
    </view>
  </view>
</view>
