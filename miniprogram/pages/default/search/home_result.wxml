<page-meta page-style="{{pageStyle}}" />
<view wx:if="{{!isLoad}}" class="loading-wrap">
  <van-loading size="48rpx" color="{{themeColor}}" />
</view>

<view class="search-result" wx:else>
  <view class="keyword">??????{{keyword}}</view>

  <view class="group" wx:if="{{meetList.length > 0}}">
    <view class="group-title">?? / ??</view>
    <view class="result-item" wx:for="{{meetList}}" wx:key="_id" bindtap="bindItemTap" data-type="meet" data-id="{{item._id}}">
      <image wx:if="{{item.pic}}" class="result-pic" mode="aspectFill" src="{{item.pic}}" />
      <view class="result-body">
        <view class="result-title text-cut">{{item.title}}</view>
        <view class="result-desc text-cut">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="group" wx:if="{{newsList.length > 0}}">
    <view class="group-title">??</view>
    <view class="result-item" wx:for="{{newsList}}" wx:key="_id" bindtap="bindItemTap" data-type="news" data-id="{{item._id}}">
      <image wx:if="{{item.pic}}" class="result-pic" mode="aspectFill" src="{{item.pic}}" />
      <view class="result-body">
        <view class="result-title text-cut">{{item.title}}</view>
        <view class="result-desc text-cut">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="group" wx:if="{{teacherList.length > 0}}">
    <view class="group-title">??</view>
    <view class="result-item" wx:for="{{teacherList}}" wx:key="_id" bindtap="bindItemTap" data-type="teacher" data-id="{{item._id}}">
      <image wx:if="{{item.pic}}" class="result-pic" mode="aspectFill" src="{{item.pic}}" />
      <view class="result-body">
        <view class="result-title text-cut">{{item.title}}</view>
        <view class="result-desc text-cut">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <van-empty wx:if="{{meetList.length==0 && newsList.length==0 && teacherList.length==0}}" description="???????" />
</view>
