.search-result {
  padding: 24rpx;
  min-height: 100vh;
  background: #f6f7f5;
}

.keyword {
  font-size: 26rpx;
  color: #8ba399;
  margin-bottom: 24rpx;
}

.group {
  margin-bottom: 32rpx;
}

.group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d332e;
  margin-bottom: 16rpx;
}

.result-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.result-pic {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.result-body {
  flex: 1;
  min-width: 0;
}

.result-title {
  font-size: 28rpx;
  color: #2d332e;
  font-weight: 500;
}

.result-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8ba399;
}
