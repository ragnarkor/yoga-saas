.invite-page {
  min-height: 100vh;
  background: #f6f7f5;
}

.invite-center {
  padding: 120rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.invite-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #5b8a72;
  color: #fff;
  font-size: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.invite-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.invite-title.fail {
  color: #e54d42;
}

.invite-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.invite-tenant {
  font-size: 32rpx;
  color: #5b8a72;
  font-weight: 600;
  margin-bottom: 48rpx;
}

.invite-btn {
  width: 100% !important;
  margin-top: 20rpx !important;
}
