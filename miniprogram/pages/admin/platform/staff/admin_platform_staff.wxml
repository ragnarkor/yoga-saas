<view class="platform-staff-page">
  <view wx:if="{{loading}}" class="staff-loading">
    <van-loading size="48rpx" color="#4a7c8c">加载中...</van-loading>
  </view>

  <block wx:else>
    <view class="staff-hero">
      <view class="staff-hero-title">管理员配置</view>
      <view class="staff-hero-tip">管理全平台馆主与教练账号，请在平台管理内使用，与单馆教练版员工管理分离。</view>
      <view class="staff-stats">
        <view class="staff-stat">
          <text class="staff-stat-num">{{stats.total}}</text>
          <text class="staff-stat-label">员工</text>
        </view>
        <view class="staff-stat">
          <text class="staff-stat-num staff-stat-num--ok">{{stats.bound}}</text>
          <text class="staff-stat-label">已绑定</text>
        </view>
        <view class="staff-stat">
          <text class="staff-stat-num staff-stat-num--warn">{{stats.pending}}</text>
          <text class="staff-stat-label">待绑定</text>
        </view>
      </view>
    </view>

    <view class="staff-toolbar">
      <view class="staff-add-btn" bindtap="bindAddTap">
        <van-icon name="plus" size="32rpx" color="#fff" />
        <text>新建馆主/教练</text>
      </view>
    </view>

    <view wx:if="{{list.length === 0}}" class="staff-empty">
      <van-empty description="暂无员工账号" />
    </view>

    <view class="staff-list" wx:else>
      <view class="staff-card {{item.bound ? 'is-bound' : ''}}" wx:for="{{list}}" wx:key="id">
        <view class="staff-card-head">
          <view class="staff-avatar">{{item.name[0] || '员'}}</view>
          <view class="staff-card-main">
            <view class="staff-name-row">
              <text class="staff-name">{{item.name}}</text>
              <text class="staff-role-tag">{{item.typeLabel}}</text>
            </view>
            <view class="staff-tenant">{{item.tenantName}}</view>
            <view class="staff-phone">{{item.phone}}</view>
          </view>
          <view class="staff-badge {{item.bound ? 'staff-badge--on' : ''}}">
            {{item.bound ? '已绑定' : '待绑定'}}
          </view>
        </view>

        <view class="staff-card-meta" wx:if="{{item.bound && item.boundOpenid}}">
          微信 …{{item.boundOpenid}}
        </view>

        <view class="staff-actions">
          <view
            wx:if="{{item.canGenCode}}"
            class="staff-action staff-action--primary"
            bindtap="bindGenTap"
            data-id="{{item.id}}"
            data-name="{{item.name}}"
          >发送绑定邀请</view>
          <view
            class="staff-action staff-action--warn {{item.bound && item.canUnbind ? '' : 'disabled'}}"
            bindtap="bindUnbindTap"
            data-id="{{item.id}}"
            data-name="{{item.name}}"
            data-bound="{{item.bound}}"
            data-can-unbind="{{item.canUnbind}}"
          >解除绑定</view>
          <view
            wx:if="{{item.canDelete}}"
            class="staff-action staff-action--muted"
            bindtap="bindDeleteTap"
            data-id="{{item.id}}"
            data-name="{{item.name}}"
            data-can-delete="{{item.canDelete}}"
          >删除</view>
        </view>
      </view>
    </view>
  </block>
</view>
