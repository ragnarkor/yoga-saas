<view class="platform-form admin-theme">
  <view class="form-card">
    <view class="field field-picker">
      <text class="label">所属瑜伽馆</text>
      <picker mode="selector" range="{{tenantList}}" range-key="TENANT_NAME" value="{{tenantIndex}}" bindchange="bindTenantChange">
        <view class="picker-val">{{tenantList[tenantIndex].TENANT_NAME || '请选择'}}</view>
      </picker>
    </view>
    <view class="field field-picker">
      <text class="label">角色</text>
      <picker mode="selector" range="{{roleOptions}}" range-key="label" value="{{roleIndex}}" bindchange="bindRoleChange">
        <view class="picker-val">{{roleOptions[roleIndex].label}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">姓名</text>
      <input class="input" placeholder="管理员姓名" maxlength="20" value="{{name}}" data-field="name" bindinput="bindInput" />
    </view>
    <view class="field">
      <text class="label">手机号（登录账号）</text>
      <input class="input" type="number" placeholder="手机号" maxlength="11" value="{{phone}}" data-field="phone" bindinput="bindInput" />
    </view>
    <view class="field">
      <text class="label">初始密码（选填）</text>
      <input class="input" password placeholder="不填则自动生成，微信绑定为主" maxlength="30" value="{{pwd}}" data-field="pwd" bindinput="bindInput" />
    </view>
  </view>
  <view class="form-tip">创建后为待绑定空壳账号。馆主请在教练版「员工管理」中添加教练并发送绑定邀请；馆主账号由平台在新建管理员时创建。</view>
  <button class="submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="bindSubmit">创建管理员</button>
</view>
