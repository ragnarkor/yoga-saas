<view class="main-admin bg-admin">

	<view class="login shadow">

		<view class="pic"><van-icon name="manager-o" size="32rpx" color="#8799a3" custom-class="text-admin"  /></view>
		<view class="hint">后台管理系统</view>

		<!-- 选馆信息 -->
		<view class="tenant-info" bindtap="bindSwitchTenantTap">
			<van-icon name="home-o" size="32rpx" color="#8799a3" custom-class="text-admin"  />
			<text class="tenant-name">{{tenantName || '未选择场馆'}}</text>
			<van-icon name="arrow" size="32rpx" color="#999999" custom-class="text-grey switch-icon"  />
		</view>

		<van-cell-group inset custom-class="login-form">
			<van-field
				value="{{ phone }}"
				label="手机号"
				type="number"
				placeholder="请输入管理员手机号"
				maxlength="11"
				data-field="phone"
				bind:change="bindFormChange"
			/>
			<van-field
				value="{{ pwd }}"
				label="密码"
				type="password"
				placeholder="请输入管理员密码"
				maxlength="30"
				data-field="pwd"
				bind:change="bindFormChange"
			/>
		</van-cell-group>

		<view class="form-submit-wrap">
			<van-button type="primary" block bind:click="bindLoginTap">点击登录</van-button>
		</view>

		<view bindtap="bindBackTap" class="return text-grey"><van-icon name="arrow-left" size="32rpx"  />返回</view>

	</view>

	<view class="foot-bottom">
		<cmpt-foot />
	</view>

</view>
<!-- [AI_END LINES=47 TIMESTAMP=2025-01-25 19:45:00] -->
