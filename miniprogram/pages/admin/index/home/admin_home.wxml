<!-- [AI_START TIMESTAMP=2025-01-25 18:20:00] -->
<view wx:if="{{!isLoad && !adminLoginShow}}" class="loading-wrap"><van-loading size="40rpx" color="#4a7c8c">加载中...</van-loading></view>

<view class="main-admin platform-shell" wx:if="{{isLoad && isAdmin}}">

  <!-- 超管：平台控制台 -->
  <block wx:if="{{admin.type=='super'}}">
    <!-- [AI_START TIMESTAMP=2025-01-27 10:40:00] -->
    <!-- Hero 渐变头：标题 + 身份 + 核心数据 -->
    <view class="platform-hero">
      <view class="platform-hero-top">
        <view class="platform-hero-info">
          <view class="platform-hero-title">平台管理</view>
          <view class="platform-hero-sub">{{admin.name}} · 超级管理员</view>
        </view>
        <view class="platform-hero-logout" bindtap="bindExitTap">
          <van-icon name="revoke" size="28rpx" />
          <text>退出</text>
        </view>
      </view>
      <view class="platform-hero-stats">
        <view class="platform-hero-stat">
          <text class="platform-hero-stat-num">{{data.tenantCount || 0}}</text>
          <text class="platform-hero-stat-label">瑜伽馆</text>
        </view>
        <view class="platform-hero-divider"></view>
        <view class="platform-hero-stat">
          <text class="platform-hero-stat-num">{{data.adminCount || 0}}</text>
          <text class="platform-hero-stat-label">管理员</text>
        </view>
      </view>
    </view>
<!-- [AI_START TIMESTAMP=2025-01-27 11:10:00] -->
<!-- Tab 切换 -->
<view class="platform-tabs">
  <view class="platform-tab {{platformTab === 0 ? 'platform-tab--active' : ''}}" bindtap="onPlatformTabTap" data-tab="0">
    <text>概览</text>
  </view>
  <view class="platform-tab {{platformTab === 1 ? 'platform-tab--active' : ''}}" bindtap="onPlatformTabTap" data-tab="1">
    <text>瑜伽馆</text>
    <text class="platform-tab-count">{{data.tenantList.length || 0}}</text>
  </view>
</view>

<!-- Tab 0: 概览 -->
<block wx:if="{{platformTab === 0}}">
  <view class="platform-section">
    <view class="platform-section-head">
      <text class="platform-section-title">快捷操作</text>
    </view>
    <view class="platform-action-grid">
      <view class="platform-action-item" bindtap="url" data-url="/pages/admin/platform/tenant_form/admin_tenant_form">
        <view class="platform-action-icon">
          <van-icon name="add-o" size="40rpx" color="#4a7c8c" />
        </view>
        <text class="platform-action-text">新建瑜伽馆</text>
      </view>
      <view class="platform-action-item" bindtap="url" data-url="/pages/admin/platform/mgr_form/admin_mgr_form">
        <view class="platform-action-icon">
          <van-icon name="manager-o" size="40rpx" color="#4a7c8c" />
        </view>
        <text class="platform-action-text">新建管理员</text>
      </view>
      <view class="platform-action-item" bindtap="bindPlatformTenantTabTap">
        <view class="platform-action-icon">
          <van-icon name="shop-o" size="40rpx" color="#4a7c8c" />
        </view>
        <text class="platform-action-text">瑜伽馆管理</text>
      </view>
      <view class="platform-action-item" bindtap="bindStaffManageTap">
        <view class="platform-action-icon">
          <van-icon name="friends-o" size="40rpx" color="#4a7c8c" />
        </view>
        <text class="platform-action-text">管理员配置</text>
      </view>
    </view>
  </view>

  <view class="platform-section platform-section--footer">
    <view class="platform-section-head">
      <text class="platform-section-title">系统</text>
    </view>
    <view class="platform-menu-item" bindtap="url" data-url="/pages/admin/mgr/log/admin_log_list">
      <van-icon name="description" size="32rpx" color="#4a7c8c" />
      <text class="platform-menu-text">操作日志</text>
      <van-icon name="arrow" size="24rpx" color="#c8c9cc" />
    </view>
    <view class="platform-menu-item" bindtap="bindSettingTap">
      <van-icon name="delete-o" size="32rpx" color="#4a7c8c" />
      <text class="platform-menu-text">清除缓存</text>
      <van-icon name="arrow" size="24rpx" color="#c8c9cc" />
    </view>
  </view>
</block>

<!-- Tab 1: 瑜伽馆 -->
<block wx:else>
  <view class="platform-section">
    <view wx:if="{{!data.tenantList.length}}" class="empty-block">暂无瑜伽馆，点击上方新建</view>
    <view class="tenant-row" wx:for="{{data.tenantList}}" wx:key="TENANT_ID">
      <view class="tenant-row-main">
        <text class="tenant-row-name">{{item.TENANT_NAME}}</text>
        <text class="tenant-row-desc" wx:if="{{item.TENANT_DESC}}">{{item.TENANT_DESC}}</text>
      </view>
      <view class="tenant-row-btn" data-item="{{item}}" bindtap="bindEnterCoachTap">管理</view>
    </view>
  </view>
</block>
<!-- [AI_END LINES=70 TIMESTAMP=2025-01-27 11:10:00] -->
  </block>

  <!-- [AI_START TIMESTAMP=2025-01-27 14:00:00] -->
  <!-- 馆长/教师：现代管理后台 -->
  <block wx:else>
    <!-- Hero 渐变头 -->
    <view class="platform-hero">
      <view class="platform-hero-top">
        <view class="platform-hero-info">
          <view class="platform-hero-title">{{admin.name}}</view>
          <view class="platform-hero-sub ah-hero-sub">
            <van-tag wx:if="{{admin.type=='owner'}}" round color="rgba(255,255,255,0.2)" text-color="#fff" size="small">馆长</van-tag>
            <van-tag wx:if="{{admin.type=='teacher'}}" round color="rgba(255,255,255,0.2)" text-color="#fff" size="small">教师</van-tag>
            <text wx:if="{{currentTenantName}}">{{currentTenantName}}</text>
          </view>
        </view>
        <view class="platform-hero-logout" bindtap="bindExitTap">
          <van-icon name="revoke" size="28rpx" />
          <text>退出</text>
        </view>
      </view>
      <view class="platform-hero-stats">
        <view class="platform-hero-stat" bindtap="url" data-url="/pages/admin/meet/list/admin_meet_list">
          <text class="platform-hero-stat-num">{{data.meetCnt || 0}}</text>
          <text class="platform-hero-stat-label">预约活动</text>
        </view>
        <view class="platform-hero-divider"></view>
        <view class="platform-hero-stat" bindtap="url" data-url="/pages/admin/meet/list/admin_meet_list">
          <text class="platform-hero-stat-num">{{data.joinCnt || 0}}</text>
          <text class="platform-hero-stat-label">预约数</text>
        </view>
        <view class="platform-hero-divider"></view>
        <view class="platform-hero-stat" bindtap="url" data-url="/pages/admin/user/list/admin_user_list">
          <text class="platform-hero-stat-num">{{data.userCnt || 0}}</text>
          <text class="platform-hero-stat-label">用户</text>
        </view>
        <block wx:if="{{admin.type=='owner'}}">
          <view class="platform-hero-divider"></view>
          <view class="platform-hero-stat" bindtap="url" data-url="/pages/admin/news/list/admin_news_list">
            <text class="platform-hero-stat-num">{{data.newsCnt || 0}}</text>
            <text class="platform-hero-stat-label">文章</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="platform-section">
      <view class="platform-section-head">
        <text class="platform-section-title">快捷操作</text>
      </view>
      <view class="platform-action-grid">
        <view class="platform-action-item" bindtap="url" data-url="/pages/admin/meet/list/admin_meet_list">
          <view class="platform-action-icon"><van-icon name="calendar-o" size="40rpx" color="#4a7c8c" /></view>
          <text class="platform-action-text">预约管理</text>
        </view>
        <view class="platform-action-item" wx:if="{{admin.type=='owner'}}" bindtap="url" data-url="/pages/coach/home/coach_home_content">
          <view class="platform-action-icon"><van-icon name="photo-o" size="40rpx" color="#4a7c8c" /></view>
          <text class="platform-action-text">首页内容</text>
        </view>
        <view class="platform-action-item" wx:if="{{admin.type=='owner'}}" bindtap="url" data-url="/pages/admin/news/list/admin_news_list">
          <view class="platform-action-icon"><van-icon name="newspaper-o" size="40rpx" color="#4a7c8c" /></view>
          <text class="platform-action-text">文章管理</text>
        </view>
        <view class="platform-action-item" bindtap="url" data-url="/pages/admin/user/list/admin_user_list">
          <view class="platform-action-icon"><van-icon name="friends-o" size="40rpx" color="#4a7c8c" /></view>
          <text class="platform-action-text">用户管理</text>
        </view>
        <view class="platform-action-item" bindtap="bindEnterCoachTap">
          <view class="platform-action-icon"><van-icon name="apps-o" size="40rpx" color="#4a7c8c" /></view>
          <text class="platform-action-text">教练端</text>
        </view>
      </view>
    </view>

    <!-- 系统 -->
    <view class="platform-section platform-section--footer">
      <view class="platform-section-head">
        <text class="platform-section-title">系统</text>
      </view>
      <view class="platform-menu-item" bindtap="url" data-url="/pages/admin/mgr/log/admin_log_list">
        <van-icon name="description" size="32rpx" color="#4a7c8c" />
        <text class="platform-menu-text">操作日志</text>
        <van-icon name="arrow" size="24rpx" color="#c8c9cc" />
      </view>
      <view class="platform-menu-item" bindtap="bindSettingTap">
        <van-icon name="delete-o" size="32rpx" color="#4a7c8c" />
        <text class="platform-menu-text">清除缓存</text>
        <van-icon name="arrow" size="24rpx" color="#c8c9cc" />
      </view>
    </view>
  </block>
  <!-- [AI_END LINES=78 TIMESTAMP=2025-01-27 14:00:00] -->

</view>

<cmpt-admin-login-panel
  show="{{adminLoginShow}}"
  mode="platform"
  redirect="admin_home"
  bind:close="bindAdminLoginCloseTap"
  bind:success="bindAdminLoginSuccessTap"
/>
