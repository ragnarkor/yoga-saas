@import "../../../../style/project/base/admin.wxss";

.main-admin.platform-shell {
  padding: 0;
  min-height: 100vh;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

/* [AI_START TIMESTAMP=2025-01-27 10:40:00] */
/* ========== 超管平台页 — Hero ========== */
.platform-hero {
  background: linear-gradient(
    135deg,
    var(--adminColor) 0%,
    var(--adminColorDark) 100%
  );
  padding: 40rpx 32rpx 36rpx;
  border-bottom-left-radius: var(--adminRadiusLg, 20rpx);
  border-bottom-right-radius: var(--adminRadiusLg, 20rpx);
  position: relative;
  overflow: hidden;
}

.platform-hero::after {
  content: "";
  position: absolute;
  top: -30%;
  right: -15%;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  pointer-events: none;
}

.platform-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.platform-hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}

.platform-hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.platform-hero-logout {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: var(--adminRadiusSm, 12rpx);
  background: rgba(255, 255, 255, 0.15);
  font-size: 24rpx;
  color: #fff;
  transition: background var(--adminTransition, 0.2s ease);
}

.platform-hero-logout:active {
  background: rgba(255, 255, 255, 0.25);
}

.platform-hero-stats {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  position: relative;
  z-index: 1;
}

.platform-hero-stat {
  flex: 1;
  text-align: center;
}

.platform-hero-stat-num {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.15;
}

.platform-hero-stat-label {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.platform-hero-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ========== 超管平台页 — Tab 切换 ========== */
.platform-tabs {
  display: flex;
  margin: 24rpx 24rpx 0;
  background: var(--adminSurface);
  border-radius: var(--adminRadius, 16rpx);
  padding: 6rpx;
  box-shadow: var(--adminShadowSm, 0 2rpx 8rpx rgba(74, 124, 140, 0.06));
}

.platform-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: var(--adminTextSecondary);
  border-radius: var(--adminRadiusSm, 12rpx);
  transition:
    background var(--adminTransition, 0.2s ease),
    color var(--adminTransition, 0.2s ease);
}

.platform-tab--active {
  background: var(--adminColor);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(74, 124, 140, 0.15);
}

.platform-tab-count {
  font-size: 22rpx;
  opacity: 0.7;
}

/* ========== 超管平台页 — 分区 ========== */
.platform-section {
  margin: 24rpx;
  background: var(--adminSurface);
  border-radius: var(--adminRadius, 16rpx);
  padding: 24rpx 20rpx 8rpx;
  box-shadow: var(--adminShadowSm, 0 2rpx 8rpx rgba(74, 124, 140, 0.06));
}

.platform-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 20rpx;
}

.platform-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--adminText);
}

.platform-section-count {
  font-size: 24rpx;
  color: var(--adminTextSecondary);
}

/* ========== 快捷操作网格 ========== */
.platform-action-grid {
  display: flex;
  gap: 8rpx;
}

.platform-action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 8rpx 28rpx;
  border-radius: var(--adminRadius, 16rpx);
  transition:
    background var(--adminTransition, 0.2s ease),
    transform var(--adminTransition, 0.2s ease);
}

.platform-action-item:active {
  background: var(--adminIconBg);
  transform: scale(0.94);
}

.platform-action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--adminRadius, 16rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  background: var(--adminColorLight);
  transition: transform var(--adminTransition, 0.2s ease);
}

.platform-action-item:active .platform-action-icon {
  transform: scale(0.88);
}

.platform-action-text {
  font-size: 24rpx;
  color: var(--adminText);
  text-align: center;
}

/* ========== 瑜伽馆列表 ========== */
.empty-block {
  margin: 0 8rpx 16rpx;
  padding: 48rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--adminTextSecondary);
  background: var(--adminIconBg);
  border-radius: var(--adminRadius, 16rpx);
  border: 1rpx dashed var(--adminBorder);
}

.tenant-row {
  display: flex;
  align-items: center;
  margin: 0 8rpx 16rpx;
  padding: 24rpx 28rpx;
  border-radius: var(--adminRadius, 16rpx);
  background: var(--adminPageBg);
  transition:
    transform var(--adminTransition, 0.2s ease),
    box-shadow var(--adminTransition, 0.2s ease);
}

.tenant-row:active {
  transform: scale(0.98);
  box-shadow: var(--adminShadow, 0 4rpx 16rpx rgba(74, 124, 140, 0.08));
}

.tenant-row-main {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.tenant-row-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--adminText);
}

.tenant-row-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--adminTextSecondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tenant-row-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--adminTextSecondary);
}

.tenant-row-actions {
  flex-shrink: 0;
  display: flex;
  gap: 12rpx;
}

.tenant-row-btn {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #fff;
  background: var(--adminColor);
  border-radius: var(--adminRadiusSm, 12rpx);
  transition: opacity var(--adminTransition, 0.2s ease);
}

.tenant-row-btn--ghost {
  color: var(--adminColor);
  background: var(--adminIconBg);
  border: 1rpx solid var(--adminBorder);
}

.tenant-row-btn:active {
  opacity: 0.7;
}

/* ========== 系统工具菜单 ========== */
.platform-section--footer {
  padding-bottom: 16rpx;
}

.platform-menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid var(--adminBorder);
  transition: background var(--adminTransition, 0.2s ease);
}

.platform-menu-item:last-child {
  border-bottom: none;
}

.platform-menu-item:active {
  background: var(--adminIconBg);
}

.platform-menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--adminText);
}
/* [AI_END LINES=210 TIMESTAMP=2025-01-27 10:40:00] */

/* [AI_START TIMESTAMP=2025-01-27 14:00:00] */
