@import '../../../../style/project/base/admin.wxss';

.main-admin.platform-shell {
  padding: 0;
  min-height: 100vh;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

/* ========== 超管平台页 ========== */
.platform-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 36rpx 32rpx 24rpx;
}

.platform-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--adminText);
  line-height: 1.3;
}

.platform-user {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--adminTextSecondary);
}

.platform-logout {
  font-size: 26rpx;
  color: var(--adminTextSecondary);
  padding: 8rpx 0 8rpx 16rpx;
}

.platform-stats {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 28rpx;
}

.stat-box {
  flex: 1;
  background: var(--adminSurface);
  border: 1rpx solid var(--adminBorder);
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
}

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: var(--adminColor);
  line-height: 1.2;
}

.stat-label {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--adminTextSecondary);
}

.platform-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 28rpx 12rpx;
  background: var(--adminSurface);
  border: 1rpx solid var(--adminBorder);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--adminText);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--adminText);
}

.section-count {
  font-size: 24rpx;
  color: var(--adminTextSecondary);
}

.empty-block {
  margin: 0 32rpx;
  padding: 48rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--adminTextSecondary);
  background: var(--adminSurface);
  border-radius: 12rpx;
  border: 1rpx dashed var(--adminBorder);
}

.tenant-row {
  display: flex;
  align-items: center;
  margin: 0 32rpx 16rpx;
  padding: 24rpx 28rpx;
  background: var(--adminSurface);
  border: 1rpx solid var(--adminBorder);
  border-radius: 12rpx;
}

.tenant-row-main {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.tenant-row-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--adminText);
}

.tenant-row-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--adminTextSecondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tenant-row-btn {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: var(--adminColor);
  border: 1rpx solid var(--adminColor);
  border-radius: 8rpx;
}

.platform-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx 32rpx 64rpx;
}

.footer-link {
  font-size: 26rpx;
  color: var(--adminTextSecondary);
}

.footer-dot {
  color: var(--adminBorder);
}

/* ========== 馆长传统页 ========== */
.admin-info {
  position: relative;
  height: 200rpx;
  width: 100%;
  color: #fff;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.admin-info .pic {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.admin-info .right .name {
  font-size: 32rpx;
  font-weight: 600;
}

.admin-info .exit-admin {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
}

.main-admin .comm-list.grid {
  margin: 24rpx;
  width: calc(100% - 48rpx);
  border-radius: 12rpx;
  border: 1rpx solid var(--adminBorder);
  background: var(--adminSurface);
}

.menu-group {
  margin: 0 24rpx 24rpx !important;
  border-radius: 12rpx !important;
  overflow: hidden;
}
