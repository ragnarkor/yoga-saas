<view class="main-admin tenant-page">

	<view class="tenant-page-head bg-admin">
		<view class="tenant-header">
			<view class="pic"><van-icon name="manager-o" size="40rpx" color="#fff" /></view>
			<view class="hint">??????????</view>
		</view>
	</view>

	<view wx:if="{{loading}}" class="loading-box">
		<van-loading size="48rpx" type="spinner" color="#4a7c8c">???...</van-loading>
	</view>

	<view wx:elif="{{tenantList.length === 0}}" class="empty-box">
		<view class="empty-icon">??</view>
		<view class="empty-text">??????</view>
		<view class="empty-sub">??????????</view>
		<van-button type="primary" size="small" bind:click="bindRefreshTap">??</van-button>
	</view>

	<view wx:else class="tenant-list">
		<van-cell-group inset>
			<van-cell
				wx:for="{{tenantList}}"
				wx:key="_id"
				title="{{item.TENANT_NAME}}"
				label="{{item.TENANT_DESC || ''}}"
				data-item="{{item}}"
				bind:click="bindSelectTap"
				is-link
				title-style="font-weight: 600; color: #2c3e44;"
			>
				<view slot="icon" class="tenant-icon">
					<van-icon name="home-o" size="32rpx" color="#4a7c8c" />
				</view>
			</van-cell>
		</van-cell-group>
	</view>

	<view class="foot-bottom">
		<cmpt-foot />
	</view>

</view>
<!-- [AI_END LINES=46 TIMESTAMP=2025-01-25 19:30:00] -->
