@import '../../../../style/project/base/admin.wxss';

.main-admin.tenant-page {
  min-height: 100vh;
  background: var(--adminPageBg);
  padding-bottom: 40rpx;
}

.tenant-page-head {
  padding: 48rpx 32rpx 56rpx;
  color: #fff;
  box-shadow: var(--adminShadow);
}

.tenant-header {
  text-align: center;
  padding: 16rpx 0 0;
}

.tenant-header .pic {
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tenant-header .hint {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

.tenant-list {
  padding: 24rpx;
  margin-top: -28rpx;
}

.tenant-list .van-cell-group {
  border-radius: 20rpx !important;
  overflow: hidden;
  box-shadow: var(--adminShadow);
}

.tenant-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: var(--adminColorLight);
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-box {
  text-align: center;
  padding: 80rpx 40rpx 100rpx;
  background: var(--adminSurface);
  margin: 0 24rpx;
  border-radius: 20rpx;
  box-shadow: var(--adminShadow);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--adminText);
  margin-bottom: 10rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--adminTextSecondary);
  margin-bottom: 30rpx;
}

.foot-bottom {
  padding: 24rpx 0 48rpx;
}
