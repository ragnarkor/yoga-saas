@import "../../../../style/project/base/admin.wxss";

/* [AI_START TIMESTAMP=2025-01-27 09:50:00] */
page {
  background-color: var(--adminPageBg);
}

.join-list {
  width: 100%;
  padding: 0rpx 20rpx 20rpx;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  position: relative;
}

.join-list .item {
  width: 100%;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  background-color: var(--adminSurface);
  border-radius: var(--adminRadius, 16rpx);
  overflow: hidden;
  margin-bottom: 24rpx;
  position: relative;
  box-shadow: var(--adminShadowSm, 0 2rpx 8rpx rgba(74, 124, 140, 0.06));
}

.join-list .item .no {
  position: absolute;
  right: 0;
  bottom: 0;
  font-size: 25rpx;
  color: var(--adminTextSecondary);
  line-height: 2;
  padding: 0rpx 15rpx 0rpx 15rpx;
  background-color: var(--adminIconBg);
  border-top-left-radius: var(--adminRadiusSm, 12rpx);
}

.join-list .item .header {
  width: 100%;
  font-size: 26rpx;
  text-align: left;
  line-height: 2.6;
  background-color: var(--adminIconBg);
  padding: 0 15rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.join-list .item .header .left {
  color: var(--adminText);
}

.join-list .item .header .right {
  font-size: 25rpx;
  color: var(--adminTextSecondary);
}
/* [AI_END LINES=54 TIMESTAMP=2025-01-27 09:50:00] */

.join-list .item .info {
  width: 100%;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  background-color: var(--adminSurface);
  min-height: 150rpx;
  padding: 15rpx 20rpx 20rpx;
  position: relative;
}

.join-list .item .info .right-corner {
  position: absolute;
  left: 10rpx;
  top: 0;
  width: 100rpx;
  height: 50rpx;
}

.join-list .item .info .fold {
  width: 100%;
  text-align: center;
  font-size: 24rpx;
  color: var(--adminTextSecondary);
  padding: 0 20rpx 10rpx;
}

.join-list .item .info .info-item {
  width: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  line-height: 1.5;
  font-size: 25rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.join-list .item .info .info-item .title {
  width: 160rpx;
  color: var(--adminText);
  text-align: right;
}

.join-list .item .info .info-item .mao {
  color: var(--adminText);
  text-align: left;
  margin-right: 10rpx;
}

.join-list .item .info .info-item .content {
  flex: 1;
  color: var(--adminTextSecondary);
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
}

.join-list .item .info .info-item.add-time {
  font-size: 24rpx !important;
  font-weight: normal !important;
  border-top: 1rpx dashed var(--adminBorder);
  padding-top: 15rpx;
}

.join-list .item .info .oprt {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0rpx 0 0rpx;
}

.join-list .item .info .oprt .btn {
  padding: 0 30rpx;
  font-size: 26rpx;
  border-radius: var(--adminRadiusSm, 12rpx) !important;
}

.cancel-area {
  border: 1rpx solid var(--adminBorder);
}

.time-line {
  width: 100%;
  text-align: right;
  font-size: 24rpx;
}
