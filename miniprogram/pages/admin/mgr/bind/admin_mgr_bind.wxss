@import '../../../../style/project/base/admin.wxss';

.mgr-bind-page {
  min-height: 100vh;
  background: var(--adminPageBg);
  padding: 24rpx;
  box-sizing: border-box;
}

.tip {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.tip.sub {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.loading-wrap,
.empty {
  text-align: center;
  padding: 80rpx 24rpx;
  color: #999;
  line-height: 1.6;
}

.item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.type-tag {
  font-size: 22rpx;
  color: #9b6fd4;
  background: #f3e8ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.status {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.status-bound {
  color: #07c160;
}

.status-unbound {
  color: #999;
}

.hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #e6a23c;
}

.item-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  flex: 1 1 40%;
  min-width: 180rpx;
  text-align: center;
  font-size: 26rpx;
  color: #4a7c8c;
  padding: 18rpx 12rpx;
  border: 1rpx solid #4a7c8c;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.btn.unbind {
  color: #e54d42;
  border-color: #e54d42;
}

.btn.delete {
  color: #999;
  border-color: #ccc;
}

.btn.disabled {
  color: #ccc;
  border-color: #ddd;
  background: #fafafa;
}
