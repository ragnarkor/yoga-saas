<view class="mgr-bind-page">
  <view class="tip">当前馆：{{tenantName || '请先选择瑜伽馆'}}</view>
  <view class="tip sub">{{roleTip}}</view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <van-loading size="40rpx">加载中...</van-loading>
  </view>

  <view wx:elif="{{list.length === 0}}" class="empty">
    本馆暂无馆长/教练账号。请确认已在后台首页选择了正确的瑜伽馆。
  </view>

  <view wx:else class="list">
    <view class="item" wx:for="{{list}}" wx:key="id">
      <view class="item-main">
        <view class="name-row">
          <text class="name">{{item.name}}</text>
          <text class="type-tag">{{item.typeLabel}}</text>
        </view>
        <view class="meta">手机：{{item.phone}}</view>
        <view class="status {{item.bound ? 'status-bound' : 'status-unbound'}}">
          微信绑定：{{item.bound ? '已绑定' : '未绑定'}}
          <text wx:if="{{item.boundOpenid}}">（…{{item.boundOpenid}}）</text>
        </view>
        <view class="hint" wx:if="{{item.type === 'owner' && !item.canGenCode}}">
          馆长绑定码需由超管生成
        </view>
      </view>
      <view class="item-actions">
        <view
          wx:if="{{item.canGenCode}}"
          class="btn"
          bindtap="bindGenTap"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
        >生成绑定码</view>
        <view
          class="btn unbind {{item.bound && item.canUnbind ? '' : 'disabled'}}"
          bindtap="bindUnbindTap"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          data-bound="{{item.bound}}"
          data-can-unbind="{{item.canUnbind}}"
        >解除绑定</view>
      </view>
    </view>
  </view>
</view>
