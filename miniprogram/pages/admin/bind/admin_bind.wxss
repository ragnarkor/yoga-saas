/* [AI_START TIMESTAMP=2025-01-27 16:30:00] */
/* ========== 页面基础 ========== */
.bind-page {
  min-height: 100vh;
  background: #f5f6f7;
}

/* ========== 顶部品牌区 ========== */
.bind-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 88rpx 48rpx 100rpx;
  background: linear-gradient(160deg, #4a7c8c 0%, #3a6572 100%);
  border-radius: 0 0 32rpx 32rpx;
}

.bind-hero-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  margin-bottom: 24rpx;
}

.bind-hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.bind-hero-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ========== 状态卡片 ========== */
.bind-card {
  margin: -64rpx 32rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.bind-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 40rpx 40rpx;
}

/* ========== 加载状态 ========== */
.bind-status-loading {
  margin-bottom: 24rpx;
}

/* ========== 状态图标 ========== */
.bind-status-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
  animation: bind-pop-in 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.bind-status-icon--success {
  background: linear-gradient(135deg, #34c759, #28a745);
}

.bind-status-icon--error {
  background: linear-gradient(135deg, #ff6b6b, #dc3545);
}

@keyframes bind-pop-in {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ========== 标题文字 ========== */
.bind-status-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #323233;
  margin-bottom: 20rpx;
}

.bind-status-title--error {
  color: #e54d42;
}

.bind-status-desc {
  font-size: 28rpx;
  color: #969799;
  text-align: center;
  line-height: 1.5;
}

.bind-status-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #c8c9cc;
}

/* ========== 角色身份 ========== */
.bind-role {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.bind-role-label {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #f0f5ff;
  font-size: 24rpx;
  color: #4a7c8c;
}

.bind-role-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #323233;
}

/* ========== 场馆信息 ========== */
.bind-tenant {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.bind-tenant-name {
  font-size: 26rpx;
  color: #646566;
}

/* ========== 提示文本（失败） ========== */
.bind-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 16rpx 0 32rpx;
}

.bind-tips-text {
  font-size: 24rpx;
  color: #969799;
}

/* ========== 按钮组 ========== */
.bind-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}

.bind-btn-primary {
  border: none !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border-radius: 44rpx !important;
}

.bind-btn-secondary {
  font-size: 30rpx !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border-radius: 44rpx !important;
  border: 2rpx solid #ebedf0 !important;
  color: #646566 !important;
}

.bind-btn-secondary::after {
  border: none !important;
}
