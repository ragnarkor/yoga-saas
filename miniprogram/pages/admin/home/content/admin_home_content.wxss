@import "../../../../style/project/base/admin.wxss";

.ahc-shell {
  min-height: 100vh;
  background: var(--adminPageBg, #f5f6f8);
  padding-bottom: 40rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

/* ========== 说明栏 ========== */
.ahc-info-bar {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin: 16rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: var(--adminColorLight, #eef3f4);
  border-radius: var(--adminRadius, 16rpx);
}

.ahc-info-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--adminTextSecondary, #8a9aa3);
  line-height: 1.6;
}

/* ========== Tab 内容区 ========== */
.ahc-tab-body {
  padding: 24rpx;
}

/* ========== 添加按钮 ========== */
.ahc-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx dashed var(--adminBorder, #e8ecef);
  border-radius: var(--adminRadius, 16rpx);
  background: var(--adminSurface, #fff);
  font-size: 28rpx;
  color: var(--adminColor, #4a7c8c);
  transition: background var(--adminTransition, 0.2s ease);
}

.ahc-add-btn:active {
  background: var(--adminColorLight, #eef3f4);
}

/* ========== 提示行 ========== */
.ahc-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.ahc-hint-text {
  font-size: 24rpx;
  color: var(--adminTextSecondary, #8a9aa3);
}

/* ========== 空状态 ========== */
.ahc-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.ahc-empty-text {
  font-size: 26rpx;
  color: var(--adminTextTertiary, #adb8be);
}

/* ========== 内容卡片 ========== */
.ahc-card {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  background: var(--adminSurface, #fff);
  border-radius: var(--adminRadius, 16rpx);
  box-shadow: var(--adminShadowSm, 0 2rpx 8rpx rgba(74, 124, 140, 0.06));
  transition: transform var(--adminTransition, 0.2s ease);
}

.ahc-card:active {
  transform: scale(0.98);
}

.ahc-card-body {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.ahc-card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--adminRadiusSm, 12rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.ahc-card-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--adminRadiusSm, 12rpx);
  flex-shrink: 0;
  margin-right: 20rpx;
  background: var(--adminIconBg, #f2f4f5);
}

.ahc-card-icon--banner {
  background: var(--adminColorLight, #eef3f4);
}

.ahc-card-icon--announce {
  background: rgba(212, 168, 67, 0.12);
}

.ahc-card-icon--photo {
  background: rgba(138, 184, 166, 0.15);
}

.ahc-card-info {
  flex: 1;
  min-width: 0;
}

.ahc-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--adminText, #1a2b32);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ahc-card-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--adminTextSecondary, #8a9aa3);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ahc-card-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.ahc-card-edit {
  padding: 12rpx;
  transition: opacity var(--adminTransition, 0.2s ease);
}

.ahc-card-edit:active {
  opacity: 0.6;
}

.ahc-card-del {
  padding: 12rpx;
  transition: opacity var(--adminTransition, 0.2s ease);
}

.ahc-card-del:active {
  opacity: 0.6;
}

/* ========== 弹窗 ========== */
.ahc-popup {
  border-radius: var(--adminRadiusLg, 20rpx) var(--adminRadiusLg, 20rpx) 0 0 !important;
}

.ahc-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
}

.ahc-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--adminText, #1a2b32);
}

.ahc-popup-close {
  padding: 8rpx;
}

.ahc-popup-form {
  padding: 0 32rpx;
}

.ahc-popup-footer {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* ========== 图片上传 ========== */
.ahc-upload-section {
  padding: 24rpx 32rpx;
}

.ahc-upload-label {
  display: block;
  font-size: 28rpx;
  color: var(--adminText, #1a2b32);
  margin-bottom: 16rpx;
}

.ahc-upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--adminBorder, #e8ecef);
  border-radius: var(--adminRadius, 16rpx);
  background: var(--adminIconBg, #f2f4f5);
  transition: border-color var(--adminTransition, 0.2s ease);
}

.ahc-upload-placeholder:active {
  border-color: var(--adminColor, #4a7c8c);
}

.ahc-upload-text {
  font-size: 24rpx;
  color: var(--adminTextTertiary, #adb8be);
}

.ahc-upload-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--adminRadius, 16rpx);
  overflow: hidden;
}

.ahc-upload-img {
  width: 100%;
  height: 100%;
}

.ahc-upload-del {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== VANT tabs 调整 ========== */
.ahc-shell .van-tabs__wrap {
  background: var(--adminSurface, #fff);
}
