<!-- [AI_START TIMESTAMP=2025-01-27 15:00:00] -->
<view wx:if="{{!isLoad}}" class="loading-wrap">
  <van-loading size="40rpx" color="#4a7c8c">加载中...</van-loading>
</view>

<view wx:else class="ahc-shell">
  <!-- 说明栏 -->
  <view class="ahc-info-bar">
    <van-icon name="info-o" size="28rpx" color="#4a7c8c" />
    <text class="ahc-info-text">管理首页横幅、公告与照片墙。教练信息由员工绑定后自动展示。</text>
  </view>

  <van-tabs active="{{activeTab}}" bind:change="bindTabChange" color="#4a7c8c" line-width="48rpx" title-active-color="#4a7c8c">

    <!-- 横幅 -->
    <van-tab title="横幅">
      <view class="ahc-tab-body">
        <view class="ahc-add-btn" data-type="banner" bindtap="bindAddTap">
          <van-icon name="add-o" size="32rpx" color="#4a7c8c" />
          <text>新增横幅</text>
        </view>
        <view wx:if="{{!banners.length}}" class="ahc-empty">
          <van-icon name="photo-o" size="80rpx" color="#c8c9cc" />
          <text class="ahc-empty-text">暂无横幅，点击上方按钮添加</text>
        </view>
        <view class="ahc-card" wx:for="{{banners}}" wx:key="_id">
          <view class="ahc-card-body">
            <image wx:if="{{item.BANNER_PIC}}" src="{{item.BANNER_PIC}}" mode="aspectFill" class="ahc-card-thumb" />
            <view wx:else class="ahc-card-icon ahc-card-icon--banner">
              <van-icon name="photo-o" size="32rpx" color="#4a7c8c" />
            </view>
            <view class="ahc-card-info">
              <text class="ahc-card-title">{{item.BANNER_TITLE || '未命名横幅'}}</text>
              <text class="ahc-card-desc">{{item.BANNER_TYPE || 'image'}} · 排序 {{item.BANNER_ORDER}}</text>
            </view>
          </view>
          <view class="ahc-card-actions">
            <view class="ahc-card-edit" data-type="banner" data-id="{{item._id}}" catchtap="bindEditTap">
              <van-icon name="edit" size="32rpx" color="#4a7c8c" />
            </view>
            <view class="ahc-card-del" data-type="banner" data-id="{{item._id}}" catchtap="bindDelTap">
              <van-icon name="delete-o" size="32rpx" color="#d9644a" />
            </view>
          </view>
        </view>
      </view>
    </van-tab>

    <!-- 公告 -->
    <van-tab title="公告">
      <view class="ahc-tab-body">
        <view class="ahc-add-btn" data-type="announce" bindtap="bindAddTap">
          <van-icon name="add-o" size="32rpx" color="#4a7c8c" />
          <text>新增公告</text>
        </view>
        <view wx:if="{{!announces.length}}" class="ahc-empty">
          <van-icon name="bell" size="80rpx" color="#c8c9cc" />
          <text class="ahc-empty-text">暂无公告，点击上方按钮添加</text>
        </view>
        <view class="ahc-card" wx:for="{{announces}}" wx:key="_id">
          <view class="ahc-card-body">
            <view class="ahc-card-icon ahc-card-icon--announce">
              <van-icon name="bell" size="32rpx" color="#d4a843" />
            </view>
            <view class="ahc-card-info">
              <text class="ahc-card-title">{{item.ANNOUNCE_TITLE}}</text>
              <text class="ahc-card-desc">{{item.ANNOUNCE_DESC || '无描述'}}</text>
            </view>
          </view>
          <view class="ahc-card-actions">
            <view class="ahc-card-edit" data-type="announce" data-id="{{item._id}}" catchtap="bindEditTap">
              <van-icon name="edit" size="32rpx" color="#4a7c8c" />
            </view>
            <view class="ahc-card-del" data-type="announce" data-id="{{item._id}}" catchtap="bindDelTap">
              <van-icon name="delete-o" size="32rpx" color="#d9644a" />
            </view>
          </view>
        </view>
      </view>
    </van-tab>

    <!-- 照片墙 -->
    <van-tab title="照片墙">
      <view class="ahc-tab-body">
        <view class="ahc-hint">
          <van-icon name="question-o" size="24rpx" color="#8a9aa3" />
          <text class="ahc-hint-text">「描述」填相册名称，相同名称归为一组</text>
        </view>
        <view class="ahc-add-btn" data-type="photo" bindtap="bindAddTap">
          <van-icon name="add-o" size="32rpx" color="#4a7c8c" />
          <text>新增照片</text>
        </view>
        <view wx:if="{{!photos.length}}" class="ahc-empty">
          <van-icon name="grid-o" size="80rpx" color="#c8c9cc" />
          <text class="ahc-empty-text">暂无照片，点击上方按钮添加</text>
        </view>
        <view class="ahc-card" wx:for="{{photos}}" wx:key="_id">
          <view class="ahc-card-body">
            <image wx:if="{{item.PHOTO_PIC}}" src="{{item.PHOTO_PIC}}" mode="aspectFill" class="ahc-card-thumb" />
            <view wx:else class="ahc-card-icon ahc-card-icon--photo">
              <van-icon name="grid-o" size="32rpx" color="#8ab8a6" />
            </view>
            <view class="ahc-card-info">
              <text class="ahc-card-title">{{item.PHOTO_TITLE || '照片'}}</text>
              <text class="ahc-card-desc">{{item.PHOTO_DESC || '无描述'}}</text>
            </view>
          </view>
          <view class="ahc-card-actions">
            <view class="ahc-card-edit" data-type="photo" data-id="{{item._id}}" catchtap="bindEditTap">
              <van-icon name="edit" size="32rpx" color="#4a7c8c" />
            </view>
            <view class="ahc-card-del" data-type="photo" data-id="{{item._id}}" catchtap="bindDelTap">
              <van-icon name="delete-o" size="32rpx" color="#d9644a" />
            </view>
          </view>
        </view>
      </view>
    </van-tab>

  </van-tabs>
</view>

<!-- 统一新增/编辑弹窗 -->
<van-popup show="{{popupShow}}" position="bottom" round bind:close="bindPopupClose" custom-class="ahc-popup">
  <view class="ahc-popup-header">
    <text class="ahc-popup-title">{{popupTitle}}</text>
    <view class="ahc-popup-close" bindtap="bindPopupClose">
      <van-icon name="cross" size="36rpx" color="#969799" />
    </view>
  </view>
  <view class="ahc-popup-form">
    <van-field
      value="{{form.title}}"
      data-field="title"
      bind:input="bindFormInput"
      label="标题"
      placeholder="请输入标题"
      border="{{ false }}"
    />
    <van-field
      wx:if="{{popupType == 'announce' || popupType == 'photo'}}"
      value="{{form.desc}}"
      data-field="desc"
      bind:input="bindFormInput"
      label="描述"
      type="textarea"
      placeholder="{{popupType == 'photo' ? '相册名称（相同名称归组）' : '请输入描述'}}"
      autosize="{{ {maxHeight: 200} }}"
      border="{{ false }}"
    />
    <!-- 图片上传区域（横幅和照片） -->
    <view wx:if="{{popupType == 'banner' || popupType == 'photo'}}" class="ahc-upload-section">
      <view class="ahc-upload-label">图片</view>
      <view wx:if="{{imgList.length}}" class="ahc-upload-preview">
        <image src="{{imgList[0]}}" mode="aspectFill" class="ahc-upload-img" />
        <view class="ahc-upload-del" catchtap="bindDelImg">
          <van-icon name="cross" size="28rpx" color="#fff" />
        </view>
      </view>
      <view wx:else class="ahc-upload-placeholder" bindtap="bindChooseImg">
        <van-icon name="photograph" size="48rpx" color="#c8c9cc" />
        <text class="ahc-upload-text">选择图片</text>
      </view>
    </view>
  </view>
  <view class="ahc-popup-footer">
    <van-button type="primary" block bindtap="bindSubmitTap" loading="{{submitting}}">{{submitBtnText}}</van-button>
  </view>
</van-popup>
<!-- [AI_END LINES=140 TIMESTAMP=2025-01-27 15:00:00] -->
