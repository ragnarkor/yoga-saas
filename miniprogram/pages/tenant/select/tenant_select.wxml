<!-- [AI_START TIMESTAMP=2025-01-25 19:10:00] -->
<view wx:if="{{!isLoad}}" class="loading-wrap">
	<van-loading size="40rpx">加载中...</van-loading>
</view>

<view class="tenant-select" wx:if="{{isLoad}}">
	<view class="header">
		<van-icon name="home-o" size="44rpx" color="#0081ff" custom-class="text-xxl text-blue"  />
		<text class="text-xl margin-left-s">选择瑜伽馆</text>
	</view>

	<view wx:if="{{list.length==0}}" class="empty-tip">
		<van-icon name="notes-o" size="32rpx" color="#999999" custom-class="text-gray"  />
		<view class="text-grey margin-top">暂无可用瑜伽馆</view>
	</view>

	<view class="tenant-list" wx:if="{{list.length>0}}">
		<view class="tenant-card" wx:for="{{list}}" wx:key="TENANT_ID"
			bindtap="bindSelectTap" data-item="{{item}}">

			<view class="tenant-logo">
					<image wx:if="{{item.TENANT_LOGO}}" src="{{item.TENANT_LOGO}}" mode="aspectFill" class="logo-img" />
					<van-icon wx:else name="home-o" size="56rpx" color="#0081ff" custom-class="text-xxxl text-blue" />
				</view>

			<view class="tenant-info">
				<view class="tenant-name text-lg">{{item.TENANT_NAME}}</view>
				<view class="tenant-desc text-s text-grey" wx:if="{{item.TENANT_DESC}}">{{item.TENANT_DESC}}</view>
			</view>

			<view class="tenant-arrow">
				<van-icon name="arrow" size="32rpx" color="#999999" custom-class="text-grey"  />
			</view>
		</view>
	</view>
</view>
<!-- [AI_END LINES=31 TIMESTAMP=2025-01-25 19:10:00] -->
