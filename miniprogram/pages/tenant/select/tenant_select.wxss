/* [AI_START TIMESTAMP=2025-01-25 19:10:00] */
.tenant-select {
  padding: 20rpx;
  min-height: 100vh;
  background: #f6f7f5;
}

.header {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
}

.header-title {
  color: var(--themeColor, #5b8a72);
  font-weight: 600;
}

.tenant-empty {
  padding: 40rpx 0 80rpx;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  color: var(--neutralTextSecondary, #646a73);
}

.invite-gate {
  margin: 24rpx 20rpx 0;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.invite-title {
  margin-top: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--neutralText, #1f2329);
}

.invite-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--neutralTextSecondary, #646a73);
}

.invite-steps {
  margin-top: 32rpx;
  text-align: left;
  padding: 24rpx 28rpx;
  background: var(--themeColorLight, #f0f5f1);
  border-radius: 12rpx;
}

.invite-step {
  font-size: 24rpx;
  color: var(--neutralTextSecondary, #646a73);
  line-height: 1.8;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.tenant-list {
  padding-bottom: 40rpx;
}

.tenant-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tenant-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--themeColorLight, #f0f5f1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.logo-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.tenant-info {
  flex: 1;
  margin-left: 24rpx;
}

.tenant-name {
  font-weight: bold;
  color: var(--neutralText, #1f2329);
}

.tenant-desc {
  margin-top: 8rpx;
  color: var(--neutralTextSecondary, #646a73);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tenant-arrow-icon {
  opacity: 0.45;
}

.tenant-arrow {
  flex-shrink: 0;
  padding-left: 10rpx;
}
/* [AI_END LINES=49 TIMESTAMP=2025-01-25 19:10:00] */
