/* [AI_START TIMESTAMP=2025-01-25 19:10:00] */
.tenant-select {
  padding: 20rpx;
  min-height: 100vh;
  background: #f6f7f5;
}

.header {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
}

.header-title {
  color: var(--themeColor, #5b8a72);
  font-weight: 600;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
}

.tenant-list {
  padding-bottom: 40rpx;
}

.tenant-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tenant-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--themeColorLight, #f0f5f1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.logo-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.tenant-info {
  flex: 1;
  margin-left: 24rpx;
}

.tenant-name {
  font-weight: bold;
  color: #333;
}

.tenant-desc {
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tenant-arrow {
  flex-shrink: 0;
  padding-left: 10rpx;
}
